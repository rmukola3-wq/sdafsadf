local function resetMods()
    for k in pairs(ModTable.camRecoilMod) do ModTable.camRecoilMod[k] = 1 end
    for k in pairs(ModTable.gunRecoilMod) do ModTable.gunRecoilMod[k] = 1 end
    ModTable.AimRM=1; ModTable.SpreadRM=1; ModTable.DamageMod=1; ModTable.minDamageMod=1
    ModTable.MinRecoilPower=1; ModTable.MaxRecoilPower=1; ModTable.RecoilPowerStepAmount=1
    ModTable.MinSpread=1; ModTable.MaxSpread=1
    ModTable.AimInaccuracyStepAmount=1; ModTable.AimInaccuracyDecrease=1
    ModTable.WalkMult=1; ModTable.MuzzleVelocity=1
end

local function setMods(d)
    local c, g = ModTable.camRecoilMod, ModTable.gunRecoilMod
    c.RecoilUp    = c.RecoilUp    * d.camRecoil.RecoilUp
    c.RecoilLeft  = c.RecoilLeft  * d.camRecoil.RecoilLeft
    c.RecoilRight = c.RecoilRight * d.camRecoil.RecoilRight
    c.RecoilTilt  = c.RecoilTilt  * d.camRecoil.RecoilTilt
    g.RecoilUp    = g.RecoilUp    * d.gunRecoil.RecoilUp
    g.RecoilTilt  = g.RecoilTilt  * d.gunRecoil.RecoilTilt
    g.RecoilLeft  = g.RecoilLeft  * d.gunRecoil.RecoilLeft
    g.RecoilRight = g.RecoilRight * d.gunRecoil.RecoilRight
    ModTable.AimRM            = ModTable.AimRM            * d.AimRecoilReduction
    ModTable.SpreadRM         = ModTable.SpreadRM         * d.AimSpreadReduction
    ModTable.DamageMod        = ModTable.DamageMod        * d.DamageMod
    ModTable.minDamageMod     = ModTable.minDamageMod     * d.minDamageMod
    ModTable.MinRecoilPower        = ModTable.MinRecoilPower        * d.MinRecoilPower
    ModTable.MaxRecoilPower        = ModTable.MaxRecoilPower        * d.MaxRecoilPower
    ModTable.RecoilPowerStepAmount = ModTable.RecoilPowerStepAmount * d.RecoilPowerStepAmount
    ModTable.MinSpread               = ModTable.MinSpread               * d.MinSpread
