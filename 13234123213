local function RequestEquip(tool)
    PendingTool=tool; EquipToken+=1
    if SwitchWorkerRunning then return end
    SwitchWorkerRunning=true
    task.spawn(function()
        while PendingTool do
            local t=PendingTool; PendingTool=nil
            if ToolEquip then unset() end
            if t and t.Parent==char then setup(t) end
        end
        SwitchWorkerRunning=false
    end)
end

char.ChildAdded:Connect(function(Tool)
    if Tool:IsA("Tool") and Humanoid.Health>0 and Tool:FindFirstChild("ACS_Settings") then
        local ok,cfg=pcall(require,Tool.ACS_Settings)
        if not ok then return end
        if cfg.Type=="Gun" or cfg.Type=="Melee" or cfg.Type=="Grenade" then
            if Humanoid.Sit and Humanoid.SeatPart and Humanoid.SeatPart:IsA("VehicleSeat") then return end
            if ToolEquip and Tool==WeaponTool then return end
            RequestEquip(Tool)
        end
    end
end)

char.ChildRemoved:Connect(function(Tool)
    task.delay(0.05,function()
        if Tool==WeaponTool and ToolEquip then unset() end
    end)
end)

