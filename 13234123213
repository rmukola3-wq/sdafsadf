-- [ИСПРАВЛЕНИЕ 2] Таблица алиасов: логическое имя → реальное имя Animation-инстанса
-- Позволяет вызывать PlayVMAnim("HighReady") когда объект называется "High Ready"
local ANIM_ALIASES = {
    HighReady      = "High Ready",
    LowReady       = "Low Ready",
    MagCheck       = "Mag Check",
    TacticalReload = "EmptyReload",
    Pump           = "Chamber",
    -- Остальные совпадают: Equip, Unequip, Idle, Sprint, Reload, Patrol, Fire, Chamber, AimFire
}

-- Fallback-карта из корневого AnimFolder (на случай отсутствия в платформе)
local FallbackAnimMap = {}
local function BuildFallbackMap()
    FallbackAnimMap = {}
    for _, obj in ipairs(AnimFolder:GetChildren()) do
        if obj:IsA("Animation") then FallbackAnimMap[obj.Name] = obj end
    end
end
BuildFallbackMap()

--- Получить Animation-объект по логическому имени.
--- Сначала ищет в CurrentVMAnimFolder, потом в FallbackAnimMap.
local function FindAnimObject(logicalName)
    -- Разрешаем алиас
    local realName = ANIM_ALIASES[logicalName] or logicalName

    -- Ищем в текущей папке платформы
    if CurrentVMAnimFolder then
        local obj = CurrentVMAnimFolder:FindFirstChild(realName)
        if obj and obj:IsA("Animation") then return obj end
    end

    -- Fallback: корневой AnimFolder
    local obj = FallbackAnimMap[realName]
    if obj then return obj end

    -- Последняя попытка: по логическому имени без алиаса
    if realName ~= logicalName then
        local obj2 = FallbackAnimMap[logicalName]
        if obj2 then return obj2 end
    end

    warn("[ACS Anim] Анимация не найдена:", logicalName, "→", realName)
    return nil
end

-- AnimationController/Animator (живут в ViewModel, создаются в setup)
local VMAnimController = nil
local VMAnimator       = nil

-- Кеш загруженных треков: логическое_имя → AnimationTrack
local AnimTrackCache = {}
-- Активные треки по логическому имени
local ActiveTracks   = {}
-- [ИСПРАВЛЕНИЕ 3] Каналы: имя_канала → AnimationTrack
local ActiveChannels = {}

--- Инициализировать AnimationController+Animator в ViewModel.
-- [ИСПРАВЛЕНО] Убрана необъявленная переменная VMAnimTrackCache
local function InitVMAnimator(viewModel)
    AnimTrackCache  = {}    -- сброс кеша треков при новом ViewModel
    ActiveTracks    = {}
    ActiveChannels  = {}

    VMAnimController = viewModel:FindFirstChildOfClass("AnimationController")
    if not VMAnimController then
        VMAnimController = Instance.new("AnimationController", viewModel)
    end
    VMAnimator = VMAnimController:FindFirstChildOfClass("Animator")
    if not VMAnimator then
        VMAnimator = Instance.new("Animator", VMAnimController)
    end
end

--- Загрузить (или взять из кеша) AnimationTrack по логическому имени.
local function GetVMTrack(logicalName)
    if not VMAnimator then return nil end

    -- Инвалидируем протухший трек (Animator был пересоздан)
    local cached = AnimTrackCache[logicalName]
    if cached then
        -- Если Animation больше не имеет родителя — трек устарел
        local ok = pcall(function() return cached.Animation.Parent end)
        if not ok then AnimTrackCache[logicalName] = nil; cached = nil end
    end
    if cached then return cached end

    local animObj = FindAnimObject(logicalName)
    if not animObj then return nil end

    local ok, track = pcall(function() return VMAnimator:LoadAnimation(animObj) end)
    if not ok then
        warn("[ACS Anim] LoadAnimation failed:", logicalName, track)
        return nil
    end
    AnimTrackCache[logicalName] = track
    return track
end

--[[
    PlayVMAnim(logicalName, options)
    ────────────────────────────────
    options:
      FadeTime  number                  — фейд (default 0.10)
      Speed     number                  — скорость (default 1)
      Looped    boolean                 — зацикленность (default false)
      Priority  Enum.AnimationPriority  — приоритет (default Action)
      Channel   string|nil             — канал (останавливает пред. трек в канале)
      StopPrev  boolean                 — остановить пред. трек в канале (default true)
--]]
local function PlayVMAnim(logicalName, options)
    if not VMAnimator then
        warn("[ACS Anim] VMAnimator не инициализирован, попытка:", logicalName)
        return nil
    end

    options = options or {}
    local fadeTime = options.FadeTime or 0.10
    local speed    = options.Speed    or 1
    local looped   = options.Looped   or false
    local priority = options.Priority or Enum.AnimationPriority.Action
    local channel  = options.Channel  -- nil = без канала
    local stopPrev = options.StopPrev
    if stopPrev == nil then stopPrev = true end

    -- [ИСПРАВЛЕНИЕ 3] Если задан канал и StopPrev=true — останавливаем текущий трек в канале
    if channel and stopPrev then
        local prev = ActiveChannels[channel]
        if prev and prev.IsPlaying then
            prev:Stop(fadeTime)
        end
        ActiveChannels[channel] = nil
    end

    -- Также останавливаем активный трек с тем же логическим именем
    local prevByName = ActiveTracks[logicalName]
    if prevByName and prevByName.IsPlaying then
        prevByName:Stop(fadeTime)
    end

    local track = GetVMTrack(logicalName)
    if not track then return nil end

    track.Priority = priority
    track.Looped   = looped
    track:AdjustSpeed(speed)
    track:Play(fadeTime)

    ActiveTracks[logicalName] = track
    if channel then
        ActiveChannels[channel] = track
    end

    -- Автоочистка
    track.Stopped:Once(function()
        if ActiveTracks[logicalName] == track  then ActiveTracks[logicalName]    = nil end
        if channel and ActiveChannels[channel] == track then ActiveChannels[channel] = nil end
    end)

    return track
end

--- Остановить трек по логическому имени
local function StopVMAnim(logicalName, fadeTime)
    local t = ActiveTracks[logicalName]
    if t and t.IsPlaying then t:Stop(fadeTime or 0.10) end
    ActiveTracks[logicalName] = nil
end

--- Остановить все активные треки
local function StopAllVMAnims(fadeTime)
    fadeTime = fadeTime or 0.10
    for _, t in pairs(ActiveTracks) do
        if t and t.IsPlaying then t:Stop(fadeTime) end
    end
    for _, t in pairs(ActiveChannels) do
        if t and t.IsPlaying then t:Stop(fadeTime) end
    end
    ActiveTracks   = {}
    ActiveChannels = {}
    AnimTrackCache = {}
end

-- [ИСПРАВЛЕНИЕ 3] Helper для базовых поз: Idle/Sprint/Patrol/HighReady/LowReady
-- Все они используют канал "BasePose" — друг друга вытесняют автоматически
local function PlayBasePose(logicalName, options)
    options = options or {}
    options.Channel  = "BasePose"
    options.StopPrev = true
    return PlayVMAnim(logicalName, options)
end

