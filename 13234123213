-- ───────────────────────────────────────────────────────────────────
local function ADS(aiming)
    if not WeaponData or not WeaponInHand then return end
    if aiming then
        if SafeMode then
            SafeMode=false; GunStance=0; IdleAnim(); UpdateGui()
        end
        UIS.MouseDeltaSensitivity = Sens/100
        WeaponInHand.Handle.AimDown:Play()
        GunStance=2; Evt.GunStance:FireServer(GunStance, nil)
        CrosshairShow(false); CrosshairCenterShow(false)
    else
        UIS.MouseDeltaSensitivity = 1
        WeaponInHand.Handle.AimUp:Play()
        GunStance=0; Evt.GunStance:FireServer(GunStance, nil)
        if WeaponData.CrossHair then CrosshairShow(true) end
        CrosshairCenterShow(WeaponData.CenterDot == true)
        if gunRecoilState then gunRecoilState:Reset() end
    end
end

-- ───────────────────────────────────────────────────────────────────
-- 15. HANDLEACTION
-- ───────────────────────────────────────────────────────────────────
function handleAction(actionName, inputState, inputObject)
    local BEGIN = Enum.UserInputState.Begin
    local END   = Enum.UserInputState.End

    if actionName=="Fire" and inputState==BEGIN and AnimDebounce then
        Shoot()
        if WeaponData and WeaponData.Type=="Grenade" then CookGrenade=true; Grenade() end
    elseif actionName=="Fire" and inputState==END then
        mouse1down=false; CookGrenade=false
    end

    if actionName=="Reload" and inputState==BEGIN and AnimDebounce and not CheckingMag and not reloading then
        if WeaponData and WeaponData.Jammed then Jammed() else Reload() end
    end
    if actionName=="Reload" and inputState==BEGIN and reloading and WeaponData and WeaponData.ShellInsert then
        CancelReload=true
    end

    if actionName=="CycleLaser"    and inputState==BEGIN and LaserAtt then SetLaser() end
    if actionName=="CycleLight"    and inputState==BEGIN and TorchAtt  then SetTorch() end
    if actionName=="CycleFiremode" and inputState==BEGIN and WeaponData and WeaponData.FireModes and WeaponData.FireModes.ChangeFiremode then Firemode() end
    if actionName=="CycleAimpart"  and inputState==BEGIN then SetAimpart() end

    if actionName=="ZeroUp" and inputState==BEGIN and WeaponData and WeaponData.EnableZeroing then
        if WeaponData.CurrentZero < WeaponData.MaxZero then
            WeaponInHand.Handle.Click:play()
            WeaponData.CurrentZero = math.min(WeaponData.CurrentZero+WeaponData.ZeroIncrement, WeaponData.MaxZero)
            UpdateGui()
        end
    end
    if actionName=="ZeroDown" and inputState==BEGIN and WeaponData and WeaponData.EnableZeroing then
        if WeaponData.CurrentZero > 0 then
            WeaponInHand.Handle.Click:play()
            WeaponData.CurrentZero = math.max(WeaponData.CurrentZero-WeaponData.ZeroIncrement, 0)
            UpdateGui()
        end
    end

    if actionName=="CheckMag" and inputState==BEGIN and not CheckingMag and not reloading and not runKeyDown and AnimDebounce then
        CheckMagFunction()
    end
    if actionName=="ToggleBipod" and inputState==BEGIN and CanBipod then
        BipodActive=not BipodActive; UpdateGui()
    end

    if actionName=="NVG" and inputState==BEGIN and not NVGdebounce then
        if plr.Character then
            local helmet = plr.Character:FindFirstChild("Helmet")
            if helmet and helmet:FindFirstChild("Up") then
                NVGdebounce=true
                task.delay(0.8, function() NVG=not NVG; Evt.NVG:Fire(NVG); NVGdebounce=false end)
            end
        end
    end

    if actionName=="ADS" and inputState==BEGIN and AnimDebounce then
        if WeaponData and WeaponData.canAim and GunStance>-2 and not runKeyDown and not CheckingMag and not BumpAdsCut then
            aimming=not aimming; ADS(aimming)
        end
        if WeaponData and WeaponData.Type=="Grenade" then GrenadeMode() end
    end

    if actionName=="Stand" and inputState==BEGIN and ChangeStance and not Swimming and not Sentado and not runKeyDown then
        if Stances==2 then Crouched=true; Proned=false; Stances=1; CameraY=-1; Crouch()
        elseif Stances==1 then Crouched=false; Stances=0; CameraY=0; Stand()
        end
    end

    if actionName=="Crouch" and inputState==BEGIN and ChangeStance and not Swimming and not Sentado and not runKeyDown then
        if Stances==0 then Stances=1; CameraY=-1; Crouch(); Crouched=true
        elseif Stances==1 then Stances=2; CameraX=0; CameraY=-3.25; Virar=0; Lean(); Prone(); Crouched=false; Proned=true
        end
    end

    if actionName=="ToggleWalk" and inputState==BEGIN and ChangeStance and not runKeyDown then
        Steady=not Steady
        SE_GUI.MainFrame.Poses.Steady.Visible=Steady
        if Stances==0 then Stand() end
    end

    if actionName=="LeanLeft" and inputState==BEGIN and Stances~=2 and ChangeStance and not Swimming and not runKeyDown and CanLean then
        if Virar==0 or Virar==1 then Virar=-1; CameraX=-1.25 else Virar=0; CameraX=0 end; Lean()
    end
    if actionName=="LeanRight" and inputState==BEGIN and Stances~=2 and ChangeStance and not Swimming and not runKeyDown and CanLean then
        if Virar==0 or Virar==-1 then Virar=1; CameraX=1.25 else Virar=0; CameraX=0 end; Lean()
    end

    if actionName=="Run" and inputState==BEGIN and not script.Parent:GetAttribute("Injured") then
        runKeyDown=true
        if running then
            Stand(); Stances=0; Virar=0; CameraX=0; CameraY=0; Lean()
            char:FindFirstChildOfClass("Humanoid").WalkSpeed = gameRules.RunWalkSpeed
            if aimming then aimming=false; ADS(false) end
            if not CheckingMag and not reloading and WeaponData and WeaponData.Type~="Grenade"
                and (GunStance==0 or GunStance==2 or GunStance==3) then
                GunStance=3; Evt.GunStance:FireServer(GunStance,nil); SprintAnim()
            end
        end
    elseif actionName=="Run" and inputState==END and runKeyDown then
        runKeyDown=false; Stand()
        if not CheckingMag and not reloading and WeaponData and WeaponData.Type~="Grenade"
            and (GunStance==0 or GunStance==2 or GunStance==3) then
            GunStance=0; Evt.GunStance:FireServer(GunStance,nil); IdleAnim()
        end
    end
end

