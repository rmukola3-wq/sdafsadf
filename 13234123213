-- 16. GUI
-- ───────────────────────────────────────────────────────────────────
function UpdateGui()
    if not SE_GUI or not WeaponData then return end
    local HUD = SE_GUI.GunHUD

    HUD.B.BackgroundColor3 = WeaponData.Jammed and Color3.fromRGB(255,0,0) or Color3.fromRGB(255,255,255)
    HUD.A.Visible = SafeMode
    HUD.B.Visible = Ammo > 0

    local fmodes = {"Semi","Burst","Auto","Pump-Action","Bolt-Action"}
    HUD.FText.Text = fmodes[WeaponData.ShootType] or ""
    HUD.Sens.Text  = tostring(Sens/100)
    HUD.BText.Text = WeaponData.BulletType
    HUD.NText.Text = WeaponData.gunName

    HUD.ZeText.Visible = WeaponData.EnableZeroing
    if WeaponData.EnableZeroing then HUD.ZeText.Text = WeaponData.CurrentZero.." m" end

    if WeaponData.MagCount then
        HUD.SAText.Text = math.ceil(StoredAmmo/WeaponData.Ammo)
        HUD.Magazines.Visible=true; HUD.Bullets.Visible=false
    else
        HUD.SAText.Text = StoredAmmo
        HUD.Magazines.Visible=false; HUD.Bullets.Visible=true
    end

    HUD.Att.Silencer.Visible = Suppressor
    HUD.Att.Laser.Visible    = LaserAtt
    if LaserAtt then
        local col = LaserActive and (IRmode and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,255,255)) or Color3.fromRGB(255,0,0)
        TS:Create(HUD.Att.Laser, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3=col, ImageTransparency=LaserActive and .123 or .5}):Play()
    end
    HUD.Att.Bipod.Visible = BipodAtt
    HUD.Att.Flash.Visible = TorchAtt
    if TorchAtt then
        TS:Create(HUD.Att.Flash, TweenInfo.new(.1,Enum.EasingStyle.Linear),
            {ImageColor3=TorchActive and Color3.fromRGB(255,255,255) or Color3.fromRGB(255,0,0),
             ImageTransparency=TorchActive and .123 or .5}):Play()
    end
    SE_GUI.GrenadeForce.Visible = WeaponData.Type=="Grenade"
end

function CheckMagFunction()
    if aimming then aimming=false; ADS(false) end
    if SE_GUI then
        local HUD = SE_GUI.GunHUD
