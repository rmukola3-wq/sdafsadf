local function loadAttachment(weapon)
    if not weapon or not weapon:FindFirstChild("Nodes") then return end
    local nodes = weapon.Nodes
    local function weldAll(model)
        for _, p in ipairs(model:GetChildren()) do
            if p:IsA("BasePart") then
                Ultil.Weld(weapon:WaitForChild("Handle"), p)
                p.Anchored=false; p.CanCollide=false
            end
        end
    end

    if nodes:FindFirstChild("Sight") and WeaponData.SightAtt ~= "" then
        SightData = require(AttModules[WeaponData.SightAtt])
        SightAtt  = AttModels[WeaponData.SightAtt]:Clone()
        SightAtt.Parent = weapon
        SightAtt:SetPrimaryPartCFrame(nodes.Sight.CFrame)
        weapon.AimPart.CFrame = SightAtt.AimPos.CFrame
        reticle = SightAtt.SightMark.SurfaceGui.Border.Scope
        if SightData.SightZoom  > 0 then ModTable.ZoomValue  = SightData.SightZoom  end
        if SightData.SightZoom2 > 0 then ModTable.Zoom2Value = SightData.SightZoom2 end
        setMods(SightData)
        for _, key in ipairs(weapon:GetChildren()) do
            if key.Name == "IS" then key.Transparency = 1 end
        end
        weldAll(SightAtt)
    end

    if nodes:FindFirstChild("Barrel") and WeaponData.BarrelAtt ~= "" then
        BarrelData = require(AttModules[WeaponData.BarrelAtt])
        BarrelAtt  = AttModels[WeaponData.BarrelAtt]:Clone()
        BarrelAtt.Parent = weapon
        BarrelAtt:SetPrimaryPartCFrame(nodes.Barrel.CFrame)
        if BarrelAtt:FindFirstChild("BarrelPos") then
            weapon.Handle.Muzzle.WorldCFrame = BarrelAtt.BarrelPos.CFrame
        end
        Suppressor = BarrelData.IsSuppressor
        FlashHider = BarrelData.IsFlashHider
        setMods(BarrelData)
        weldAll(BarrelAtt)
    end

    if nodes:FindFirstChild("UnderBarrel") and WeaponData.UnderBarrelAtt ~= "" then
        UnderBarrelData = require(AttModules[WeaponData.UnderBarrelAtt])
        UnderBarrelAtt  = AttModels[WeaponData.UnderBarrelAtt]:Clone()
        UnderBarrelAtt.Parent = weapon
        UnderBarrelAtt:SetPrimaryPartCFrame(nodes.UnderBarrel.CFrame)
        setMods(UnderBarrelData)
        BipodAtt = UnderBarrelData.IsBipod
        if BipodAtt then CAS:BindAction("ToggleBipod", handleAction, true, Enum.KeyCode.B) end
        weldAll(UnderBarrelAtt)
    end

    if nodes:FindFirstChild("Other") and WeaponData.OtherAtt ~= "" then
        OtherData = require(AttModules[WeaponData.OtherAtt])
        OtherAtt  = AttModels[WeaponData.OtherAtt]:Clone()
        OtherAtt.Parent = weapon
        OtherAtt:SetPrimaryPartCFrame(nodes.Other.CFrame)
        setMods(OtherData)
        LaserAtt = OtherData.EnableLaser
        TorchAtt = OtherData.EnableFlashlight
        if OtherData.InfraRed then IREnable = true end
        weldAll(OtherAtt)
    end
end

-- ───────────────────────────────────────────────────────────────────
-- 11. SETUP / UNSET
-- ───────────────────────────────────────────────────────────────────
local function setup(Tool)
    local myToken   = EquipToken
    SetupVersion   += 1
    local myVersion = SetupVersion

    -- Уничтожаем старые Viewmodel (не _OLD — те ждут своего task.delay)
    for _, obj in ipairs(cam:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "Viewmodel" then obj:Destroy() end
    end

    if not (char and char:FindFirstChildOfClass("Humanoid") and
            char:FindFirstChildOfClass("Humanoid").Health > 0 and Tool) then return end

    ToolEquip            = true
    UIS.MouseIconEnabled = false
    plr.CameraMode       = Enum.CameraMode.LockFirstPerson

    WeaponTool   = Tool
    WeaponData   = require(Tool:WaitForChild("ACS_Settings"))
    WeaponInHand = GunModels:WaitForChild(Tool.Name):Clone()
    WeaponInHand.PrimaryPart = WeaponInHand:WaitForChild("Handle")

    Evt.Equip:FireServer(Tool, 1, WeaponData, nil)

    -- [ИСПРАВЛЕНИЕ 1] Выбираем папку платформы и ViewmodelAnims
    do
        local platformName = (WeaponData.AnimationPlatform)
                          or (WeaponData.Platform)
                          or Tool:GetAttribute("AnimationPlatform")
                          or "AKPlatform"

        local pf = GunAnimFolder:FindFirstChild(platformName)
        if not pf then
            warn("[ACS Anim] Platform folder not found:", platformName, "— using AKPlatform fallback")
            pf = GunAnimFolder:FindFirstChild("AKPlatform")
        end
        CurrentPlatformFolder = pf

        if pf then
            local vf = pf:FindFirstChild("ViewmodelAnims")
            CurrentVMAnimFolder = vf or pf   -- если нет ViewmodelAnims — сама платформа
        else
            CurrentVMAnimFolder = nil
            warn("[ACS Anim] No platform folder found at all, will use FallbackAnimMap only")
        end
    end

    -- ── ViewModel ──
    ViewModel = ArmModel:WaitForChild("Arms"):Clone()
    ViewModel.Name = "Viewmodel"

    if char:FindFirstChild("Body Colors") then char:FindFirstChild("Body Colors"):Clone().Parent = ViewModel end
    if char:FindFirstChild("Shirt")        then char:FindFirstChild("Shirt"):Clone().Parent = ViewModel end

    AnimPart            = Instance.new("Part", ViewModel)
    AnimPart.Size       = Vector3.new(0.1, 0.1, 0.1)
    AnimPart.Anchored   = true
    AnimPart.CanCollide = false
    AnimPart.Transparency = 1
    ViewModel.PrimaryPart = AnimPart

    LArmWeld = Instance.new("Motor6D", AnimPart); LArmWeld.Name="LeftArm";  LArmWeld.Part0=AnimPart
    RArmWeld = Instance.new("Motor6D", AnimPart); RArmWeld.Name="RightArm"; RArmWeld.Part0=AnimPart
    GunWeld  = Instance.new("Motor6D", AnimPart); GunWeld.Name="Handle"

    -- AnimationController + Animator (VMAnimTrackCache убран)
    InitVMAnimator(ViewModel)

    if myVersion ~= SetupVersion or myToken ~= EquipToken then
        pcall(function() ViewModel:Destroy() end)
        ViewModel=nil; VMAnimController=nil; VMAnimator=nil
        return
    end

    ViewModel.Parent = cam

    maincf = WeaponData.MainCFrame or CFrame.new()
    guncf  = WeaponData.GunCFrame  or CFrame.new()

    if WeaponData.CrossHair then
        CrosshairShow(true)
        local rot = (WeaponData.Bullets or 1) > 1 and 90 or 0
        for _, id in ipairs({"Up","Down","Left","Right"}) do Crosshair[id].Rotation = rot end
    else
        CrosshairShow(false)
    end
    CrosshairCenterShow(WeaponData.CenterDot == true)

    LArm = ViewModel:WaitForChild("Left Arm")
    LArmWeld.Part1=LArm; LArmWeld.C0=CFrame.new(); LArmWeld.C1=CFrame.new(1,-1,-5)

    RArm = ViewModel:WaitForChild("Right Arm")
    RArmWeld.Part1=RArm; RArmWeld.C0=CFrame.new(); RArmWeld.C1=CFrame.new(-1,-1,-5)
    GunWeld.Part0=RArm; LArm.Anchored=false; RArm.Anchored=false

    AnimPart.CFrame     = cam.CFrame * NearZ * maincf
    ModTable.ZoomValue  = WeaponData.Zoom
    ModTable.Zoom2Value = WeaponData.Zoom2
    IREnable            = WeaponData.InfraRed

    CAS:BindAction("Fire",          handleAction, true,  Enum.UserInputType.MouseButton1, Enum.KeyCode.ButtonR2)
    CAS:BindAction("ADS",           handleAction, true,  Enum.UserInputType.MouseButton2, Enum.KeyCode.ButtonL2)
    CAS:BindAction("Reload",        handleAction, true,  Enum.KeyCode.R, Enum.KeyCode.ButtonB)
    CAS:BindAction("CycleAimpart",  handleAction, false, Enum.KeyCode.T)
    CAS:BindAction("CycleLaser",    handleAction, true,  Enum.KeyCode.H)
    CAS:BindAction("CycleLight",    handleAction, true,  Enum.KeyCode.J)
    CAS:BindAction("CycleFiremode", handleAction, false, Enum.KeyCode.V)
    CAS:BindAction("CheckMag",      handleAction, false, Enum.KeyCode.M)
    CAS:BindAction("ZeroDown",      handleAction, false, Enum.KeyCode.LeftBracket)
    CAS:BindAction("ZeroUp",        handleAction, false, Enum.KeyCode.RightBracket)

    loadAttachment(WeaponInHand)

    BSpread     = math.min(WeaponData.MinSpread*ModTable.MinSpread,       WeaponData.MaxSpread*ModTable.MaxSpread)
    RecoilPower = math.min(WeaponData.MinRecoilPower*ModTable.MinRecoilPower, WeaponData.MaxRecoilPower*ModTable.MaxRecoilPower)

    Ammo       = WeaponData.AmmoInGun
    StoredAmmo = WeaponData.StoredAmmo
    CurAimpart = WeaponInHand:FindFirstChild("AimPart")

    for _, d in ipairs(WeaponInHand:GetDescendants()) do
        if d:IsA("BasePart") then
            if d.Name == "FlashPoint" then TorchAtt = true end
            if d.Name == "LaserPoint" then LaserAtt  = true end
        end
    end

    if WeaponData.EnableHUD then SE_GUI.GunHUD.Visible = true end
    UpdateGui()

    for _, key in ipairs(WeaponInHand:GetChildren()) do
        if key:IsA("BasePart") and key.Name ~= "Handle" then
            if key.Name ~= "Bolt" and key.Name ~= "Lid" and key.Name ~= "Slide" then
                Ultil.Weld(WeaponInHand:WaitForChild("Handle"), key)
            end
            if key.Name == "Bolt" or key.Name == "Slide" then
                Ultil.WeldComplex(WeaponInHand:WaitForChild("Handle"), key, key.Name)
            end
            if key.Name == "Lid" then
                local hinge = WeaponInHand:FindFirstChild("LidHinge")
                Ultil.Weld(key, hinge or WeaponInHand:WaitForChild("Handle"))
            end
        end
    end
    for _, p in ipairs(WeaponInHand:GetChildren()) do
        if p:IsA("BasePart") then p.Anchored=false; p.CanCollide=false end
    end
    if WeaponInHand:FindFirstChild("Nodes") then
        for _, p in ipairs(WeaponInHand.Nodes:GetChildren()) do
            if p:IsA("BasePart") then
                Ultil.Weld(WeaponInHand:WaitForChild("Handle"), p)
                p.Anchored=false; p.CanCollide=false
            end
        end
    end

    GunWeld.Part1       = WeaponInHand:WaitForChild("Handle")
    GunWeld.C1          = guncf
    WeaponInHand.Parent = ViewModel

    if Ammo <= 0 and WeaponData.Type == "Gun" then
        WeaponInHand.Handle.Slide.C0 = WeaponData.SlideEx:inverse()
    end

    -- Equip-анимация → callback → Idle (через BasePose-канал)
    AnimDebounce = false
    local equipTrack = PlayVMAnim("Equip", {FadeTime=0.05, Priority=Enum.AnimationPriority.Action})
    if equipTrack then
        equipTrack.Stopped:Once(function()
            AnimDebounce = true
            PlayBasePose("Idle", {Looped=true, Priority=Enum.AnimationPriority.Idle, FadeTime=0.15})
        end)
    else
        AnimDebounce = true
        PlayBasePose("Idle", {Looped=true, Priority=Enum.AnimationPriority.Idle, FadeTime=0.15})
    end

    RunCheck()
end

-- ─────────────────────────────────────────────────────────────────
local function unset()
    UnsetVersion += 1
    local myUnset = UnsetVersion

    if ToolEquip and IsBusy() then
        local waited = 0
        while IsBusy() and waited < 3 do
            if UnsetVersion ~= myUnset then return end
            task.wait(0.05); waited += 0.05
        end
    end
    if UnsetVersion ~= myUnset then return end

    ToolEquip = false
    Evt.Equip:FireServer(WeaponTool, 2)

    CAS:UnbindAction("Fire");         CAS:UnbindAction("ADS")
    CAS:UnbindAction("Reload");       CAS:UnbindAction("CycleLaser")
    CAS:UnbindAction("CycleLight");   CAS:UnbindAction("CycleFiremode")
    CAS:UnbindAction("CycleAimpart"); CAS:UnbindAction("ZeroUp")
    CAS:UnbindAction("ZeroDown");     CAS:UnbindAction("CheckMag")

    mouse1down = false; aimming = false

    if WeaponInHand then
        WeaponData.AmmoInGun  = Ammo
        WeaponData.StoredAmmo = StoredAmmo

        -- [ИСПРАВЛЕНИЕ 4a] Переименовываем ViewModel → "Viewmodel_OLD"
        -- Это защищает его от уничтожения в следующем setup() (там ищется "Viewmodel")
        local oldVM = ViewModel
        if oldVM then oldVM.Name = "Viewmodel_OLD" end

        -- [ИСПРАВЛЕНИЕ 4b] Останавливаем базовые/текущие треки с коротким fade
        StopAllVMAnims(0.08)

        -- [ИСПРАВЛЕНИЕ 4c] Запускаем Unequip-анимацию (теперь ViewModel жив)
        local unequipTrack = PlayVMAnim("Unequip", {FadeTime=0.05, Priority=Enum.AnimationPriority.Action})

        -- [ИСПРАВЛЕНИЕ 4d] Откладываем Destroy на длину анимации
        local delayTime = 0.15
        if unequipTrack then
            -- clamp длины на безопасный диапазон
            local ok, len = pcall(function() return unequipTrack.Length end)
            if ok and type(len) == "number" and len > 0 then
                delayTime = math.clamp(len, 0.05, 0.35)
            end
        end

        -- [ИСПРАВЛЕНИЕ 4e] Планируем отложенный Destroy
        task.delay(delayTime, function()
            if oldVM and oldVM.Parent then
                pcall(function() oldVM:Destroy() end)
            end
        end)

        -- Сброс UI/камеры через 0.15с (после завершения)
        task.spawn(function()
            task.wait(0.15)
            if UnsetVersion == myUnset and not WeaponInHand then
                TS:Create(cam, AimTween, {FieldOfView=70}):Play()
                CrosshairShow(false); CrosshairCenterShow(false)
                UIS.MouseIconEnabled      = true
                UIS.MouseDeltaSensitivity = 1
                cam.CameraType            = Enum.CameraType.Custom
                plr.CameraMode            = Enum.CameraMode.Classic
            end
        end)

        -- Обнуляем переменные (oldVM уже сохранён выше, Destroy — в task.delay)
        ViewModel=nil; VMAnimController=nil; VMAnimator=nil
        CurrentPlatformFolder=nil; CurrentVMAnimFolder=nil
        WeaponInHand=nil; WeaponTool=nil
        LArm=nil; RArm=nil; LArmWeld=nil; RArmWeld=nil; GunWeld=nil
        WeaponData=nil
        SightAtt=nil; reticle=nil; BarrelAtt=nil; UnderBarrelAtt=nil; OtherAtt=nil
        LaserAtt=false; LaserActive=false; IRmode=false
        TorchAtt=false; TorchActive=false
        BipodAtt=false; BipodActive=false
        LaserDist=0; Pointer=nil
        BSpread=nil; RecoilPower=nil
        Suppressor=false; FlashHider=false
        CancelReload=false; reloading=false
        SafeMode=false; CheckingMag=false
        GRDebounce=false; CookGrenade=false
        GunStance=0; resetMods()
        generateBullet=1; AimPartMode=1
        SE_GUI.GunHUD.Visible       = false
        SE_GUI.GrenadeForce.Visible = false
        BipodCF=CFrame.new(); bumpCF=CFrame.new(); bumpPushCF=CFrame.new()
        VM_Bump=false
        -- AnimTrackCache/ActiveTracks уже сброшены в StopAllVMAnims выше
        AnimTrackCache={}; ActiveTracks={}; ActiveChannels={}

        if gameRules.ReplicatedLaser then Evt.SVLaser:FireServer(nil,2,nil,false,nil) end
        if gunRecoilState then gunRecoilState:Reset() end
    end
end

