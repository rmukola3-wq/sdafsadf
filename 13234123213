Humanoid.StateChanged:Connect(function(_,state)
    if state==Enum.HumanoidStateType.Swimming then
        Swimming=true; Stances=0; Virar=0; CameraX=0; CameraY=0; Stand(); Lean()
    else Swimming=false end
    if gameRules.EnableFallDamage then
        if state==Enum.HumanoidStateType.Freefall and not falling then
            falling=true
            task.spawn(function()
                local vel,peak=0,0
                while falling do vel=HumanoidRootPart.Velocity.Magnitude; peak+=1; Thread:Wait() end
                local dmg=(vel-gameRules.MaxVelocity)*gameRules.DamageMult
                if dmg>5 and peak>20 then
                    cameraspring:accelerate(Vector3.new(-dmg/20,0,math.random(-dmg,dmg)/5))
                    SwaySpring:accelerate(Vector3.new(math.random(-dmg,dmg)/5,dmg/5,0))
                    local snd=PastaFx.FallDamage:Clone(); snd.Parent=plr.PlayerGui
                    snd.Volume=dmg/Humanoid.MaxHealth; snd:Play(); Debris:AddItem(snd,snd.TimeLength)
                    Evt.Damage:InvokeServer(nil,nil,nil,nil,nil,nil,true,dmg,SKP_01.."-"..plr.UserId)
                end
            end)
        elseif state==Enum.HumanoidStateType.Landed or state==Enum.HumanoidStateType.Dead then
            falling=false; SwaySpring:accelerate(Vector3.new(0,2.5,0))
        end
    end
end)

