local function GunFx()
    local muzzle=WeaponInHand.Handle.Muzzle
    if Suppressor then muzzle.Supressor:Play() else muzzle.Fire:Play() end
    if FlashHider then muzzle["Smoke"]:Emit(10) else muzzle["FlashFX[Flash]"]:Emit(10); muzzle["Smoke"]:Emit(10) end
    if BSpread then
        BSpread     =math.min(WeaponData.MaxSpread*ModTable.MaxSpread, BSpread+WeaponData.AimInaccuracyStepAmount*ModTable.AimInaccuracyStepAmount)
        RecoilPower =math.min(WeaponData.MaxRecoilPower*ModTable.MaxRecoilPower, RecoilPower+WeaponData.RecoilPowerStepAmount*ModTable.RecoilPowerStepAmount)
    end
    generateBullet+=1; LastSpreadUpdate=time()
    local slide=WeaponInHand.Handle.Slide
    if Ammo>0 or not WeaponData.SlideLock then
        TS:Create(slide,TweenInfo.new(30/WeaponData.ShootRate,Enum.EasingStyle.Linear,Enum.EasingDirection.InOut,0,true),{C0=WeaponData.SlideEx:inverse()}):Play()
    else
        TS:Create(slide,TweenInfo.new(30/WeaponData.ShootRate,Enum.EasingStyle.Linear,Enum.EasingDirection.InOut),{C0=WeaponData.SlideEx:inverse()}):Play()
    end
    WeaponInHand.Handle.Chamber.Smoke:Emit(10)
    WeaponInHand.Handle.Chamber.Shell:Emit(1)
end

local function JamChance()
    if WeaponData.CanBreak and not WeaponData.Jammed and Ammo-1>0 then
        if math.random(1000)<=2 then WeaponData.Jammed=true; WeaponInHand.Handle.Click:Play() end
    end
end

local function Recoil()
    local name=WeaponData and WeaponData.RecoilProfile or "Rifle556"
    local profile=GetRecoilProfile(name) or GetRecoilProfile("Rifle556")
    if not profile then return end
    if gunRecoilState.currentProfile~=profile then gunRecoilState:SetProfile(profile) end

    local adsVKS=profile.adsViewKickScale or 0.35
    local adsRCS=profile.adsRecoilCFScale or 0.45
    local adsCRP=profile.adsCamRecoilPower or 0.18
    local hipRS =profile.hipRecoilScale or 0.20
    local hipVKS=profile.hipVMKickScale or 0.20

    local mult=(RecoilPower or 1)*5.5
    if aimming     then mult=mult*(profile.aimMultiplier or 0.30) end
    if Crouched    then mult=mult*(profile.crouchMultiplier or 0.65) end
    if BipodActive then mult=mult*0.3 end
    if charspeed>0.1 then mult=mult*(profile.moveMultiplier or 1.2) end
    if not aimming then mult=mult*hipRS end
    if aimming     then mult=mult*adsRCS end

    gunRecoilState:Kick(profile,mult)
    if aimming then
        local cr=gunRecoilState:GetCameraRecoil()
        cameraspring:accelerate(Vector3.new(math.rad(cr.Y)*adsCRP,math.rad(cr.X)*adsCRP,0))
    end

    local kick=(aimming and 0.55 or 1.0)*(BipodActive and 0.4 or 1)
              *(not aimming and (WeaponData.HipRecoilMult or 1.15) or 1)
              *(aimming and (WeaponData.ADSRecoilMult or 0.85) or 1)
    if not aimming then kick=kick*hipVKS end
    local kvm=kick*(aimming and adsVKS or 1)*0.75*0.345

    VMKickPos:accelerate(Vector3.new(0,1.15*kvm*0.83,-1.55*kvm))
    VMKickRot:accelerate(Vector3.new(math.rad(3.4)*kvm*0.83,
        math.rad(RAND(-2.2,2.2,.5))*kvm, math.rad(RAND(-1.5,2.2,.5))*kvm))
end

function Shoot()
    if WeaponData and WeaponData.Type=="Gun" and not shooting and not reloading then
        if reloading or runKeyDown or SafeMode or CheckingMag then mouse1down=false; return end
        if Ammo<=0 or WeaponData.Jammed then WeaponInHand.Handle.Click:Play(); mouse1down=false; return end
        mouse1down=true
        local function doShot()
            Evt.Atirar:FireServer(WeaponTool,Suppressor,FlashHider)
            for _=1,WeaponData.Bullets do Thread:Spawn(CreateBullet) end
            Ammo-=1; GunFx(); JamChance(); UpdateGui(); Thread:Spawn(Recoil)
        end
        task.spawn(function()
            if WeaponData.ShootType==1 then
                shooting=true; doShot(); task.wait(60/WeaponData.ShootRate); shooting=false
            elseif WeaponData.ShootType==2 then
                for _=1,WeaponData.BurstShot do
                    if shooting or Ammo<=0 or not mouse1down or WeaponData.Jammed then break end
                    shooting=true; doShot(); task.wait(60/WeaponData.ShootRate); shooting=false
                end
            elseif WeaponData.ShootType==3 then
                while mouse1down do
                    if shooting or Ammo<=0 or WeaponData.Jammed then break end
                    shooting=true; doShot(); task.wait(60/WeaponData.ShootRate); shooting=false
                end
            elseif WeaponData.ShootType==4 or WeaponData.ShootType==5 then
                shooting=true; doShot(); PumpAnim(); RunCheck(); shooting=false
            end
        end)
    elseif WeaponData and WeaponData.Type=="Melee" and not runKeyDown then
        if not shooting then
            shooting=true
            local rp=RaycastParams.new(); rp.FilterDescendantsInstances=Ignore_Model
            rp.FilterType=Enum.RaycastFilterType.Blacklist; rp.IgnoreWater=true
            local res=workspace:Raycast(cam.CFrame.Position,cam.CFrame.LookVector*WeaponData.BladeRange,rp)
            if res then
                local fh,hum=CheckForHumanoid(res.Instance)
                HitMod.HitEffect(Ignore_Model,res.Position,res.Instance,res.Normal,res.Material,WeaponData)
                Evt.HitEffect:FireServer(res.Position,res.Instance,res.Normal,res.Material,WeaponData)
                if fh and hum.Health>0 then
                    local z=(res.Instance.Name=="Head") and 1 or (res.Instance.Name:match("Torso") or res.Instance.Name:match("Arm")) and 2 or 3
                    Thread:Spawn(function()
                        Evt.Damage:InvokeServer(WeaponTool,hum,0,z,WeaponData,ModTable,nil,nil,SKP_01.."-"..plr.UserId)
                    end)
                end
            end
            meleeAttack(); RunCheck(); shooting=false
        end
    end
end

function Jammed()
    if WeaponData.Type~="Gun" or not WeaponData.Jammed then return end
    mouse1down=false; reloading=true; SafeMode=false
    GunStance=0; Evt.GunStance:FireServer(GunStance,nil); UpdateGui()
    JammedAnim(); WeaponData.Jammed=false; UpdateGui()
    reloading=false; RunCheck()
end

function Reload()
    if WeaponData.Type~="Gun" or StoredAmmo<=0 then return end
    if not (Ammo<WeaponData.Ammo or (WeaponData.IncludeChamberedBullet and Ammo<WeaponData.Ammo+1)) then return end
    mouse1down=false; reloading=true; SafeMode=false
    GunStance=0; Evt.GunStance:FireServer(GunStance,nil); UpdateGui()

    if WeaponData.ShellInsert then
        local function insertOne()
            if StoredAmmo<=0 or Ammo>=WeaponData.Ammo or CancelReload then return false end
            ReloadAnim(); Ammo+=1; StoredAmmo-=1; UpdateGui(); return true
        end
        if Ammo==0 then TacticalReloadAnim(); Ammo+=1; StoredAmmo-=1; UpdateGui() end
        for _=1,WeaponData.Ammo do if not insertOne() then break end end
    else
        if Ammo>0 then ReloadAnim() else TacticalReloadAnim() end
        if Ammo-(WeaponData.Ammo-StoredAmmo)<0 then Ammo=Ammo+StoredAmmo; StoredAmmo=0
        elseif Ammo<=0 then StoredAmmo=StoredAmmo-(WeaponData.Ammo-Ammo); Ammo=WeaponData.Ammo
        elseif WeaponData.IncludeChamberedBullet then StoredAmmo=StoredAmmo-(WeaponData.Ammo-Ammo)-1; Ammo=WeaponData.Ammo+1
        else StoredAmmo=StoredAmmo-(WeaponData.Ammo-Ammo); Ammo=WeaponData.Ammo
        end
    end
    CancelReload=false; reloading=false; RunCheck(); UpdateGui()
    IdleAnim()
end

