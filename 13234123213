local function CheckForHumanoid(inst)
    if not inst then return false,nil end
    local hum = inst.Parent:FindFirstChildOfClass("Humanoid")
            or  inst.Parent.Parent:FindFirstChildOfClass("Humanoid")
    return hum~=nil, hum
end

local BODY_NAMES = {Head=true,["Right Arm"]=true,["Left Arm"]=true,["Right Leg"]=true,["Left Leg"]=true,
    UpperTorso=true,LowerTorso=true,RightUpperArm=true,RightLowerArm=true,RightHand=true,
    LeftUpperArm=true,LeftLowerArm=true,LeftHand=true,RightUpperLeg=true,RightLowerLeg=true,
    RightFoot=true,LeftUpperLeg=true,LeftLowerLeg=true,LeftFoot=true,Armor=true,EShield=true}

local IGNORE_PARENTS = {Top=true,Helmet=true,Up=true,Down=true,Face=true,Olho=true,
    Headset=true,Numero=true,Vest=true,Chest=true,Waist=true,Back=true,Belt=true,
    Leg1=true,Leg2=true,Arm1=true,Arm2=true}

local function shouldIgnore(inst)
    if not inst then return false end
    return inst.Name=="Ignorable" or inst.Name=="Glass" or inst.Name=="Ignore"
        or IGNORE_PARENTS[inst.Parent and inst.Parent.Name or ""]
end

local function CastRay(Bullet, Origin)
    if not Bullet then return end
    local Bpos2=cam.CFrame.Position
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances=Ignore_Model; rp.FilterType=Enum.RaycastFilterType.Blacklist; rp.IgnoreWater=true

    while Bullet do
        Run.Heartbeat:Wait()
        if not Bullet.Parent then break end
        local Bpos=Bullet.Position
        if (Bpos-Origin).Magnitude>7000 then Bullet:Destroy(); break end

        for _, plyr in ipairs(game.Players:GetChildren()) do
            if plyr:IsA("Player") and plyr~=plr and plyr.Character then
                local head=plyr.Character:FindFirstChild("Head")
                if head and (head.Position-Bpos).Magnitude<=25 then
                    Evt.Whizz:FireServer(plyr)
                    Evt.Suppression:FireServer(plyr,1,nil,nil)
                end
            end
        end

        local res=workspace:Raycast(Bpos2,(Bpos-Bpos2),rp)
        if res then
            local h=res.Instance
            if h and (h.Parent:IsA("Accessory") or h.Parent:IsA("Hat")) then
                for _, pl in ipairs(game.Players:GetPlayers()) do
                    if pl.Character then
                        for _, acc in ipairs(pl.Character:GetChildren()) do
                            if acc:IsA("Accessory") then table.insert(Ignore_Model,acc) end
                        end
                    end
                end
                CastRay(Bullet,Origin); break
            end
            if shouldIgnore(h) then table.insert(Ignore_Model,h); CastRay(Bullet,Origin); break end
            if not BODY_NAMES[h.Name] and (h.Transparency>=1 or not h.CanCollide) then
                table.insert(Ignore_Model,h); CastRay(Bullet,Origin); break
            end

            Bullet:Destroy()
            local dist=(res.Position-Origin).Magnitude
            HitMod.HitEffect(Ignore_Model,res.Position,h,res.Normal,res.Material,WeaponData)
            Evt.HitEffect:FireServer(res.Position,h,res.Normal,res.Material,WeaponData)

            local fh,hum=CheckForHumanoid(h)
            if fh and hum.Health>0 and WeaponData then
                local zone=3
                if h.Name=="Head" or IGNORE_PARENTS[h.Parent and h.Parent.Name or ""] then zone=1
                elseif h.Name=="Torso" or h.Name:match("Torso") or h.Name:match("Arm") or h.Name:match("Hand")
                    or h.Name=="Right Arm" or h.Name=="Left Arm" then zone=2 end
                Evt.Damage:InvokeServer(WeaponTool,hum,dist,zone,WeaponData,ModTable,nil,nil,SKP_01.."-"..plr.UserId)
            end
            break
        end
        Bpos2=Bullet.Position
    end
end

local Tracers=0
local function TracerCalc()
    if not (WeaponData.Tracer or WeaponData.BulletFlare) then return false end
    if WeaponData.RandomTracer.Enabled then return math.random(1,100)<=WeaponData.RandomTracer.Chance end
    if Tracers>=WeaponData.TracerEveryXShots then Tracers=0; return true end
    Tracers+=1; return false
end

local function CreateBullet()
    local Bullet=Instance.new("Part",ACS_Workspace.Client)
    Bullet.Name="Bullet"; Bullet.CanCollide=false; Bullet.Shape=Enum.PartType.Ball
    Bullet.Transparency=1; Bullet.Size=Vector3.new(1,1,1)
    local handle=WeaponInHand.Handle
    local Origin   =handle.Muzzle.WorldPosition
    local Direction=handle.Muzzle.WorldCFrame.LookVector
        + handle.Muzzle.WorldCFrame.UpVector*(((WeaponData.BulletDrop*WeaponData.CurrentZero/4)/WeaponData.MuzzleVelocity)/2)
    local wm=WeaponData.WalkMult*ModTable.WalkMult; local sp=charspeed
    local div = aimming and WeaponData.Bullets<=1 and (10*WeaponData.AimSpreadReduction) or 10
    local spread=CFrame.Angles(
        math.rad(RAND(-BSpread-(sp*wm),BSpread+(sp*wm))/div),
        math.rad(RAND(-BSpread-(sp*wm),BSpread+(sp*wm))/div),
        math.rad(RAND(-BSpread-(sp*wm),BSpread+(sp*wm))/div))
    Direction=spread*Direction
    local visible=TracerCalc()
    local BColor=WeaponData.RainbowMode and Color3.fromRGB(math.random(0,255),math.random(0,255),math.random(0,255)) or WeaponData.TracerColor
    if visible then
        if gameRules.ReplicatedBullets then Evt.ServerBullet:FireServer(Origin,Direction,WeaponData,ModTable) end
        if WeaponData.Tracer then
            local a1=Instance.new("Attachment",Bullet); a1.Position=Vector3.new(-.05,0,0)
            local a2=Instance.new("Attachment",Bullet); a2.Position=Vector3.new(.05,0,0)
            local trail=Instance.new("Trail",Bullet)
            trail.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)})
            trail.WidthScale=NumberSequence.new({NumberSequenceKeypoint.new(0,2),NumberSequenceKeypoint.new(1,1)})
            trail.Color=ColorSequence.new(BColor); trail.Texture="rbxassetid://232918622"
            trail.TextureMode=Enum.TextureMode.Stretch; trail.FaceCamera=true
            trail.LightEmission=1; trail.LightInfluence=0; trail.Lifetime=.25
            trail.Attachment0=a1; trail.Attachment1=a2
        end
        if WeaponData.BulletFlare then
            local bg=Instance.new("BillboardGui",Bullet); bg.Adornee=Bullet; bg.Enabled=false
            local sz=math.random(275,375)/10; bg.Size=UDim2.new(sz,0,sz,0); bg.LightInfluence=0
            local fl=Instance.new("ImageLabel",bg); fl.BackgroundTransparency=1; fl.Size=UDim2.new(1,0,1,0)
            fl.Image="rbxassetid://1047066405"; fl.ImageTransparency=math.random(2,5)/15; fl.ImageColor3=BColor
            task.delay(.1,function() if Bullet:FindFirstChild("BillboardGui") then Bullet.BillboardGui.Enabled=true end end)
        end
    end
    local bf=Instance.new("BodyForce",Bullet)
    bf.Force=Vector3.new(0,Bullet:GetMass()*196.2-WeaponData.BulletDrop*196.2,0)
    Bullet.CFrame=CFrame.new(Origin,Origin+Direction)
    Bullet:ApplyImpulse(Direction*WeaponData.MuzzleVelocity*ModTable.MuzzleVelocity)
    game.Debris:AddItem(Bullet,5)
    CastRay(Bullet,Origin)
end

