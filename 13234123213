-- ───────────────────────────────────────────────────────────────────
-- 31. RENDERSTEP  — НЕТ wait/task.wait/yield внутри!
-- ───────────────────────────────────────────────────────────────────
Run.RenderStepped:Connect(function(dt)
    HeadMovement()
    if aimming then renderCam() end

    if not (ViewModel and LArm and RArm and WeaponInHand) then return end

    local md=UIS:GetMouseDelta()

    -- Sway
    local ss=aimming and 0.22 or 1
    SwaySpring:accelerate(Vector3.new((md.X/60)*ss,(md.Y/60)*ss,0))
    local sv=SwaySpring.p
    local Sway=CFrame.Angles(sv.Y,sv.X,sv.X)

    -- Lag
    local rotK=aimming and LAG_ROT_ADS or LAG_ROT_HIP
    local posK=aimming and LAG_POS_ADS or LAG_POS_HIP
    local lagMx=aimming and LAG_MAX_ADS or LAG_MAX_HIP
    LagSpring.t=Vector3.new(math.clamp(-md.Y*rotK,-lagMx,lagMx),math.clamp(-md.X*rotK,-lagMx,lagMx),0)
    local lp=LagSpring.p
    local lagCF=CFrame.new(math.clamp(-md.X*posK,-0.08,0.08),math.clamp(-md.Y*posK,-0.06,0.06),0)*CFrame.Angles(lp.X,lp.Y,0)

    -- Bipod
    if BipodAtt and UnderBarrelAtt then
        local bRay=Ray.new(UnderBarrelAtt.Main.Position,Vector3.new(0,-1.75,0))
        local bHit,bPos=workspace:FindPartOnRayWithIgnoreList(bRay,Ignore_Model,false,true)
        if bHit then
            CanBipod=true
            if BipodActive and not runKeyDown and (GunStance==0 or GunStance==2) then
                TS:Create(SE_GUI.GunHUD.Att.Bipod,TweenInfo.new(.1,Enum.EasingStyle.Linear),{ImageColor3=Color3.fromRGB(255,255,255),ImageTransparency=.123}):Play()
                if not aimming then BipodCF=lerpCF_dt(BipodCF,CFrame.new(0,((UnderBarrelAtt.Main.Position-bPos).Magnitude-1)*(-1.5),0),14,dt)
                else BipodCF=BipodCF:Lerp(CFrame.new(),.2) end
            else
                BipodActive=false; BipodCF=BipodCF:Lerp(CFrame.new(),.2)
                TS:Create(SE_GUI.GunHUD.Att.Bipod,TweenInfo.new(.1,Enum.EasingStyle.Linear),{ImageColor3=Color3.fromRGB(255,255,0),ImageTransparency=.5}):Play()
            end
        else
            BipodActive=false; CanBipod=false; BipodCF=BipodCF:Lerp(CFrame.new(),.2)
            TS:Create(SE_GUI.GunHUD.Att.Bipod,TweenInfo.new(.1,Enum.EasingStyle.Linear),{ImageColor3=Color3.fromRGB(255,0,0),ImageTransparency=.5}):Play()
        end
    end

    -- VMKick
    local kp=VMKickPos.p; local kr=VMKickRot.p
    vmKickCF=CFrame.new(kp)*CFrame.Angles(kr.X,kr.Y,kr.Z)

    -- VM_Bump
    do
        local bumpTarget=CFrame.new(); local pushTarget=CFrame.new(); VM_Bump=false
        if ToolEquip and WeaponData and WeaponData.Type=="Gun" and AnimDebounce and not reloading and not CheckingMag then
            local hbCF=cam.CFrame*CFrame.new(0,0,-0.5)*gunbobcf
            local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Exclude
            rp.FilterDescendantsInstances={char,cam,ViewModel,WeaponInHand,ACS_Workspace.Client,ACS_Workspace.Server}
            rp.IgnoreWater=true
            local hit=workspace:Raycast(hbCF.Position,hbCF.LookVector*3.0,rp)
            if hit and hit.Instance and hit.Instance:IsA("BasePart") and hit.Instance.Transparency<1 and hit.Instance.Name~="HitIgnore" then
                VM_Bump=true; bumpTarget=BUMP_POSE
                local d=(hit.Position-hbCF.Position).Magnitude
                if d<2.5 then pushTarget=CFrame.new(0,0,math.clamp((2.5-d)/2.5,0,1)*1.5) end
            end
        end
        bumpCF=lerpCF_dt(bumpCF,bumpTarget,20,dt)
        bumpPushCF=lerpCF_dt(bumpPushCF,pushTarget,22,dt)
        if VM_Bump then
            if aimming then
                if not BumpAdsCut then BumpAdsCut=true; aimming=false; ADS(false)
                else aimming=false end
            end
        else BumpAdsCut=false end
    end

    AnimPart.CFrame=cam.CFrame*NearZ*BipodCF*maincf*bumpPushCF*bumpCF*lagCF*gunbobcf*aimcf*recoilcf*vmKickCF

    -- AimPart / maincf lerp
    if CurAimpart and aimming and AnimDebounce and not CheckingMag then
        local useNV=NVG and WeaponInHand.AimPart:FindFirstChild("NVAim")
        if not useNV then
            TS:Create(cam,AimTween,{FieldOfView=AimPartMode==1 and ModTable.ZoomValue or ModTable.Zoom2Value}):Play()
            maincf=lerpCF_dt(maincf,maincf*CFrame.new(0,0,-.5)*Sway:inverse()*CurAimpart.CFrame:toObjectSpace(cam.CFrame),14,dt)
        else
            TS:Create(cam,AimTween,{FieldOfView=70}):Play()
            maincf=maincf:Lerp(maincf*CFrame.new(0,0,-.5)*Sway:inverse()*(WeaponInHand.AimPart.CFrame*WeaponInHand.AimPart.NVAim.CFrame):toObjectSpace(cam.CFrame),0.2)
        end
    else
        TS:Create(cam,AimTween,{FieldOfView=70}):Play()
        maincf=lerpCF_dt(maincf,(WeaponData and WeaponData.MainCFrame or CFrame.new())*Sway:inverse(),14,dt)
    end

    -- Reticle
    for _, p in ipairs(WeaponInHand:GetDescendants()) do
        if p:IsA("BasePart") and p.Name=="SightMark" then
            local ds=p.CFrame:pointToObjectSpace(cam.CFrame.Position)/p.Size
            p.SurfaceGui.Border.Scope.Position=UDim2.new(.5+ds.x,0,.5-ds.y,0)
        end
    end

    recoilcf=gunRecoilState:Update(dt)

    -- Crosshair
    if WeaponData and WeaponData.CrossHair then
        if aimming then
            CHup=lerpU2_dt(CHup,UDim2.new(.5,0,.5,0),14,dt); CHdown=lerpU2_dt(CHdown,UDim2.new(.5,0,.5,0),14,dt)
            CHleft=lerpU2_dt(CHleft,UDim2.new(.5,0,.5,0),14,dt); CHright=lerpU2_dt(CHright,UDim2.new(.5,0,.5,0),14,dt)
        else
            local N=((WeaponData.CrosshairOffset+BSpread+charspeed*WeaponData.WalkMult*ModTable.WalkMult)/50)/10
            CHup=lerpU2_dt(CHup,UDim2.new(.5,0,.5-N,0),35,dt); CHdown=lerpU2_dt(CHdown,UDim2.new(.5,0,.5+N,0),35,dt)
            CHleft=lerpU2_dt(CHleft,UDim2.new(.5-N,0,.5,0),35,dt); CHright=lerpU2_dt(CHright,UDim2.new(.5+N,0,.5,0),35,dt)
        end
    else
        CHup=lerpU2_dt(CHup,UDim2.new(.5,0,.5,0),14,dt); CHdown=lerpU2_dt(CHdown,UDim2.new(.5,0,.5,0),14,dt)
        CHleft=lerpU2_dt(CHleft,UDim2.new(.5,0,.5,0),14,dt); CHright=lerpU2_dt(CHright,UDim2.new(.5,0,.5,0),14,dt)
    end
    Crosshair.Position=UDim2.new(0,mouse.X,0,mouse.Y)
    Crosshair.Up.Position=CHup; Crosshair.Down.Position=CHdown
    Crosshair.Left.Position=CHleft; Crosshair.Right.Position=CHright

    -- Spread decay
    if BSpread and WeaponData then
        local ct=time()
        if ct-LastSpreadUpdate>(60/WeaponData.ShootRate)*2 and not shooting and BSpread>WeaponData.MinSpread*ModTable.MinSpread then
            BSpread=math.max(WeaponData.MinSpread*ModTable.MinSpread,BSpread-WeaponData.AimInaccuracyDecrease*ModTable.AimInaccuracyDecrease)
        end
        if ct-LastSpreadUpdate>(60/WeaponData.ShootRate)*1.5 and not shooting and RecoilPower>WeaponData.MinRecoilPower*ModTable.MinRecoilPower then
            RecoilPower=math.max(WeaponData.MinRecoilPower*ModTable.MinRecoilPower,RecoilPower-WeaponData.RecoilPowerStepAmount*ModTable.RecoilPowerStepAmount)
        end
    end

    -- Gun bob
    if running then
        gunbobcf=lerpCF_dt(gunbobcf,
            CFrame.new(.025*(charspeed/10)*math.sin(tick()*8),.025*(charspeed/10)*math.cos(tick()*16),0)
            *CFrame.Angles(math.rad(math.sin(tick()*16)*(charspeed/10)),math.rad(math.cos(tick()*8)*(charspeed/10)),0),
            6.3,dt)
    else
        gunbobcf=lerpCF_dt(gunbobcf,CFrame.new(.005*math.sin(tick()*1.5),.005*math.cos(tick()*2.5),0),6.3,dt)
    end

    -- Laser
    if LaserActive and Pointer then
        Pointer.Transparency=(IRmode and not NVG) and 1 or 0
        local beamOn=NVG or not gameRules.RealisticLaser
        for _, d in ipairs(WeaponInHand:GetDescendants()) do if d:IsA("Beam") then d.Enabled=beamOn end end
        for _, Key in ipairs(WeaponInHand:GetDescendants()) do
            if Key:IsA("BasePart") and Key.Name=="LaserPoint" then
                local lr=Ray.new(Key.CFrame.Position,Key.CFrame.LookVector*1000)
                local h,p=workspace:FindPartOnRayWithIgnoreList(lr,Ignore_Model,false,true)
                Pointer.CFrame=h and CFrame.new(p,p+Vector3.new(0,1,0)) or CFrame.new(cam.CFrame.Position+Key.CFrame.LookVector*2000,Key.CFrame.LookVector)
                if HalfStep and gameRules.ReplicatedLaser then Evt.SVLaser:FireServer(p,1,Pointer.Color,IRmode,WeaponTool) end
                break
            end
        end
    end
end)

