self.ReloadAnim = function(objs)
	TS:Create(objs[1],TweenInfo.new(.25,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(0.1,0.15,1) * CFrame.Angles(math.rad(90),math.rad(-20),math.rad(0))):inverse() }):Play()
	TS:Create(objs[2],TweenInfo.new(.25,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(-1,-2,1) * CFrame.Angles(math.rad(110),math.rad(35),math.rad(15))):inverse() }):Play()
	wait(.25)

	------------------------------------
	local MagC = Instance.new("Part")
	MagC.Size = Vector3.new(0.2,0.2,0.2)
	MagC.Transparency = 1
	MagC.CanCollide = false
	MagC.CFrame = objs[4].Handle.CFrame
	MagC.Parent = objs[4]

	local W = Instance.new("Motor6D")
	W.Part0 = objs[4].Handle
	W.Part1 = MagC
	local CJ = CFrame.new(W.Part0.Position)
	W.C0 = W.Part0.CFrame:ToObjectSpace(W.Part1.CFrame)
	W.Parent = MagC

	-- Create fake warhead
	for _, child in pairs(objs[4]:GetChildren()) do
		if child.Name == "Mag" then
			local nPart = child:Clone()
			nPart.Transparency = 0
			nPart.Name = "TempModel"
			nPart.Anchored = true
			local W2 = Instance.new("Weld")
			W2.Part0 = nPart
			W2.Part1 = MagC
			local CJ = CFrame.new(W.Part0.Position)
			W2.C0 = W2.Part0.CFrame:ToObjectSpace(W.Part1.CFrame)
			W2.Parent = nPart
			nPart.Anchored = false
			nPart.Parent = MagC
		end
	end

	W.C1 = CFrame.new(0,2,0)

	TS:Create(W, TweenInfo.new(.25,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {C1 = CFrame.new(0,2,0)}):Play()
	------------------------------------------------------

	wait(.25)
	TS:Create(objs[2],TweenInfo.new(.5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(-.5,-0.15,0.4) * CFrame.Angles(math.rad(110),math.rad(-30),math.rad(15))):inverse() }):Play()
	TS:Create(W, TweenInfo.new(.5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {C1 = CFrame.new(0.2,.2,0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))}):Play()
	wait(.5)
	objs[4].Handle.MagOut:play()
	TS:Create(objs[1],TweenInfo.new(.5,Enum.EasingStyle.Back,Enum.EasingDirection.InOut),{C1 = (CFrame.new(0.1,0.15,1) * CFrame.Angles(math.rad(85),math.rad(-20),math.rad(0))):inverse() }):Play()
	TS:Create(W, TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {C1 = CFrame.new(0.2,.5,0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))}):Play()
	TS:Create(objs[4].Handle.Mag,TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(0,-.5,0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))):inverse() }):Play()
	TS:Create(objs[2],TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(-.5,-0.5,0.4) * CFrame.Angles(math.rad(110),math.rad(-30),math.rad(15))):inverse() }):Play()
	wait(.35)
	TS:Create(W, TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {C1 = CFrame.new(0,.5,0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))}):Play()
	TS:Create(objs[4].Handle.Mag,TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(0,-.5,-0.2) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))):inverse() }):Play()
	TS:Create(objs[2],TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(-.3,-0.5,0.4) * CFrame.Angles(math.rad(110),math.rad(-30),math.rad(15))):inverse() }):Play()
	wait(.35)
	TS:Create(objs[1],TweenInfo.new(.5,Enum.EasingStyle.Back,Enum.EasingDirection.InOut),{C1 = (CFrame.new(0.1,0.15,1) * CFrame.Angles(math.rad(95),math.rad(-20),math.rad(0))):inverse() }):Play()
	TS:Create(objs[2],TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(-.3,-0.1,0.4) * CFrame.Angles(math.rad(110),math.rad(-30),math.rad(15))):inverse() }):Play()
	objs[4].Handle.MagIn:Play()
	objs[4].Handle.AimUp:play()
	TS:Create(objs[4].Handle.Mag,TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(0,-.2,-0.2) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))):inverse() }):Play()
	TS:Create(W, TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {C1 = CFrame.new()}):Play()
	wait(.35)
	TS:Create(objs[2],TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(-.3,-1,1) * CFrame.Angles(math.rad(110),math.rad(-30),math.rad(15))):inverse() }):Play()
	TS:Create(objs[4].Handle.Mag,TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(0,-1.5,0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))):inverse() }):Play()
	wait(.35)
	TS:Create(objs[1], TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {C1 = self.RArmCFrame:Inverse()}):Play()
	TS:Create(objs[2],TweenInfo.new(.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{C1 = (CFrame.new(-1,-1,1) * CFrame.Angles(math.rad(110),math.rad(-30),math.rad(15))):inverse() }):Play()
	wait(.35)

	TS:Create(objs[2], TweenInfo.new(.25,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {C1 = self.LArmCFrame:Inverse()}):Play()
	objs[4].Mag.Transparency = 1
	TS:Create(objs[4].Handle.Mag,TweenInfo.new(.01,Enum.EasingStyle.Back),{C1 = (CFrame.new()):inverse() }):Play()
	wait(.25)

	for _, cPart in pairs(objs[4]:GetChildren()) do
		if cPart.Name == "Mag" then
			cPart.Transparency = 0
		end
	end

	MagC:Destroy()	


end;

