self.EquipAnim = function(objs)
	-- Фаза 1: Подготовка (было 0.25с -> стало 0.6с)
	TS:Create(objs[1], TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
		C1 = (CFrame.new(1, -1, 1) * CFrame.Angles(0, 0, 0)):inverse() 
	}):Play()

	TS:Create(objs[2], TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
		C1 = (CFrame.new(-1, -1, 1) * CFrame.Angles(0, 0, 0)):inverse() 
	}):Play()

	task.wait(0.6) -- Используем task.wait для большей точности

	-- Фаза 2: Финальная позиция (было 0.35с -> стало 0.8с)
	TS:Create(objs[1], TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
		C1 = self.RArmCFrame:Inverse()
	}):Play()

	TS:Create(objs[2], TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
		C1 = self.LArmCFrame:Inverse()
	}):Play()

	task.wait(0.8)
end;
