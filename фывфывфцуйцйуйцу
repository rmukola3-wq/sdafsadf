local ReturnToIdle = function(VMHuman,WeaponInHand)
	if not self.LoadedAnims["Idle"] then
		self.LoadedAnims["Idle"] = VMHuman:LoadAnimation(WeaponInHand.ViewmodelAnims["Idle"])
		self.LoadedAnims["Idle"].Looped = true
		self.LoadedAnims["Idle"]:Play()
	else
		self.LoadedAnims["Idle"].Looped = true
		self.LoadedAnims["Idle"]:Play()
	end
end

local InitiateAnim = function(VMHuman, AnimName, WeaponInHand, WaitTillStopped, Loop)
	local FADE_TIME = gameRules.StanceTransitionTime

	local function smoothStopAnimation(anim)
		if anim.IsPlaying then
			anim:Stop(FADE_TIME)
		end
	end

	for _, playinganim in pairs(self.LoadedAnims) do
		smoothStopAnimation(playinganim)
	end
	
	if not self.LoadedAnims[AnimName] then
		local animationTrack
		if Data.Animations.NewSystem then
			animationTrack = VMHuman:LoadAnimation(AnimationsFolder:FindFirstChild(GunPlatform.."Platform").ViewmodelAnims[AnimName])
		else
			animationTrack = VMHuman:LoadAnimation(WeaponInHand.ViewmodelAnims[AnimName])
		end
		self.LoadedAnims[AnimName] = animationTrack
	end

	local animationTrack = self.LoadedAnims[AnimName]

	if Loop then
		animationTrack.Looped = true
	end

	animationTrack:Play(FADE_TIME)

	if (WaitTillStopped and not Loop) and animationTrack then
		animationTrack.Stopped:Wait()
		ReturnToIdle(VMHuman, WeaponInHand)
	end
end

