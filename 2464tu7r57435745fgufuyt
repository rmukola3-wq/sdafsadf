local Tracers = 0
function TracerCalculation()
	if BulletData ~= nil and BulletData.Tracer or WeaponData.Tracer or WeaponData.BulletFlare then
		if BulletData ~= nil and BulletData.RandomTracer.Enabled or WeaponData.RandomTracer.Enabled then
			if (math.random(1, 100) <= (BulletData ~= nil and BulletData.RandomTracer.Chance or  WeaponData.RandomTracer.Chance)) then	
				return true
			else
				return false
			end
		else
			if Tracers >= (BulletData ~= nil and BulletData.TracerEveryXShots or WeaponData.TracerEveryXShots) then
				Tracers = 0
				return true
			else
				Tracers = Tracers + 1
				return false
			end
		end
	end
end

