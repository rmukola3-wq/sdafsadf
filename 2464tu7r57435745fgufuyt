		WeaponData.ShootType = 1
		ModeText = 'Semi Automatic'
		---Auto Settings---
	elseif WeaponData.ShootType == 3 and WeaponData.FireModes.Semi == true then
		WeaponData.ShootType = 1
		ModeText = 'Semi Automatic'
