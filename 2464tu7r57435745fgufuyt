function handleAction(actionName, inputState, inputObject)
if plr.PlayerGui:FindFirstChild('WardrobeGUI') and actionName ~= "Third" then return end
	if actionName == "Fire" and inputState == Enum.UserInputState.Begin and AnimDebounce then
		Shoot()

		if WeaponData.Type == "Grenade" then
			CookGrenade = true
			Grenade()
		end



	elseif actionName == "Fire" and inputState == Enum.UserInputState.End then
		mouse1down = false
		CookGrenade = false
	end

	if actionName == "Reload" and inputState == Enum.UserInputState.Begin and AnimDebounce and not CheckingMag and not reloading then
		if WeaponData.Jammed then
			Jammed()
		else
			Reload()
		end
	end

	if actionName == "Reload" and inputState == Enum.UserInputState.Begin and reloading and WeaponData.ShellInsert then
		CancelReload = true
	end

	if actionName == "CycleLaser" and inputState == Enum.UserInputState.Begin and LaserAtt then
		SetLaser()
	end

	if actionName == "CycleLight" and inputState == Enum.UserInputState.Begin and TorchAtt then
		SetTorch()
	end

	if actionName == "CycleFiremode" and inputState == Enum.UserInputState.Begin and WeaponData and WeaponData.FireModes.ChangeFiremode then
		Firemode()
	end

	if actionName == "CycleAimpart" and inputState == Enum.UserInputState.Begin then
		SetAimpart()
	end

	if actionName == "ZeroUp" and inputState == Enum.UserInputState.Begin and WeaponData and WeaponData.EnableZeroing  then
		if WeaponData.CurrentZero < WeaponData.MaxZero then
			WeaponInHand.BodyAttach.Click:play()
			WeaponData.CurrentZero = math.min(WeaponData.CurrentZero + WeaponData.ZeroIncrement, WeaponData.MaxZero) 
			UpdateGui()
		end
	end

	if actionName == "ZeroDown" and inputState == Enum.UserInputState.Begin and WeaponData and WeaponData.EnableZeroing  then
		if WeaponData.CurrentZero > 0 then
			WeaponInHand.BodyAttach.Click:play()
			WeaponData.CurrentZero = math.max(WeaponData.CurrentZero - WeaponData.ZeroIncrement, 0) 
			UpdateGui()
		end
	end

	if actionName == "CheckMag" and inputState == Enum.UserInputState.Begin and not CheckingMag and not reloading and not runKeyDown and AnimDebounce then
		CheckMagFunction()
	end

	if actionName == "ToggleBipod" and inputState == Enum.UserInputState.Begin and CanBipod then

		BipodActive = not BipodActive
		UpdateGui()
	end

	if actionName == "NVG" and inputState == Enum.UserInputState.Begin and not NVGdebounce then
		if plr.Character then
			local helmet = plr.Character:FindFirstChild("Helmet")
			if helmet then
				local nvg = helmet:FindFirstChild("Up")
				if nvg then
					NVGdebounce = true
					delay(.8,function()
						NVG = not NVG
						Evt.NVG:Fire(NVG)
						NVGdebounce = false		
					end)

				end
			end
		end
	end

	if actionName == "ADS" and inputState == Enum.UserInputState.Begin and AnimDebounce then
		if WeaponData and WeaponData.canAim and GunStance > -2 and not runKeyDown and not CheckingMag then
			aimming = not aimming
			ADS(aimming)

		end

		if WeaponData.Type == "Grenade" then
			GrenadeMode()
		end
	end


	if actionName == "Stand" and inputState == Enum.UserInputState.Begin and ChangeStance and not Swimming and not Sentado and not runKeyDown then
		if Stances == 2 then
			Crouched = false
			Proned = false
			Stances = 0
			TS:Create(script.Offset, TweenInfo.new(.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, 0, false, 0), {Value = -.5}):Play()

			CameraY = -.5
			Stand()


		elseif Stances == 0 or Stances == 1 then		
			Crouched = false
			Proned = true
			Stances = 2
			CameraY = -2
			TS:Create(script.Offset, TweenInfo.new(.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, 0, false, 0), {Value = -.5}):Play()

			Prone()
		end	
	end

	if actionName == "Crouch" and inputState == Enum.UserInputState.Begin and ChangeStance and not Swimming and not Sentado and not runKeyDown then
		if Stances == 0 then
			Stances = 1
			CameraY = -.5
			TS:Create(script.Offset, TweenInfo.new(.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, 0, false, 0), {Value = -.5}):Play()
			Crouch()
			Crouched = true
		elseif Stances == 1 then	
			Crouched = false
			Proned = false
			Stances = 0
			TS:Create(script.Offset, TweenInfo.new(.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, 0, false, 0), {Value = -.5}):Play()

			CameraY = -.5
			Stand()
		end
	end



	if actionName == "LeanLeft" and inputState == Enum.UserInputState.Begin and Stances ~= 2 and ChangeStance and not Swimming and not runKeyDown and CanLean then
		if Virar == 0 or Virar == 1 then
			Virar = -1
			CameraX = -.35
			lean = true
			Humanoid.AutoRotate = false
			if third then
			TS:Create(script.ShoulderOffset,TweenInfo.new(0.4,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{Value = Virar}):Play()
			task.delay(0.4,function()
				canSwapShoulder = true
				end)
			end
		else
			Virar = 0
			CameraX = 0
			if freelook == true and not InCam and not ToolEquip then
				Humanoid.AutoRotate = true
			end
			delay(.2,function()
				lean = false

			end)
			--[[TS:Create(script.ShoulderOffset,TweenInfo.new(0.4,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{Value = 1}):Play()
			task.delay(0.4,function()
				canSwapShoulder = true
			end)]]--
		end
		Lean()
	end
	if actionName == "FreeLook" and inputState == Enum.UserInputState.Begin and not Sitting then
		if freelook == true then
			freelook = false
			looking = false
			Humanoid.AutoRotate = false

			oldY,oldX,oldZ = cam.CFrame:ToOrientation()
			prevAngle = cam.CFrame
			canBrightness = true
			--print('brightness switch on')
			task.wait(0.25)
				canBrightness = false
				--print('brightness switch off')
		end
	end

	if actionName == "FreeLook" and inputState == Enum.UserInputState.End and not Sitting then
		if freelook == false then
			--[[if prevAngle ~= nil and oldY and oldX and oldZ then
				TS:Create(cam,TweenInfo.new(.3,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{CFrame = CFrame.new(cam.CFrame.Position,prevAngle.Position+prevAngle.lookVector)}):Play()

				wait(0.3)
			end]]--
			if Equipped and WeaponInHand ~= nil and AnimPart ~= nil and not returnAnim then
				--returnAnim = true
				--wait(0.25)
				returnAnim = false
			end
			freelook =true
			looking = true
			if Virar == 0 and not InCam and not ToolEquip then
				Humanoid.AutoRotate = true
			end
			--print(canBrightness)
			if canBrightness == true and ViewModel and WeaponInHand and WeaponInHand:FindFirstChild('SightMark') and WeaponTool then
				if WeaponTool:FindFirstChild('MaxReticleBrightness') and WeaponTool:FindFirstChild('MinReticleBrightness') then
					for i,v in pairs(WeaponInHand:GetChildren()) do
						if v.Name == "SightMark" and v:IsA('BasePart') and v:FindFirstChildOfClass('SurfaceGui') then
							if v:FindFirstChildOfClass('SurfaceGui').Brightness >= WeaponTool:FindFirstChild('MaxReticleBrightness').Value then
								v:FindFirstChildOfClass('SurfaceGui').Brightness = WeaponTool:FindFirstChild('MinReticleBrightness').Value
								WeaponTool.CurrentBrightness.Value = WeaponTool:FindFirstChild('MinReticleBrightness').Value
							else
								v:FindFirstChildOfClass('SurfaceGui').Brightness = WeaponTool:FindFirstChild('MaxReticleBrightness').Value
								WeaponTool.CurrentBrightness.Value = WeaponTool:FindFirstChild('MaxReticleBrightness').Value
							end
						end
					end
					WeaponInHand.BodyAttach.Click:play()
				end
			end
		end
		--canBrightness = true
	end

	if actionName == "Third" and inputState == Enum.UserInputState.Begin and (not InCam or GunCam == nil) then
		if third == false then

			TS:Create(game.Lighting.ColorCorrection,TweenInfo.new(.2, Enum.EasingStyle.Linear),{Brightness = -1}):Play()
			task.wait(.2)

			third = true
			
			if Equipped and WeaponData and WeaponData.Type == "Gun" and WeaponInHand ~= nil and char:FindFirstChild('S'..WeaponInHand.Name) then
			if char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('Magazine1') ~= nil then
				script.AmmoCounter.Adornee = char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('Magazine1')
			elseif char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('Mag') ~= nil then
				script.AmmoCounter.Adornee = char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('Mag')
			else
				script.AmmoCounter.Adornee = char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('BodyAttach')
			end

			script.Firemode.Adornee = char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('BodyAttach')
				if char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('Slide') ~= nil then
					script.Malfunction.Adornee = char:FindFirstChild('S'..WeaponInHand.Name):FindFirstChild('Slide')
				end
			end
			
			TS:Create(game.Lighting.ColorCorrection,TweenInfo.new(.2, Enum.EasingStyle.Linear),{Brightness = 0}):Play()
			if WeaponInHand ~= nil then
				for index, Key in pairs(WeaponInHand:GetDescendants()) do
					if Key:IsA("BasePart") and Key.Name == "FlashPoint" then
						Key.Light.Enabled = false
					end
				end
			Evt.SVFlash:FireServer(WeaponTool,TorchActive,third)
			end
			if ViewModel then
				for i,v in pairs(ViewModel:GetDescendants()) do
					if v:IsA("BasePart") or v:IsA('Decal') then
						if v.Name == "Ignore" or v:IsA('Decal') then
							v.Transparency = 1
						end
					elseif v:IsA('SurfaceGui') then
						v.Enabled = false
					end
				end
			end
			
		elseif third == true then

			TS:Create(game.Lighting.ColorCorrection,TweenInfo.new(.2, Enum.EasingStyle.Linear),{Brightness = -1}):Play()
			task.wait(.2)

			third = false
			
			if Equipped and WeaponData and WeaponData.Type == "Gun" and WeaponInHand ~= nil then
				if WeaponInHand:FindFirstChild('Magazine1') ~= nil then
					script.AmmoCounter.Adornee = WeaponInHand:FindFirstChild('Magazine1')
					
				elseif WeaponInHand:FindFirstChild('Mag') ~= nil then
					script.AmmoCounter.Adornee = WeaponInHand:FindFirstChild('Mag')
				else
					script.AmmoCounter.Adornee = WeaponInHand:FindFirstChild('BodyAttach')
				end
				script.Firemode.Adornee = WeaponInHand:FindFirstChild('BodyAttach')
				if WeaponInHand:FindFirstChild('Slide') ~= nil then
					script.Malfunction.Adornee = WeaponInHand:FindFirstChild('Slide')
				end
			end
			
			TS:Create(game.Lighting.ColorCorrection,TweenInfo.new(.2, Enum.EasingStyle.Linear),{Brightness = 0}):Play()
			if ViewModel then
			if TorchActive then
				for index, Key in pairs(WeaponInHand:GetDescendants()) do
					if Key:IsA("BasePart") and Key.Name == "FlashPoint" then
						local Bright = GunModels[WeaponInHand.Name].FlashPoint.Light.Brightness
						Key.Light.Brightness = 0
						Key.Light.Enabled = true
						TS:Create(Key.Light,TweenInfo.new(0.35,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{Brightness = Bright}):Play()
					end
				end
			else
				for index, Key in pairs(WeaponInHand:GetDescendants()) do
					if Key:IsA("BasePart") and Key.Name == "FlashPoint" then
						Key.Light.Enabled = false
					end
				end
			end
				Evt.SVFlash:FireServer(WeaponTool,TorchActive,third)
			end
			if ViewModel then
				for i,v in pairs(ViewModel:GetDescendants()) do
					if v:IsA("BasePart") or v:IsA('Decal') then
						if not v:FindFirstChild("Transparent") and not v:FindFirstChild("Ignore") then
							if Head:FindFirstChild('OLD_TRANSPARENCY') then
								v.Transparency = 0.5
								v.Material = Enum.Material.ForceField
								local col = Instance.new('Color3Value',v)
								col.Name = "OLD_COLOR"
								col.Value = v.Color
								v.Color = Color3.new(255,255,255)
							else
								if v:FindFirstChild('Transparent') and (v:FindFirstChild('Transparent'):IsA('IntValue') or v:FindFirstChild('Transparent'):IsA('NumberValue')) then
									v.Transparency = v:FindFirstChild('Transparent').Value
								else
									v.Transparency = 0
								end
								--v.Material = Enum.Material.Fabric
								if v:FindFirstChild('OLD_COLOR') then
									v.Color = v:FindFirstChild('OLD_COLOR').Value
									v:FindFirstChild('OLD_COLOR'):Destroy()
								end
							end

						end
					elseif v:IsA('SurfaceGui') then
						v.Enabled = true
					end
				end
				if WeaponInHand:FindFirstChild('Magazine2') ~= nil then
					WeaponInHand:FindFirstChild('Magazine2').Transparency = 1
				end
			end
		end
