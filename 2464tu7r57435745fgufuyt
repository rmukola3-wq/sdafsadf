function New_CheckMag()
	-- Reset the list of mags
	allmags = {}
	local result = false
	local fmag = nil
	
	for i,v in ipairs(plr.Character.GridInventory:GetChildren()) do
		if v:FindFirstChild("MagType") and v:FindFirstChild("MagType").Value == WeaponData.BulletType and v.Rounds.Value > 0 then
			table.insert(allmags,v)
			if v:FindFirstChild("MagType") and v:FindFirstChild("MagType").Value == WeaponData.BulletType and v.Rounds.Value > 0 and v ~= oldmag and not table.find(mags,v) then
				if #mags >= #allmags then
					mags = {}
				end
				if result == false then
					result = true
					fmag = v
				end
			end
		end
	end
	return result,fmag
