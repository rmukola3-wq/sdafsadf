				PumpAnim()
				WeaponData.Jammed = false
				RunCheck()
				if WeaponInHand:FindFirstChild("LoopEnd") then
					loopend = WeaponInHand:FindFirstChild("LoopEnd").Value
				end
				shooting = false
				delay((loopend or 0.075),function()
					shooting = false
					GunFx()
					Evt.Atirar:FireServer(WeaponTool,Suppressor,FlashHider,false,barrelMode,WeaponData,Ammo)
				end)
				task.wait(60/WeaponData.ShootRate)
				shooting = false
			end
			Evt.Atirar:FireServer(WeaponTool,Suppressor,FlashHider,false,barrelMode,WeaponData,Ammo)
			GunFx()
		end)

		if WeaponInHand.BodyAttach:FindFirstChild('Muzzle2') then
			if barrelMode == 1 then
				barrelMode = 2
			elseif barrelMode == 2 then
				barrelMode = 1
			end
		else
			barrelMode = 1
		end



	elseif WeaponData and WeaponData.Type == "Melee" and not runKeyDown then
		if not shooting then
			shooting = true
			meleeCast()
			meleeAttack()
			RunCheck()
			shooting = false
		end
	end
end
