					Pointer.Beam.Enabled = true
				end
				if IRmode then
					Pointer.Beam.Enabled = false
					Pointer.Transparency = 1
					Pointer.Gui.Dot.ImageTransparency = 1
				else
					Pointer.Transparency = 1
					Pointer.Gui.Dot.ImageTransparency = 0
					Pointer.Beam.Enabled = true

				end
			end
			if third == true and looking == false then
				if char:FindFirstChild("S"..WeaponInHand.Name) then
					for index, Key in pairs(char:FindFirstChild("S"..WeaponInHand.Name):GetDescendants()) do
						if Key:IsA("BasePart") and Key.Name == "LaserPoint" then
							local L_361_ = Ray.new(Key.CFrame.Position, Key.CFrame.LookVector * 1000)
							local Hit, Pos, Normal = workspace:FindPartOnRayWithIgnoreList(L_361_, Ignore_Model, false, true)
							
							
							if Hit then
								Pointer.CFrame =  CFrame.new(Pos, Pos - Normal)
							else
								Pointer.CFrame =  CFrame.new(cam.CFrame.Position + Key.CFrame.LookVector * 2000, Key.CFrame.LookVector)
							end

							if HalfStep and gameRules.ReplicatedLaser then
								Evt.SVLaser:FireServer(Pointer.CFrame,1,Pointer.Color,IRmode,WeaponTool)
							end
							break
						end
					end
				end
			elseif third == false or third == true and looking == true then
				for index, Key in pairs(WeaponInHand:GetDescendants()) do
					if Key:IsA("BasePart") and Key.Name == "LaserPoint" then
						local L_361_ = Ray.new(Key.CFrame.Position, Key.CFrame.LookVector * 1000)
						local Hit, Pos, Normal = workspace:FindPartOnRayWithIgnoreList(L_361_, Ignore_Model, false, true)

						if Hit then
							Pointer.CFrame =  CFrame.new(Pos, Pos - Normal)
						else
							Pointer.CFrame =  CFrame.new(cam.CFrame.Position + Key.CFrame.LookVector * 2000, Key.CFrame.LookVector)
						end

						if HalfStep and gameRules.ReplicatedLaser then
							Evt.SVLaser:FireServer(Pointer.CFrame,1,Pointer.Color,IRmode,WeaponTool)
						end
						break
					end
				end
			end
		end
	else
		for i,v in pairs(char:GetChildren()) do
			if v.Name == "RightUpperArm" or v.Name == "RightLowerArm" or v.Name == "RightHand" or v.Name == "LeftUpperArm" or v.Name == "LeftLowerArm" or v.Name == "LeftHand" then
				v.Transparency = 0
			end


		end
	end
end)
