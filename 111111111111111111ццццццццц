		RArmWeld.Part0 = AnimPart

		GunWeld = Instance.new("Motor6D",AnimPart)
		GunWeld.Name = "Handle"

		--setup arms to camera

		-- если пока мы делали WaitForChild/Clone пришёл новый setup() — выходим
		if myVersion ~= SetupVersion or myToken ~= EquipToken then
			pcall(function() ViewModel:Destroy() end)
			ViewModel = nil
			return
		end

		ViewModel.Parent = cam

		maincf = AnimData.MainCFrame
		guncf = AnimData.GunCFrame

