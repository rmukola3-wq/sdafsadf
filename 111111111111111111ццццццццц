local RecoilProfilesFolder = Mods:WaitForChild("RecoilProfiles")
local _profileCache = {}

local function GetRecoilProfile(profileName)
	if _profileCache[profileName] then
		return _profileCache[profileName]
	end

	local m = RecoilProfilesFolder:FindFirstChild(profileName)
	if not m or not m:IsA("ModuleScript") then
		return nil
	end

	local ok, profile = pcall(require, m)
	if not ok then
		warn("[Recoil] Profile require failed:", profileName, profile)
		return nil
	end

	_profileCache[profileName] = profile
	return profile
end

