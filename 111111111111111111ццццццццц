Run.RenderStepped:Connect(function(step)
	HeadMovement()
	renderGunRecoil()
	-- renderCam() только в ADS
	if aimming then
		renderCam()
	end
	
	-- Debug: print FPS every 2 seconds
	-- print("dt", step, "fps", math.floor(1/step))

	if ViewModel and LArm and RArm and WeaponInHand then --Check if the weapon and arms are loaded

		local mouseDelta = User:GetMouseDelta()
		-- Sway меньше в ADS
		local swayScale = aimming and adsSwayScale or 1
		SwaySpring:accelerate(Vector3.new((mouseDelta.x/60)*swayScale, (mouseDelta.y/60)*swayScale, 0))

		-- Weapon Lag / Inertia Sway (hip vs ads, stable across FPS)
		local rotK = aimming and LAG_ROT_ADS or LAG_ROT_HIP
		local posK = aimming and LAG_POS_ADS or LAG_POS_HIP
		local lagMax = aimming and LAG_MAX_ADS or LAG_MAX_HIP

		-- target для пружины (угловое отставание)
		LagSpring.t = Vector3.new(
			math.clamp(-mouseDelta.Y * rotK, -lagMax, lagMax),
			math.clamp(-mouseDelta.X * rotK, -lagMax, lagMax),
			0
		)

		local lp = LagSpring.p

		-- позиционное отставание (немного "массы")
		local lagPosX = math.clamp(-mouseDelta.X * posK, -0.08, 0.08)
		local lagPosY = math.clamp(-mouseDelta.Y * posK, -0.06, 0.06)

		local lagCF =
			CFrame.new(lagPosX, lagPosY, 0)
			* CFrame.Angles(lp.X, lp.Y, 0)

		local swayVec = SwaySpring.p
		local TSWAY = swayVec.z
		local XSSWY = swayVec.X
		local YSSWY = swayVec.Y
		local Sway = CFrame.Angles(YSSWY,XSSWY,XSSWY)

		if BipodAtt then

			local BipodRay = Ray.new(UnderBarrelAtt.Main.Position, Vector3.new(0,-1.75,0))
			local BipodHit, BipodPos, BipodNorm = workspace:FindPartOnRayWithIgnoreList(BipodRay, Ignore_Model, false, true)

			if BipodHit then
				CanBipod = true
				if CanBipod and BipodActive and not runKeyDown and (GunStance == 0 or GunStance == 2) then
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255,255,255), ImageTransparency = .123}):Play()
					if not aimming then
						BipodCF = lerpCF_dt(BipodCF, CFrame.new(0,(((UnderBarrelAtt.Main.Position - BipodPos).magnitude)-1) * (-1.5), 0), 14, step)
					else
						BipodCF = BipodCF:Lerp(CFrame.new(),.2)
					end				

				else
					BipodActive = false
					BipodCF = BipodCF:Lerp(CFrame.new(),.2)
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255,255,0), ImageTransparency = .5}):Play()
				end
			else
				BipodActive = false
				CanBipod = false
				BipodCF = BipodCF:Lerp(CFrame.new(),.2)
				TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255,0,0), ImageTransparency = .5}):Play()
			end

		end

		local kp = VMKickPos.p
		local kr = VMKickRot.p
		vmKickCF = CFrame.new(kp) * CFrame.Angles(kr.X, kr.Y, kr.Z)

		-- VM_Bump: wall collision check (как ACS HeadBase)
		do
			local bumpTarget = CFrame.new()
			local pushTarget = CFrame.new()
			VM_Bump = false

			local BUMP_DIST = 3.0

			local PUSH_START_DIST = 2.5   -- когда начинаем отодвигать (studs)
			local PUSH_MAX = 1.5          -- максимум отодвигания назад (studs)
			local PUSH_SPEED = 22         -- скорость догонки

			if ToolEquip and WeaponInHand and WeaponData and WeaponData.Type == "Gun"
				and AnimDebounce and not reloading and not CheckingMag then

				-- аналог HeadBase: cam * (0,0,-0.5) * gunbobcf
				local headBaseCF = cam.CFrame * CFrame.new(0, 0, -0.5) * gunbobcf
				local origin = headBaseCF.Position
				local dir = headBaseCF.LookVector * BUMP_DIST

				local params = RaycastParams.new()
				params.FilterType = Enum.RaycastFilterType.Exclude
				params.FilterDescendantsInstances = {char, cam, ViewModel, WeaponInHand, ACS_Workspace.Client, ACS_Workspace.Server}
				params.IgnoreWater = true

				local hit = workspace:Raycast(origin, dir, params)
				if hit and hit.Instance and hit.Instance:IsA("BasePart") then
					local p = hit.Instance
					if p.Transparency < 1 and p.Name ~= "HitIgnore" then
						VM_Bump = true
						bumpTarget = BUMP_POSE

						local dist = (hit.Position - origin).Magnitude
						if dist < PUSH_START_DIST then
							local t = math.clamp((PUSH_START_DIST - dist) / PUSH_START_DIST, 0, 1)
							local push = t * PUSH_MAX
							pushTarget = CFrame.new(0, 0, push) -- +Z = назад к камере
						end
						-- DEBUG (можно потом удалить)
						-- print("dist=", dist, "pushZ=", pushTarget.Z, "VM_Bump=", VM_Bump)
					end
				end
			end

			bumpCF = lerpCF_dt(bumpCF, bumpTarget, BUMP_SPEED, step)
			bumpPushCF = lerpCF_dt(bumpPushCF, pushTarget, PUSH_SPEED, step)

			-- Force disable ADS when near-wall bump triggers (even if player was already aiming)
			if VM_Bump then
				if aimming then
					if not BumpAdsCut then
						BumpAdsCut = true
						aimming = false
						ADS(false)
					else
						-- keep state off without spamming ADS(false)
						aimming = false
					end
				end
			else
				BumpAdsCut = false
			end
		end

		AnimPart.CFrame = cam.CFrame * NearZ * BipodCF * maincf * bumpPushCF * bumpCF * lagCF * gunbobcf * aimcf * recoilcf * vmKickCF

		if not AnimData.GunModelFixed then
			WeaponInHand:SetPrimaryPartCFrame(
				ViewModel.PrimaryPart.CFrame
					* guncf
			)
		end

		if running then
			gunbobcf = lerpCF_dt(gunbobcf, CFrame.new(
				0.025 * (charspeed/10) * math.sin(tick() * 8),
				0.025 * (charspeed/10) * math.cos(tick() * 16),
				0
				) * CFrame.Angles(
					math.rad( 1 * (charspeed/10) * math.sin(tick() * 16) ), 
					math.rad( 1 * (charspeed/10) * math.cos(tick() * 8) ), 
					math.rad(0)
				), 6.3, step)
		else
			gunbobcf = lerpCF_dt(gunbobcf, CFrame.new(
				0.005 * math.sin(tick() * 1.5),
				0.005 * math.cos(tick() * 2.5),
				0 
				), 6.3, step)
		end

		if CurAimpart and aimming and AnimDebounce and not CheckingMag then
			if not NVG or WeaponInHand.AimPart:FindFirstChild("NVAim") == nil then
				if AimPartMode == 1 then
					TS:Create(cam,AimTween,{FieldOfView = ModTable.ZoomValue}):Play()
-- BACKUP: maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 0.2)
					maincf = lerpCF_dt(maincf, maincf * CFrame.new(0,0,-.5) * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 14, step)
				else
					TS:Create(cam,AimTween,{FieldOfView = ModTable.Zoom2Value}):Play()
-- BACKUP: maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 0.2)
					maincf = lerpCF_dt(maincf, maincf * CFrame.new(0,0,-.5) * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 14, step)
				end
			else
				TS:Create(cam,AimTween,{FieldOfView = 70}):Play()
-- BACKUP: maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * Sway:inverse() * (WeaponInHand.AimPart.CFrame * WeaponInHand.AimPart.NVAim.CFrame):toObjectSpace(cam.CFrame), 0.2)
				maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * Sway:inverse() * (WeaponInHand.AimPart.CFrame * WeaponInHand.AimPart.NVAim.CFrame):toObjectSpace(cam.CFrame), 0.2)
			end

		else
			TS:Create(cam,AimTween,{FieldOfView = 70}):Play()
-- BACKUP: maincf = maincf:Lerp(AnimData.MainCFrame * recoilcf * Sway:inverse(), 0.2)
			maincf = lerpCF_dt(maincf, AnimData.MainCFrame * Sway:inverse(), 14, step)
		end

		for index, Part in pairs(WeaponInHand:GetDescendants()) do
			if Part:IsA("BasePart") and Part.Name == "SightMark" then
				local dist_scale = Part.CFrame:pointToObjectSpace(cam.CFrame.Position)/Part.Size
				local reticle = Part.SurfaceGui.Border.Scope	
				reticle.Position=UDim2.new(.5+dist_scale.x,0,.5-dist_scale.y,0)	
			end
		end

		-- НОВАЯ СИСТЕМА ОТДАЧИ из ВНЕДРЕНИЕ
		-- Используем stateful spring-based recoil
		local dt = step -- Delta time из RenderStepped
		local newRecoilCF = gunRecoilState:Update(dt)
		-- Вариант А (самый резкий)
		recoilcf = newRecoilCF


		if WeaponData.CrossHair then
			if aimming then
				CHup = lerpUDim2_dt(CHup, UDim2.new(.5,0,.5,0), 14, step)
				CHdown = lerpUDim2_dt(CHdown, UDim2.new(.5,0,.5,0), 14, step)
				CHleft = lerpUDim2_dt(CHleft, UDim2.new(.5,0,.5,0), 14, step)
				CHright = lerpUDim2_dt(CHright, UDim2.new(.5,0,.5,0), 14, step)
			else
				local Normalized = ((WeaponData.CrosshairOffset + BSpread + (charspeed * WeaponData.WalkMult * ModTable.WalkMult) ) / 50)/10

				CHup = lerpUDim2_dt(CHup, UDim2.new(0.5, 0, 0.5 - Normalized,0), 35, step)
				CHdown = lerpUDim2_dt(CHdown, UDim2.new(.5, 0, 0.5 + Normalized,0), 35, step)
				CHleft = lerpUDim2_dt(CHleft, UDim2.new(.5 - Normalized, 0, 0.5, 0), 35, step)
				CHright = lerpUDim2_dt(CHright, UDim2.new(.5 + Normalized, 0, 0.5, 0), 35, step)
			end

			Crosshair.Position = UDim2.new(0,mouse.X,0,mouse.Y)

			Crosshair.Up.Position = CHup
			Crosshair.Down.Position = CHdown
			Crosshair.Left.Position = CHleft
			Crosshair.Right.Position = CHright

		else

			CHup = lerpUDim2_dt(CHup, UDim2.new(.5,0,.5,0), 14, step)
			CHdown = lerpUDim2_dt(CHdown, UDim2.new(.5,0,.5,0), 14, step)
			CHleft = lerpUDim2_dt(CHleft, UDim2.new(.5,0,.5,0), 14, step)
			CHright = lerpUDim2_dt(CHright, UDim2.new(.5,0,.5,0), 14, step)

			Crosshair.Position = UDim2.new(0,mouse.X,0,mouse.Y)

			Crosshair.Up.Position = CHup
			Crosshair.Down.Position = CHdown
			Crosshair.Left.Position = CHleft
			Crosshair.Right.Position = CHright

		end

		if BSpread then
			local currTime = time()
			if currTime - LastSpreadUpdate > (60/WeaponData.ShootRate) * 2 and not shooting and BSpread > WeaponData.MinSpread * ModTable.MinSpread then
				BSpread = math.max(WeaponData.MinSpread * ModTable.MinSpread, BSpread - WeaponData.AimInaccuracyDecrease * ModTable.AimInaccuracyDecrease)
			end
			if currTime - LastSpreadUpdate > (60/WeaponData.ShootRate) * 1.5 and not shooting and RecoilPower > WeaponData.MinRecoilPower * ModTable.MinRecoilPower then
				RecoilPower =  math.max(WeaponData.MinRecoilPower * ModTable.MinRecoilPower, RecoilPower - WeaponData.RecoilPowerStepAmount * ModTable.RecoilPowerStepAmount)
			end
		end

		if LaserActive and Pointer ~= nil then

			if NVG then
				Pointer.Transparency = 0
				Pointer.Beam.Enabled = true
			else
				if not gameRules.RealisticLaser then
					Pointer.Beam.Enabled = true
				else
					Pointer.Beam.Enabled = false
				end
				if IRmode then
					Pointer.Transparency = 1
				else
					Pointer.Transparency = 0
				end
			end

			for index, Key in pairs(WeaponInHand:GetDescendants()) do
				if Key:IsA("BasePart") and Key.Name == "LaserPoint" then
					local L_361_ = Ray.new(Key.CFrame.Position, Key.CFrame.LookVector * 1000)
					local Hit, Pos, Normal = workspace:FindPartOnRayWithIgnoreList(L_361_, Ignore_Model, false, true)

					if Hit then
						Pointer.CFrame =  CFrame.new(Pos, Pos + Normal)
					else
						Pointer.CFrame =  CFrame.new(cam.CFrame.Position + Key.CFrame.LookVector * 2000, Key.CFrame.LookVector)
					end

					if HalfStep and gameRules.ReplicatedLaser then
						Evt.SVLaser:FireServer(Pos,1,Pointer.Color,IRmode,WeaponTool)
					end
					break
				end
			end
		end
	end
end)
