-- FPS-independent Lerp functions (dt-based smoothing)
local function alphaFromSpeed(speed, dt)
	-- speed: "насколько быстро догоняем" (больше = резче)
	return 1 - math.exp(-speed * dt)
end

local function lerpCF_dt(current, target, speed, dt)
	return current:Lerp(target, alphaFromSpeed(speed, dt))
end

local function lerpUDim2_dt(current, target, speed, dt)
	return current:Lerp(target, alphaFromSpeed(speed, dt))
end
