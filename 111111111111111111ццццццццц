function Recoil()
	-- НОВАЯ СИСТЕМА ОТДАЧИ из ВНЕДРЕНИЕ
	-- Используем stateful spring-based recoil вместо math.random
	
	-- Получаем профиль отдачи для текущего оружия
	local name = WeaponData.RecoilProfile or "Rifle556"
	local profile = GetRecoilProfile(name) or GetRecoilProfile("Rifle556")
	print("[Recoil] Using:", name, "OK=", profile ~= nil, "inst=", profile and profile.instantKickRatio)
	if not profile then return end
	
	-- Устанавливаем профиль если изменился
	if gunRecoilState.currentProfile ~= profile then
		gunRecoilState:SetProfile(profile)
	end
	
	-- ADS multipliers для стабильного прицеливания
	local adsViewKickScale = (profile and profile.adsViewKickScale) or 0.35   -- насколько меньше VMKick в ADS
	local adsRecoilCFScale = (profile and profile.adsRecoilCFScale) or 0.45   -- насколько меньше RecoilSystem recoilcf в ADS
	local adsSwayScale     = (profile and profile.adsSwayScale) or 0.22       -- sway меньше в ADS
	local adsLagScale      = (profile and profile.adsLagScale) or 0.15        -- lag меньше в ADS
	local adsCamRecoilPower = (profile and profile.adsCamRecoilPower) or 0.18 -- маленькая отдача в камеру ТОЛЬКО ADS
	
	-- Вычисляем множитель силы отдачи
	local mult = 1.0
	
	-- ADS множитель
	if aimming then
		mult = mult * (profile.aimMultiplier or 0.3)
	end
	
	-- Crouch множитель
	if Crouched then
		mult = mult * (profile.crouchMultiplier or 0.65)
	end
	
	-- Bipod множитель (очень сильно снижает отдачу)
	if BipodActive then
		mult = mult * 0.3
	end
	
	-- Movement множитель
	if charspeed > 0.1 then
		mult = mult * (profile.moveMultiplier or 1.2)
	end
	
	-- Усиливаем ОТДАЧУ СТВОЛА/ВЬЮМОДЕЛИ примерно в 5.5 раза
	mult = mult * (RecoilPower or 1) * 5.5
	
	-- Hipfire only recoil scale (4-6x softer)
	local hipRecoilScale = (profile and profile.hipRecoilScale) or 0.20  -- 0.25 = ~4x softer, 0.17 = ~6x softer
	if not aimming then
		mult = mult * hipRecoilScale
	end
	
	-- Уменьшаем recoilcf (RecoilSystem) только в ADS
	if aimming then
		mult = mult * adsRecoilCFScale
	end
	
	-- КИКАЕМ новую систему отдачи
	gunRecoilState:Kick(profile, mult)
	
	-- Проверка: print hipfire scales
	if not aimming then
		print("[Recoil] hip scales:", hipRecoilScale, hipVMKickScale)
	end
	
	-- Камерная отдача ТОЛЬКО в ADS (делает прицеливание естественным)
	if aimming then
		local camRecoil = gunRecoilState:GetCameraRecoil()
		cameraspring:accelerate(Vector3.new(
			math.rad(camRecoil.Y) * adsCamRecoilPower,
			math.rad(camRecoil.X) * adsCamRecoilPower,
			0
		))
	end
	
	-- VMKick: viewmodel positional kick
	local kick = aimming and 0.55 or 1.0
	if BipodActive then kick = kick * 0.4 end
	
	local hipMult = (not aimming) and (WeaponData.HipRecoilMult or 1.15) or 1
	local adsMult = aimming and (WeaponData.ADSRecoilMult or 0.85) or 1
	kick = kick * hipMult * adsMult

	-- Hipfire only VMKick scale (4-6x softer)
	local hipVMKickScale = (profile and profile.hipVMKickScale) or 0.20
	if not aimming then
		kick = kick * hipVMKickScale
	end
	
	-- Уменьшаем viewmodel "удар" только в ADS (чтобы мушку не сносило)
	local viewKickScale = aimming and adsViewKickScale or 1
	local kickVM = kick * viewKickScale

	-- Усиливаем VMKick множителем vm = 0.75 (уменьшено в 2 раза от 1.5)
	local vm = 0.75
	
	-- Уменьшаем удар ствола в 2.9 раза (~на 66%)
	local hitScale = 0.345 -- weaker punch (~2.9x softer)
	
	-- Уменьшаем высоту подброса вверх в 1.2 раза
	local vertScale = 0.83 -- 1/1.2, ниже подброс вверх
	
	VMKickPos:accelerate(Vector3.new(
		0,
		1.15 * kickVM * vm * hitScale * vertScale,
		-1.55 * kickVM * vm * hitScale
	))
	
	VMKickRot:accelerate(Vector3.new(
		math.rad(3.4) * kickVM * vm * hitScale * vertScale, -- pitch меньше
		math.rad(RAND(-2.2, 2.2, 0.5)) * kickVM * vm * hitScale, -- yaw не трогаем
		math.rad(RAND(-1.5, 2.2, 0.5)) * kickVM * vm * hitScale  -- roll не трогаем
	))
end

