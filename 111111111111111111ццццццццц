-- Один воркер для свапа — никогда не создаётся больше одного task.spawn
local function RequestEquip(tool)
	PendingTool = tool
	EquipToken += 1
	-- print("RequestEquip", tool.Name)

	if SwitchWorkerRunning then
		return  -- воркер уже крутится, он возьмёт свежий PendingTool
	end
	SwitchWorkerRunning = true

	task.spawn(function()
		while PendingTool do
			local t = PendingTool
			PendingTool = nil

			if ToolEquip then
				unset()
			end

			if t and t.Parent == char then
				setup(t)
			end
		end
		SwitchWorkerRunning = false
	end)
end
