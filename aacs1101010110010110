function RequestEquip(tool)
	PendingTool = tool
	EquipToken += 1
	if SwitchWorkerRunning then return end
	SwitchWorkerRunning = true
	task.spawn(function()
		while PendingTool do
			local t = PendingTool
			PendingTool = nil
			if ToolEquip then
				unset()
			end
			if t and t.Parent == char then
				setup(t)
			end
		end
		SwitchWorkerRunning = false
	end)
end

