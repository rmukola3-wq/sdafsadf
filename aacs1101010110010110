		if not CheckingMag and not reloading and WeaponData and WeaponData.Type ~= "Grenade" and (GunStance == 0 or GunStance == 2 or GunStance == 3) then
			GunStance = 0
			Evt.GunStance:FireServer(GunStance, AnimData)
			IdleAnim()
		end
	end
	if Stances == 0 then
		Stand()
	elseif Stances == 1 then
		Crouch()
	end
end)

