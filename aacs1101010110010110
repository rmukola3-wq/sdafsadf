function unset()
	UnsetVersion += 1
	local myUnset = UnsetVersion

	if ToolEquip and IsBusy() then
		local waited = 0
		while IsBusy() and waited < 3 do
			if UnsetVersion ~= myUnset then return end
			task.wait(0.05)
			waited += 0.05
		end
	end

	if UnsetVersion ~= myUnset then return end

	ToolEquip = false
	Evt.Equip:FireServer(WeaponTool, 2)
	CAS:UnbindAction("Fire")
	CAS:UnbindAction("ADS")
	CAS:UnbindAction("Reload")
	CAS:UnbindAction("CycleLaser")
	CAS:UnbindAction("CycleLight")
