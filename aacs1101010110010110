function Recoil()
	local name = WeaponData.RecoilProfile or "Rifle556"
	local profile = GetRecoilProfile(name) or GetRecoilProfile("Rifle556")
	if not profile then return end

	if gunRecoilState.currentProfile ~= profile then
		gunRecoilState:SetProfile(profile)
	end

	local adsViewKickScale  = (profile and profile.adsViewKickScale) or 0.35
	local adsRecoilCFScale  = (profile and profile.adsRecoilCFScale) or 0.45
	adsSwayScale            = (profile and profile.adsSwayScale) or VM_Config.adsMotionScale
	local adsCamRecoilPower = (profile and profile.adsCamRecoilPower) or 0.18

	local mult = 1.0
	if aimming then
		mult = mult * (profile.aimMultiplier or 0.3)
	end
	if Crouched then
		mult = mult * (profile.crouchMultiplier or 0.65)
	end
	if BipodActive then
		mult = mult * 0.3
	end
	if charspeed > 0.1 then
		mult = mult * (profile.moveMultiplier or 1.2)
	end

	mult = mult * (RecoilPower or 1) * 2.35

	local hipRecoilScale = (profile and profile.hipRecoilScale) or 0.20
	if not aimming then
		mult = mult * hipRecoilScale
	end
	if aimming then
		mult = mult * adsRecoilCFScale
	end

	gunRecoilState:Kick(profile, mult)

	local camRecoil = gunRecoilState:GetCameraRecoil()
	local camPower = aimming and (profile.adsCamRecoilPower or 0.34) or (profile.hipCamRecoilPower or 0.16)

	cameraspring:accelerate(Vector3.new(
		math.rad(camRecoil.Y) * camPower,
		math.rad(camRecoil.X) * camPower,
		math.rad(camRecoil.X * 0.04) * camPower
		))

	local kick = aimming and 0.55 or 1.0
	if BipodActive then kick = kick * 0.4 end

	local hipMult = (not aimming) and (WeaponData.HipRecoilMult or 1.15) or 1
	local adsMult = aimming and (WeaponData.ADSRecoilMult or 0.85) or 1
	kick = kick * hipMult * adsMult

	local hipVMKickScale = (profile and profile.hipVMKickScale) or 0.20
	if not aimming then
		kick = kick * hipVMKickScale
	end

	local viewKickScale = aimming and adsViewKickScale or (profile.hipViewKickScale or 0.75)
	local kickVM = kick * viewKickScale
	local vm = 0.52
	local hitScale = 0.24
	local vertScale = 0.90

	VMKickPos:accelerate(Vector3.new(
		0,
		0.70 * kickVM * vm * hitScale * vertScale,
		-0.95 * kickVM * vm * hitScale
		))

	VMKickRot:accelerate(Vector3.new(
		math.rad(1.9) * kickVM * vm * hitScale * vertScale,
		math.rad(RAND(-1.2, 1.2, 0.5)) * kickVM * vm * hitScale,
		math.rad(RAND(-0.8, 1.1, 0.5)) * kickVM * vm * hitScale
		))

	-- secondary bobble kick on shot (передняя часть оружия "дёргается")
	SecondarySpring:accelerate(Vector3.new(
		math.rad(RAND(-1.2, 1.2, 0.5)) * kick * vm * hitScale,
		math.rad(RAND(-0.8, 0.8, 0.5)) * kick * vm * hitScale,
		0
		))
end

