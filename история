local function BuildImportedViewmodel()
	local source = ArmModel:FindFirstChild("WeaponRig_Default")
	if not source then
		warn("[ACS] WeaponRig_Default not found in ReplicatedStorage.ACS_Engine.ArmModel")
		return nil
	end

	local vm = source:Clone()
	vm.Name = "Viewmodel"

	local animBase = vm:WaitForChild("AnimBase")
	local fakeCameraPart = vm:WaitForChild("FakeCamera")
	local leftArm = vm:WaitForChild("Left Arm")
	local rightArm = vm:WaitForChild("Right Arm")

	-- если в импортном риге остался старый BaseWeld из чужой системы
	local oldBaseWeld = vm:FindFirstChild("BaseWeld", true)
	if oldBaseWeld then
		oldBaseWeld:Destroy()
	end

	animBase.Transparency = 1
	animBase.CanCollide = false
	animBase.CanTouch = false
	animBase.CanQuery = false
	animBase.Anchored = true
	animBase.CastShadow = false

	fakeCameraPart.Transparency = 1
	fakeCameraPart.CanCollide = false
	fakeCameraPart.CanTouch = false
	fakeCameraPart.CanQuery = false
	fakeCameraPart.Anchored = false
	fakeCameraPart.CastShadow = false

	leftArm.Anchored = false
	leftArm.CanCollide = false
	leftArm.CanTouch = false
	leftArm.CanQuery = false

	rightArm.Anchored = false
	rightArm.CanCollide = false
	rightArm.CanTouch = false
	rightArm.CanQuery = false

	local fakeCameraJoint = animBase:FindFirstChild("FakeCamera")
	if not (fakeCameraJoint and fakeCameraJoint:IsA("Motor6D")) then
		fakeCameraJoint = Instance.new("Motor6D")
		fakeCameraJoint.Name = "FakeCamera"
		fakeCameraJoint.Parent = animBase
	end
	fakeCameraJoint.Part0 = animBase
	fakeCameraJoint.Part1 = fakeCameraPart
	fakeCameraJoint.C0 = CFrame.new()
	fakeCameraJoint.C1 = CFrame.new()

	local leftJoint = animBase:FindFirstChild("LeftJoint")
	if not (leftJoint and leftJoint:IsA("Motor6D")) then
		leftJoint = Instance.new("Motor6D")
		leftJoint.Name = "LeftJoint"
		leftJoint.Parent = animBase
	end
	leftJoint.Part0 = animBase
	leftJoint.Part1 = leftArm

	local rightJoint = animBase:FindFirstChild("RightJoint")
	if not (rightJoint and rightJoint:IsA("Motor6D")) then
		rightJoint = Instance.new("Motor6D")
		rightJoint.Name = "RightJoint"
		rightJoint.Parent = animBase
	end
	rightJoint.Part0 = animBase
	rightJoint.Part1 = rightArm

	vm.PrimaryPart = animBase

	return vm, animBase, leftArm, rightArm, leftJoint, rightJoint
end



