local KeyframeSequenceProvider = game:GetService("KeyframeSequenceProvider")
local RS = game:GetService("ReplicatedStorage")

-- 1) ПАПКА С ТВОИМИ АНИМКАМИ (ИЗМЕНИ ПУТЬ!)
local AnimFolder = RS:WaitForChild("YourAnimFolderHere")

-- 2) ТЕСТОВЫЕ РИГИ (должны быть в Workspace)
local TestR6 = workspace:WaitForChild("TestR6")
local TestR15 = workspace:WaitForChild("TestR15")
local TestArms = workspace:WaitForChild("TestArms") -- клонированный ACS_Arms

local function getAnimator(model)
	local hum = model:FindFirstChildOfClass("Humanoid") or model:FindFirstChildOfClass("AnimationController")
	if not hum then return nil end
	return hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
end

local function toAnimationInstance(obj, parent)
	-- поддержка Animation и KeyframeSequence
	if obj:IsA("Animation") then
		return obj
	end
	if obj:IsA("KeyframeSequence") then
		local a = Instance.new("Animation")
		a.Name = obj.Name
		a.AnimationId = KeyframeSequenceProvider:RegisterKeyframeSequence(obj)
		a.Parent = parent
		return a
	end
	return nil
end

local function snapshotParts(model)
	-- берём несколько “сигнальных” частей, которые обычно двигаются
	local names = {"Left Arm","Right Arm","Torso","UpperTorso","LowerTorso","LeftHand","RightHand","Head"}
	local parts = {}
	for _,n in ipairs(names) do
		local p = model:FindFirstChild(n, true)
		if p and p:IsA("BasePart") then
			parts[#parts+1] = p
		end
	end
	local snap = {}
	for _,p in ipairs(parts) do
		snap[p] = p.CFrame
	end
	return snap
end

local function movedEnough(before, model, posEps)
	posEps = posEps or 0.03 -- порог
	local maxDist = 0
	for part, cf0 in pairs(before) do
		if part and part.Parent then
			local dist = (part.Position - cf0.Position).Magnitude
			if dist > maxDist then maxDist = dist end
		end
	end
	return maxDist >= posEps, maxDist
end

local function testOn(model, animObj)
	local animator = getAnimator(model)
	if not animator then
		return false, "no animator"
	end

	local anim = toAnimationInstance(animObj, model)
	if not anim then
		return false, "not Animation/KeyframeSequence"
	end

	local ok, track = pcall(function()
		return animator:LoadAnimation(anim)
	end)
	if not ok then
		return false, "LoadAnimation failed: " .. tostring(track)
	end

	local before = snapshotParts(model)
	track:Play(0.05)

	task.wait(0.35)

	local moved, amount = movedEnough(before, model)
	track:Stop(0.05)

	return moved, ("moved=%.3f"):format(amount)
end

for _,obj in ipairs(AnimFolder:GetChildren()) do
	print("=== Testing:", obj.Name, obj.ClassName)

	local r6ok, r6info = testOn(TestR6, obj)
	local r15ok, r15info = testOn(TestR15, obj)
	local armsOk, armsInfo = testOn(TestArms, obj)

	print(("R6:  %s (%s)"):format(tostring(r6ok), r6info))
	print(("R15: %s (%s)"):format(tostring(r15ok), r15info))
	print(("Arms:%s (%s)"):format(tostring(armsOk), armsInfo))
end


