EquipAnim

Вот так лучше:

self.EquipAnim = function(objs)
	local viewmodel = objs[5]
	if not viewmodel then return end

	local humanoid = viewmodel:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)

	-- останавливаем текущие треки
	for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
		track:Stop(0.05)
	end

	local equipAnim = script:FindFirstChild("Equip")
	if equipAnim and equipAnim:IsA("Animation") then
		local track = animator:LoadAnimation(equipAnim)
		track.Priority = Enum.AnimationPriority.Action
		track.Looped = false
		track:Play(0.05)

		track.Ended:Connect(function()
			track:Destroy()
		end)
	end
end



ReloadAnim

Тут у тебя идея правильная, но marker-сигналы лучше вешать до :Play():

self.ReloadAnim = function(objs)
	local viewmodel = objs[5]
	if not viewmodel then return end

	local humanoid = viewmodel:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)

	local reloadAnim = script:FindFirstChild("Reload")
	if reloadAnim and reloadAnim:IsA("Animation") then
		local track = animator:LoadAnimation(reloadAnim)
		track.Priority = Enum.AnimationPriority.Action
		track.Looped = false

		track:GetMarkerReachedSignal("MagOut"):Connect(function()
			if objs[4] and objs[4]:FindFirstChild("Handle") and objs[4].Handle:FindFirstChild("MagOut") then
				objs[4].Handle.MagOut:Play()
			end
		end)

		track:GetMarkerReachedSignal("MagIn"):Connect(function()
			if objs[4] and objs[4]:FindFirstChild("Handle") and objs[4].Handle:FindFirstChild("MagIn") then
				objs[4].Handle.MagIn:Play()
			end
		end)

		track:Play(0.05)
		track.Ended:Wait()
		track:Destroy()
	end
end



