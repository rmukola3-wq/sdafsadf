local Sequencer = game:GetService("KeyframeSequenceProvider")

local M = {}
M._tracks = nil
M._animator = nil

local function toAnimation(animObj, parent)
	if animObj:IsA("Animation") then return animObj end
	if animObj:IsA("KeyframeSequence") then
		local a = Instance.new("Animation")
		a.Name = animObj.Name
		a.AnimationId = Sequencer:RegisterKeyframeSequence(animObj)
		a.Parent = parent
		return a
	end
	return nil
end

function M.Setup(viewModel, weaponModel)
	local hum = viewModel:FindFirstChildOfClass("Humanoid")
		or viewModel:FindFirstChildOfClass("AnimationController")
	if not hum then error("No Humanoid/AnimationController in ViewModel") end

	local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
	M._animator = animator
	M._tracks = {}

	local folder = weaponModel:WaitForChild("ViewportAnimations")
	for _,obj in ipairs(folder:GetChildren()) do
		local anim = toAnimation(obj, folder)
		if anim then
			local tr = animator:LoadAnimation(anim)
			M._tracks[obj.Name] = tr
		end
	end
end

function M.Play(name, fade)
	local tr = M._tracks and M._tracks[name]
	if tr then tr:Play(fade or 0.1) end
end

function M.StopAll(fade)
	if not M._tracks then return end
	for _,tr in pairs(M._tracks) do
		tr:Stop(fade or 0.1)
	end
end

function M.Cleanup()
	M.StopAll(0)
	M._tracks = nil
	M._animator = nil
end

return M


