    local tr = ViewportTracks and ViewportTracks[name]
    if tr then tr:Play(0.1) end
end

function EquipAnim()
    PlayVM("Equip")
end
function IdleAnim()
    local tr = ViewportTracks and ViewportTracks["Idle"]
    if tr then tr.Looped = true; tr:Play(0.1) end
end
function ReloadAnim()
    PlayVM("Reload")
end



