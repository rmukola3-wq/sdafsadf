			0
		)

		local lp = LagSpring.p
		local lagPosX = math.clamp(-mouseDelta.X * posK * inputBoost, -0.07, 0.07)
		local lagPosY = math.clamp(-mouseDelta.Y * posK * inputBoost, -0.055, 0.055)

		local posScale = ms
