    or ViewModel:FindFirstChildOfClass("AnimationController")
local animator = hum and (hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum))

local tracks = {}
local animFolder = WeaponInHand:FindFirstChild("ViewportAnimations") -- или ViewModel:WaitForChild("Animations")
if animator and animFolder then
    for _, anim in ipairs(animFolder:GetChildren()) do
        if anim:IsA("Animation") then
            local tr = animator:LoadAnimation(anim)
            tracks[anim.Name] = tr
        end
    end
end

-- сохрани tracks куда-то глобально (например Obama/ViewportAnims)
ViewportTracks = tracks


И дальше:

