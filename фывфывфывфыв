function CycleSilencer()
	StopShooting()
	BUTTONHELD = false
	if WeaponInHand and WeaponInHand:findFirstChild("Handle") then
		for _, v in WeaponInHand.Handle.Muzzle:GetChildren() do
			if v:IsA("Sound") and v.IsPlaying then 
				v:Stop()
			end
		end
	end
	if not (WeaponInHand and (WeaponInHand:FindFirstChild("Silencer") or WeaponInHand:FindFirstChild("Suppressor") or WeaponInHand:FindFirstChild("Supressor"))) then return end;		
	if Suppressor and SuppressorAct then
		if _G.ThirdPerson then
			for _,part in WeaponInHand:GetChildren() do
