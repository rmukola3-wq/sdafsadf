local freelooking = false
local resetfree = false
local freelookorigin = nil

local maxAngle = math.rad(60) -- 60 degrees in radians (120 degrees total range)
local lerpSpeed = 0.1 -- Adjust this value to change the lerp speed
local initialCharacterCF = nil
function renderCam()
	if Humanoid and Humanoid.Health > 0 and not char:FindFirstChild('Plane') and not helmcamact then
		if not freelooking then
			if resetfree and freelookorigin then
				cam.CFrame = freelookorigin
				freelookorigin = nil
				resetfree = false
				initialCharacterCF = nil
			end
			cam.CFrame = cam.CFrame * CFrame.Angles(cameraspring.p.x * 2, cameraspring.p.y * 2, cameraspring.p.z + HeadAimingAngle.Value)
		else
			if initialCharacterCF == nil then
				initialCharacterCF = char.HumanoidRootPart.CFrame
				freelookorigin = cam.CFrame
			end

			local characterRotation = initialCharacterCF.Rotation
			local cameraRotation = cam.CFrame.Rotation

			local relativeRotation = characterRotation:ToObjectSpace(cameraRotation)
			local _, yAngle, _ = relativeRotation:ToEulerAnglesYXZ()

			local clampedYAngle = math.clamp(yAngle, -maxAngle, maxAngle)

			local targetRotation = characterRotation * CFrame.Angles(0, clampedYAngle, 0)

			local newRotation = cameraRotation:Lerp(targetRotation, lerpSpeed)

			cam.CFrame = CFrame.new(cam.CFrame.Position) * newRotation
		end
	end
end

