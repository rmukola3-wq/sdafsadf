function Shoot()
	--print("shoot", _G.ThirdPerson)
	if WeaponData and WeaponData.Type == "Gun" and Ammo > 0 and not shooting and not _G.reloading then
		if Ammo <= 0 or WeaponData.Jammed then
			return
		end
		if _G.reloading or runKeyDown or _G.SafeMode or CheckingMag then
			_G.mouse1down = false
			return
		end

		_G.mouse1down = true

		delay(0, function()

			if WeaponData and WeaponData.ShootType == 1 then 
				shooting = true	
				Network:FireServer("Atirar",{WeaponTool,SuppressorAct,FlashHider,_G.ThirdPerson,randomizer,_G.aiming,TPaiming,Ammo,inside,WeaponData.ShootType,shelljecttable})
				for _ =  1, WeaponData.Bullets do
					Thread:Spawn(CreateBullet)
				end
				Ammo -= 1
				GunFx(false)
				JamChance()
				UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
				Thread:Spawn(advrecoil)
				wait(60/WeaponData.ShootRate)
				shooting = false
				if WeaponInHand.Handle.Muzzle:FindFirstChild("Loops") then
					Network:FireServer("Loope",{3,WeaponTool.Name,inside})
					LoopGunshots(3)
				end

			elseif WeaponData and WeaponData.ShootType == 2 then
				for i = 1, WeaponData.BurstShot do
					if shooting or Ammo <= 0 or _G.mouse1down == false or WeaponData.Jammed then
						break
					end
					shooting = true	
					Network:FireServer("Atirar",{WeaponTool,SuppressorAct,FlashHider,_G.ThirdPerson,randomizer,_G.aiming,TPaiming,Ammo,inside,WeaponData.ShootType,shelljecttable})
					for _ =  1, WeaponData.Bullets do
						Thread:Spawn(CreateBullet)
					end
					Ammo -= 1
					GunFx(false)
					JamChance()
					UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
					Thread:Spawn(advrecoil)
					wait(60/WeaponData.ShootRate)
					shooting = false

				end
			elseif WeaponData and WeaponData.ShootType == 3 then
				while _G.mouse1down do

					if shooting or Ammo <= 0 or WeaponData.Jammed or not _G.AnimDebounce then
						LoopGunshots(3)
						Network:FireServer("Loope",{3,WeaponTool.Name,inside,WeaponData.CutoffTime})
						break
					end
					shooting = true	
					Network:FireServer("Atirar",{WeaponTool,SuppressorAct,FlashHider,_G.ThirdPerson,randomizer,_G.aiming,TPaiming,Ammo,inside,WeaponData.ShootType,shelljecttable})
					for _ =  1, WeaponData.Bullets do
						Thread:Spawn(CreateBullet)
					end
					Ammo -= 1
					GunFx(false)
					JamChance()
					UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
					Thread:Spawn(advrecoil)
					wait(60/WeaponData.ShootRate)
					shooting = false
				end
			elseif ((WeaponData and WeaponData.ShootType == 4) or (WeaponData and WeaponData.ShootType == 5)) and _G.racked then
				shooting = true
				_G.racked = false
				Network:FireServer("Atirar",{WeaponTool,SuppressorAct,FlashHider,_G.ThirdPerson,randomizer,_G.aiming,TPaiming,Ammo,inside,WeaponData.ShootType,shelljecttable})
				for _ =  1, WeaponData.Bullets do
					Thread:Spawn(CreateBullet)
				end
				Ammo -= 1
				GunFx(false)
				UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
				Thread:Spawn(advrecoil)
				WaitForCheck()
				if WeaponData.AutoChamber then
					if gameRules.RigType == Enum.HumanoidRigType.R15 then
						delay(WeaponData.TPAutoChamberDelay,function()
							for i,v in WeaponInHand:GetDescendants() do
								if v:IsA("BasePart") and v.Name == ("REG" or "REG2" or "ADS" or "ADS2") then
									v.Transparency = v.OrigTrans.Value
								end
							end

							CharAnims.KeyframeEvent("PlayAnims","Chamber",WeaponTool,true,false,"Idle",true,shelljecttable)

							for i,v in WeaponInHand:GetDescendants() do
								if v:IsA("BasePart") and v.Name == ("REG" or "REG2" or "ADS" or "ADS2") then
									v.Transparency = 1
								end
							end
						end)
					end
					if not _G.ThirdPerson and not WeaponData.Keyframebased then
						PumpAnim()
						if Ammo > 0 then
							_G.racked = true
						end
					elseif not _G.ThirdPerson and WeaponData.Keyframebased then
						delay(WeaponData.FPAutoChamberDelay,function()
							PumpAnim()
							if Ammo > 0 then
								_G.racked = true
							end
						end)
					end
				end
				RunCheck()
				shooting = false

			elseif WeaponData and WeaponData.ShootType == 7 then
				shooting = true	
				Network:FireServer("Atirar",{WeaponTool,SuppressorAct,FlashHider,_G.ThirdPerson,randomizer,_G.aiming,TPaiming,Ammo,inside,WeaponData.ShootType,shelljecttable})
				for _ =  1, WeaponData.Bullets do
					Thread:Spawn(CreateBullet)
				end
				Ammo -= 1
				GunFx(false)
				UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
				Thread:Spawn(advrecoil)
				wait(60/WeaponData.ShootRate)
				shooting = false

			elseif WeaponData and WeaponData.ShootType == 6 and GreAmmo > 0 and _G.GreReady then
				shooting = true	
				Network:FireServer("Atirar",{WeaponTool,SuppressorAct,FlashHider,_G.ThirdPerson,3,_G.aiming,TPaiming,Ammo,inside,WeaponData.ShootType,shelljecttable})
				Thread:Spawn(advrecoil)
				GreAmmo = GreAmmo - 1
				_G.GreReady = false
				GunFx(WeaponData.RPG)
				Launcher()
				UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
				shooting = false	
			end
		end)
	end
end

local L_150_ = {}

local LeanSpring = {}
LeanSpring.cornerPeek = SpringMod.new(0)
LeanSpring.cornerPeek.d = 1
LeanSpring.cornerPeek.s = 20
LeanSpring.peekFactor = math.rad(-15)
LeanSpring.dirPeek = 0

function L_150_.Update()
	HeadBase.CFrame = cam.CFrame * CFrame.new(0,0,-.5)
	LeanSpring.cornerPeek.t = LeanSpring.peekFactor * Virar
	local NewLeanCF = CFrame.fromAxisAngle(Vector3.new(0, 0, 1), LeanSpring.cornerPeek.p)
	cam.CFrame = cam.CFrame * NewLeanCF
end

game:GetService("RunService"):BindToRenderStep("Camera Update", 200, L_150_.Update)

function RunCheck()
	if not _G.ThirdPerson then
		if runKeyDown then
			StopShooting()
			_G.GunStance = 3
			if gameRules.RigType == Enum.HumanoidRigType.R15 then
				CharAnims.KeyframeEvent("PlayAnims","Sprint",WeaponTool,false,true,nil,false)
			else
				Network:FireServer("GunStance", {_G.GunStance,AnimData})
			end
			if _G.reloading == false then
				SprintAnim()
			end
		else
			if _G.aiming then
				_G.GunStance = 2
				AimAnim()
				--Network:FireServer("GunStance",{_G.GunStance,AnimData,"Aim",WeaponTool})
			else
				_G.GunStance = 0
				if gameRules.RigType == Enum.HumanoidRigType.R15 then
					CharAnims.KeyframeEvent("PlayAnims","Idle",WeaponTool,false,true,nil,false)
				else
					Network:FireServer("GunStance", {_G.GunStance,AnimData})
				end
			end
			IdleAnim()
		end	
	end
end

function Stand()
	Network:FireServer("Stance",{Stances,Virar})

	if Virar == 0 then
		Tween(tiltaxis,.6,{CFrame = CFrame.new(0,0,0)*CFrame.Angles(0,0,0)})
	end

	SE_GUI.MainFrame.Poses.Levantado.Visible = true
	SE_GUI.MainFrame.Poses.Agaixado.Visible = false
	SE_GUI.MainFrame.Poses.Deitado.Visible = false

	if Steady then
		char.Humanoid.JumpPower = gameRules.JumpPower
	else
		if gameRules.UseMomentum then
			TS:Create(Humanoid, TweenInfo.new(gameRules.WalkSpeedTransitionTime), {WalkSpeed = gameRules.NormalWalkSpeed - (gameRules.NormalWalkSpeed*Weight.Value)}):Play()
		else
			Humanoid.WalkSpeed = gameRules.NormalWalkSpeed - (gameRules.NormalWalkSpeed*Weight.Value)
		end
		char.Humanoid.JumpPower = gameRules.JumpPower
	end
end
