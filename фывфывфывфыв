				Network:FireServer("LauncherHit",{Pos, Hit, Norm, Mat, WeaponData})
				HitMod.CreateEffect(plr, Pos, Hit, Norm, Mat, "Explosion", WeaponData.BulletType)
				M203:remove()

				local Hitmark = Instance.new("Attachment")
				Hitmark.CFrame = CFrame.new(Pos, Pos + Norm)
				Hitmark.Parent = workspace.Terrain
				Debris:AddItem(Hitmark, 5)

				local Exp = Instance.new("Explosion")
				Exp.BlastPressure = 0
				Exp.BlastRadius = WeaponData.LauncherRadius
				Exp.DestroyJointRadiusPercent = 0
				Exp.Position = Hitmark.Position
				Exp.Parent = Hitmark
				Exp.Visible = false

				Exp.Hit:connect(function(hitPart, partDistance)

					local FoundHuman,VitimaHuman = CheckForHumanoid(hitPart)
					if FoundHuman == true and VitimaHuman.Health > 0 then
						local distance_factor = partDistance / Exp.BlastRadius
						distance_factor = 1 - distance_factor
						if distance_factor > 0 then
							local SKP_02 = SKP_01.."-"..plr.UserId
							local TotalDistTraveled = (Hitmark.Position - L_257_).Magnitude
							Network:InvokeServer("Damage",{WeaponTool, VitimaHuman, TotalDistTraveled, 2, WeaponData, ModTable, nil, nil, SKP_02, true})
						end
					end
				end)

				break
			end
			L_257_ = L_258_;
		end
	end
end

