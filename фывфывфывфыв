function ADS(aiming)
	if WeaponData and WeaponInHand and not script.Parent:GetAttribute("aimcancel") then
		if _G.aiming then
			if _G.SafeMode then
				_G.SafeMode = false
				_G.DontAllowShooting = false
				_G.GunStance = 0
				IdleAnim()
				UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
			end

			if not _G.reloading then
				AimAnim()
