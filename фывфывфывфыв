function RAND(Min, Max, Accuracy)
	local Inverse = 1 / (Accuracy or 1)
	return (math.random(Min * Inverse, Max * Inverse) / Inverse)
end
function TweenThing(Thing,What,Value,Time)
	local Goal = {}
	local Info = TweenInfo.new(Time)
	Goal[What] = Value
	game:GetService("TweenService"):Create(Thing,Info,Goal):Play()
end
function AssignCFrame(p,c)
	if p then
		if p:IsA('BasePart') then
			if c then
				p.CFrame = c
			end
			return p.CFrame
		elseif p:IsA('Attachment') then
			if c then
				p.WorldCFrame = c
			end
			return p.WorldCFrame
		end
	end
end

