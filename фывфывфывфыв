function LoopGunshots(Mode)
	if Humanoid and Humanoid.Health > 0 and WeaponInHand and WeaponInHand.Handle.Muzzle:FindFirstChild("Loops") then
		spawn(function()
			local Loops = WeaponInHand.Handle.Muzzle.Loops
			local Folder = nil
			local Type = nil

			if inside then
				Folder = Loops.Indoor
				if Suppressor then
					Type = "Indoor_S"
				else
					Type = "Indoor"
				end
			else
				Folder = Loops.Outdoor
				if Suppressor then
					Type = "Outdoor_S"
				else
					Type = "Outdoor"
				end
			end

			if Mode == 3 then
				for _,v in WeaponInHand.Handle.Muzzle:GetChildren() do
					if v:IsA("Sound") and (v.Name == ("Outdoor") or v.Name ==("Outdoor_S") or v.Name ==("Indoor") or v.Name ==("Indoor_S")) then
						v:Stop()
						v:Destroy()
						for _,x in Folder:GetDescendants() do
							if x.Name == v.Name then
								if x.Parent:FindFirstChild(v.Name.."_Tail") then
									local CSound = x.Parent[v.Name.."_Tail"]:Clone()
									if WeaponInHand:FindFirstChild("Handle") and WeaponInHand.Handle:FindFirstChild("Muzzle") and not WeaponInHand.Handle.Muzzle:FindFirstChild(CSound.Name) then
										CSound.Looped = false
										CSound.Parent = WeaponInHand.Handle.Muzzle
										CSound:Play()
										game.Debris:AddItem(CSound,CSound.TimeLength)
									else
										WeaponInHand.Handle.Muzzle[CSound.Name]:Destroy()
										CSound.Looped = false
										CSound.Parent = WeaponInHand.Handle.Muzzle
										CSound:Play()
										game.Debris:AddItem(CSound,CSound.TimeLength)
									end
								end
							end
						end

					end
				end
			end

			if WeaponData.ShootType == 6 or WeaponData.ShootType == 7 then return end;
			for _,gunsound in Folder:GetDescendants() do
				if gunsound:IsA("Sound") and (gunsound.Parent.Name == "Close" or gunsound.Parent.Parent.Name == "Close") then
					if gunsound.Name == Type then
						if Mode == 1 then
							local CSound = gunsound:Clone()
							CSound.Looped = true
							CSound.PlaybackSpeed = (WeaponData.ShootRate/.85)/WeaponData.ShootRate
							CSound.Parent = WeaponInHand.Handle.Muzzle
							gunsound:SetAttribute("Playing",true)
							CSound:Play()

						elseif Mode == 2 then
							gunsound:SetAttribute("Playing",true)
							local sgunsound = gunsound:Clone()
							sgunsound.Looped = false
							sgunsound.PlaybackSpeed = (WeaponData.ShootRate/.85)/WeaponData.ShootRate
							sgunsound.Parent = WeaponInHand.Handle.Muzzle
							sgunsound:Play()

							delay(WeaponData.CutoffTime, function()
								sgunsound:Stop()
								sgunsound:Destroy()
								gunsound:SetAttribute("Playing",false)
								if gunsound.Parent:FindFirstChild(gunsound.Name.."_Tail") then
									local TailSound = gunsound.Parent[gunsound.Name.."_Tail"]:Clone()
									TailSound.Looped = false
									TailSound.Parent = WeaponInHand.Handle.Muzzle
									TailSound:Play()			
									game.Debris:AddItem(TailSound,TailSound.TimeLength)
								end
							end)
						end	
					end
				end
			end 	

		end)


	end
end

