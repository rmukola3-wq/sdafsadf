local ShotBlur,ShotBloom
function GunFx(RPG)
	if (WeaponInHand.Handle.Muzzle:FindFirstChild("Loops") and WeaponData.Cutoff) and (WeaponData.ShootType == 1 or WeaponData.ShootType == 2) then
		Network:FireServer("Loope",{2,WeaponTool.Name,inside,WeaponData.CutoffTime})
		LoopGunshots(2)
	elseif (WeaponInHand.Handle.Muzzle:FindFirstChild("Loops") and WeaponData.ShootType ~= 3) or (not WeaponInHand.Handle.Muzzle:FindFirstChild("Loops")) or WeaponData.ShootType == 6 or WeaponData.ShootType == 7 then
		if SuppressorAct then
			if gameRules.CloneGunSounds then
				local sound = WeaponInHand.Handle.Muzzle.Suppressor:Clone()
				if inside then
					sound.Volume = sound.Volume + (sound.Volume*.2)
				end
				sound.Parent = WeaponInHand.Handle.Muzzle
				sound:Play()
				Debris:AddItem(sound,sound.TimeLength)
			else
				WeaponInHand.Handle.Muzzle.Suppressor:Play()
			end
		else
			if gameRules.CloneGunSounds then
				local sound = WeaponInHand.Handle.Muzzle.Close:Clone()
				if inside then
					sound.Volume = sound.Volume + (sound.Volume*.3)
				end
				sound.Parent = WeaponInHand.Handle.Muzzle
				sound:Play()
				Debris:AddItem(sound,sound.TimeLength)
			else
				local sound = WeaponInHand.Handle.Muzzle.Close
				if inside then
					sound.Volume = sound.Volume + (sound.Volume*.3)
				end
				sound:Play()
			end

			if WeaponInHand.Handle.Muzzle:FindFirstChild("BulletCrack") then
				if gameRules.CloneGunSounds then
					local sound2 = WeaponInHand.Handle.Muzzle.BulletCrack:Clone()
					sound2.Parent = WeaponInHand.Handle.Muzzle
					sound2:Play()
					Debris:AddItem(sound2,sound2.TimeLength)
				else
					WeaponInHand.Handle.Muzzle.BulletCrack:Play()
				end
			end
		end
		for _,othersounds in WeaponInHand.Handle.Muzzle:GetChildren() do
			if othersounds:IsA('Sound') then
				if othersounds.Name == 'Medium' or othersounds.Name == 'Far' then
					othersounds:Play()
				end
			end
		end
	end

	if WeaponData.ShootingBloom and not ShotBloom then
		ShotBloom = Instance.new("BloomEffect",cam)
		ShotBloom.Size = WeaponData.BloomSize
		ShotBloom.Threshold = WeaponData.BloomThresh
		ShotBloom.Enabled = true
		ShotBloom.Name = "ShotBloom"
		cam.DescendantRemoving:Connect(function(Desc)
			if Desc.Name == "ShotBloom" then
				ShotBloom = nil
			end
		end)
		game.Debris:AddItem(ShotBloom,.02)
	end
	if WeaponData.ShootingBlur ~= nil and WeaponData.ShootingBlur > 0 and not ShotBlur then
		ShotBlur = Instance.new("BlurEffect",cam)
		ShotBlur.Size = WeaponData.ShootingBlur
		ShotBlur.Enabled = true
		ShotBlur.Name = "ShotBlur"
		cam.DescendantRemoving:Connect(function(Desc)
			if Desc.Name == "ShotBlur" then
				ShotBlur = nil
			end
		end)
		game.Debris:AddItem(ShotBlur,.04)
	end

	if FlashHider == true then
		for _,search in WeaponInHand.Handle.Muzzle:GetChildren() do
			if search:IsA("ParticleEmitter") and search.Name:sub(1, 7) == "Smoke" then
				search:Emit(10)
			end
		end
	else
		if randomizer == 3 or RPG then
			for _,search in WeaponInHand.Handle.Muzzle:GetChildren() do
				if search.Name:sub(1, 7) == "Smoke" or search.Name:sub(1, 7) == "FlashFX" then
					search.Enabled = true
					delay(1/15,function()
						search.Enabled = false
					end)
				end
			end
		end
	end

	if RPG then return end;

	LastSpreadUpdate = time()
	if BSpread then
		BSpread = math.min(WeaponData.MaxSpread * ModTable.MaxSpread, BSpread + WeaponData.AimInaccuracyStepAmount * ModTable.AimInaccuracyStepAmount)
		RecoilPower =  math.min(WeaponData.MaxRecoilPower * ModTable.MaxRecoilPower, RecoilPower + WeaponData.RecoilPowerStepAmount * ModTable.RecoilPowerStepAmount)
	end

	generateBullet = generateBullet + 1

	if Ammo > 0 and WeaponData.MoveSlide then
		TS:Create(WeaponInHand.Handle.Slide, TweenInfo.new(30/WeaponData.ShootRate,Enum.EasingStyle.Linear,Enum.EasingDirection.InOut,0,true,0), {C0 =  WeaponData.SlideEx:Inverse() }):Play()
	elseif Ammo <= 0 and WeaponData.MoveSlide and WeaponData.SlideLock then
		TS:Create(WeaponInHand.Handle.Slide, TweenInfo.new(30/WeaponData.ShootRate,Enum.EasingStyle.Linear,Enum.EasingDirection.InOut,0,false,0), {C0 =  WeaponData.SlideEx:Inverse() }):Play()
	end

	if WeaponData.ShootType ~= 4 and WeaponData.ShootType ~= 5 and not _G.ThirdPerson then
		ShellEjection:Eject(plr,WeaponInHand,ACS_Workspace,WeaponData.DropCasings,WeaponData.BulletType,Engine,CasingConfig,PastaFx,Ignore_Model)
	end

	for _,v in WeaponInHand.Handle.Chamber:GetChildren() do
		if v:IsA("ParticleEmitter") and v.Name ~= "Shell" then
			v:Emit(10)	
		end				
	end

end

