	if input.UserInputType == Enum.UserInputType.MouseMovement and _G.ThirdPerson and ToolEquip then
		xAngle = xAngle-input.Delta.x*0.4
		yAngle = math.clamp(yAngle-input.Delta.y*0.4,-80,80)
	end
end)

Run.Heartbeat:Connect(function(step)
	HeadMovement()
end)

local walkanimcf = CFrame.new()

local t = 0

----------//Render Functions\\----------

Run.RenderStepped:Connect(function(step)
	renderGunRecoil()
	renderCam()
	randomizer = math.random(1,3)

	if helmcamact and currentcam ~= nil then
		cam.CFrame = currentcam.CFrame
	end

	if Virar == -1 then
		LeanAmount = .57
	elseif Virar == 1 then
		LeanAmount = -.57
	elseif Virar == 0 then
		LeanAmount = 0
	end

	if not IsFirstPerson() and not Leaning.Value and not _G.aiming then
		_G.CameraX = 1.3
		_G.LeanCameraX = 1.3
		AimCameraOffset = 1.3
	elseif IsFirstPerson() and not Leaning.Value and not _G.aiming then
		_G.CameraX = 0
		_G.LeanCameraX = 0
		AimCameraOffset = 0
	end

	if gameRules.CameraSway then
		local camera = workspace.CurrentCamera
		local speed = Humanoid.WalkSpeed * WalkRate
		local isMoving = Humanoid.MoveDirection.Magnitude > 0

		local swaySpeed = 1.0

		if isMoving then
			t = t + step * speed * swaySpeed

			local SwayAmountSpeed = math.min(SwayAmount(speed), HPMax)
			local NewCF = CFrame.new(
				SwayAmountSpeed * HPosMult * math.sin(t),
				math.min(SwayAmount(speed), VPMax) * VPosMult * -math.cos(t * 2),
				0
			) * CFrame.Angles(
				math.min(SwayAmount(speed), VMax) * VAngMult / 100 * -math.cos(t * 2),
				math.min(SwayAmount(speed), HMax) * HAngMult / 100 * math.sin(t),
				math.min(SwayAmount(speed), TMax) * TAngMult / 100 * -math.sin(t)
			)
			walkanimcf = walkanimcf:Lerp(NewCF, math.clamp(step * SwayStep, 0, 0.1))
		else
			walkanimcf = CFrame.new()
		end

		camera.CFrame = camera.CFrame * walkanimcf
	end

	if gameRules.FOVs.adjustableFOV then
		if IsFirstPerson() and not (_G.aiming or TPaiming) and not _G.FOVDisconnect then
			TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.FirstPersonFOV}):Play()
		elseif not IsFirstPerson() and not (_G.aiming or TPaiming) and not _G.FOVDisconnect then
			TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.ThirdPersonFOV}):Play()
		end
	end

	if Stances ~= 0 then
		Humanoid.Jump = false
	end

	script.Parent.Stances.Jumping.Delay.Value = JumpDelay

	if not gameRules.UseMomentum then
		if _G.ThirdPerson or not IsFirstPerson() then
			if not _G.ThirdPerson then
				CamOffset = Vector3.new(_G.CameraX,CameraY,0)
			else
				CamOffset = Vector3.new(_G.CameraX,CameraY+TPYOffset,0)
			end
		else
			CamOffset = Vector3.new(_G.CameraX,CameraY,CameraZ)	
		end
	else
		if _G.ThirdPerson or not IsFirstPerson() then
			if not Leaning.Value then
				if not _G.ThirdPerson then
					CamOffset = Vector3.new(_G.CameraX,CameraY,CameraZ)
				else
					CamOffset = Vector3.new(_G.CameraX,CameraY+TPYOffset,CameraZ)
				end
			else
				if not _G.ThirdPerson then
					CamOffset = Vector3.new(_G.CameraX/2,CameraY,CameraZ)
				else
					CamOffset = Vector3.new(_G.CameraX/2,CameraY+TPYOffset,CameraZ)
				end
			end
		else
			CamOffset = Vector3.new(_G.CameraX,CameraY,CameraZ)
		end
	end

	if _G.ThirdPerson and Seated and ShiftLocked then
		shiftLock(false)
	end

	local function ToggleFreeLook(bool)
		Humanoid.AutoRotate = not bool
		HumanoidRootPart.Anchored = bool
		freelooking = bool
		if bool then
			freelookorigin = cam.CFrame
		else
			resetfree = true
		end
	end

	-- This part should be in your main loop or input handling function
	if ViewModel then
		if IsFirstPerson() then
			if User:IsKeyDown(Enum.KeyCode.LeftAlt) then
				if not _G.Sprinting then
					ToggleFreeLook(true)
				end
			else
				ToggleFreeLook(false)
			end
		else
			ToggleFreeLook(false)
		end
	end


	local rayOrigin = Head.Position
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {Head.Parent, workspace.CurrentCamera}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams)

	------------------------------------------------------------------------
	if helmetmodel and Humanoid.Health > 0 and not freelooking then
		if helmetmodel:IsA("Model") then	
			if helmetmodel.Parent ~= cam and IsFirstPerson() and not _G.ThirdPerson then
				helmetmodel.Parent = cam
			elseif helmetmodel.Parent == cam and not IsFirstPerson() then
				if LocalHelmetFldr then
					helmetmodel.Parent = LocalHelmetFldr
				else
					helmetmodel.PrimaryPart.CFrame = cam.CFrame * CFNew(0, -100, 100)
				end
			elseif  helmetmodel.Parent == cam and _G.ThirdPerson then
				if LocalHelmetFldr then
					helmetmodel.Parent = LocalHelmetFldr
				else
					helmetmodel.PrimaryPart.CFrame = cam.CFrame * CFNew(0, -100, 100)
				end
			end

			if not IsFirstPerson() and LocalHelmetFldr and helmetmodel.Parent ~= LocalHelmetFldr then
				helmetmodel.Parent = LocalHelmetFldr
			end

			if helmetmodel.Parent == cam then
				helmetmodel.PrimaryPart.CFrame = cam.CFrame * CFNew(0, 0, 0)
			end
		end
	elseif helmetmodel and Humanoid.Health <= 0 then
		if helmetmodel then helmetmodel:Destroy() end;
	end

	------------------------------------------------------------------------

	if gameRules.FPBodyParts == true and not _G.ThirdPerson and IsFirstPerson() then
		for _,part in char:GetChildren() do
			if not ToolEquip then
				if part:IsA("BasePart") and (part.Name == ("LowerTorso") or part.Name == ("RightUpperLeg") or part.Name == ("RightLowerLeg") or part.Name == ("RightFoot") or part.Name == ("LeftUpperLeg") or part.Name == ("LeftLowerLeg") or part.Name == ("LeftFoot") or part.Name == ("Torso") or part.Name == ("Right Arm") or part.Name == ("Left Arm") or part.Name == ("Right Leg") or part.Name == ("Left Leg")) then
					part.CastShadow = false
					part.LocalTransparencyModifier = part.Transparency
				end
			else
				if part:IsA("BasePart") and (part.Name == ("LowerTorso") or part.Name == ("RightUpperLeg") or part.Name == ("RightLowerLeg") or part.Name == ("RightFoot") or part.Name == ("LeftUpperLeg") or part.Name == ("LeftLowerLeg") or part.Name == ("LeftFoot") or part.Name == ("Torso") or part.Name == ("Right Leg") or part.Name == ("Left Leg")) then
					part.CastShadow = false
					part.LocalTransparencyModifier = part.Transparency
				end
				if part:IsA("BasePart") and (part.Name == ("RightUpperArm") or part.Name == ("RightLowerArm") or part.Name == ("RightHand") or part.Name == ("LeftUpperArm") or part.Name == ("LeftLowerArm") or part.Name == ("LeftHand") or part.Name == ("Right Arm") or part.Name == ("Left Arm")) then
					part.LocalTransparencyModifier = 1
				end
			end		
			if part:IsA("Model") then
				for _,modelparts in part:GetDescendants() do
					if modelparts:IsA("BasePart") then
						if ToolEquip and part:FindFirstChild("MakeVisible") then
							modelparts.CastShadow = false
							modelparts.LocalTransparencyModifier = modelparts.Transparency
						else
							modelparts.LocalTransparencyModifier = 1
						end
					end
				end
			end
		end
	end

	if gameRules.RigType == Enum.HumanoidRigType.R15 and not plr:GetAttribute("InLockerMenu") and not freelooking then
		local PreCompAngle = CFAng(0,0,0)
		if ToolEquip then
			if Stances == 0 and (s and not w and not a and not d) then
				PreCompAngle = CFAng(-.1,0,0)
			elseif Stances == 0 and (w and not a and not s and not d) then
				PreCompAngle = CFAng(-.1,0,0)
			elseif Stances == 0 and (d and not a and not s and not w) then
				PreCompAngle = CFAng(0,.5,0)
			elseif Stances == 0 and (a and not d and not s and not w) then
				PreCompAngle = CFAng(0,-.45,0)
			elseif Stances == 1 and (s and not w and not a and not d) or (w and not a and not s and not d) then
				PreCompAngle = CFAng(-.6,0,0)
			elseif Stances == 1 and (d and not a and not s and not w) then
				PreCompAngle = CFAng(-.225,.65,0)
			elseif Stances == 1 and (a and not d and not s and not w) then
				PreCompAngle = CFAng(-.225,-.6,0)
			elseif Stances == 2 and a and not d then
				PreCompAngle = CFAng(0,-.5,0)
			elseif Stances == 2 and d and not a then
				PreCompAngle = CFAng(0,.5,0)
			end
		else
			if Stances == 2 and a and not d then
				PreCompAngle = CFAng(0,-.5,0)
			elseif Stances == 2 and d and not a then
				PreCompAngle = CFAng(0,.5,0)
			end
		end

		if not debug then

			if Humanoid.Health > 0 and not Swimming and ((Humanoid.WalkSpeed > gameRules.ProneWalksSpeed) or (Humanoid.WalkSpeed <= gameRules.ProneWalksSpeed and Steady)) then
				local CameraDirection = HumanoidRootPart.CFrame:toObjectSpace(cam.CFrame).lookVector


				if Waist then
					if not ToolEquip then
						if gameRules.MoveTorsoWithHead then
							TS:Create(Waist, TweenInfo.new(gameRules.StanceSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, false, 0), {C0 = CFNew(0, TorsoYOffset, 0) * CFAng(Asin(CameraDirection.Y), -Asin(CameraDirection.X/1.5), LeanAmount)}):Play()
						else
							TS:Create(Waist, TweenInfo.new(gameRules.StanceSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, false, 0), {C0 = CFNew(0,0,0) * CFAng(0,0,LeanAmount)}):Play()
						end
					elseif ToolEquip and not MB3 then
						if _G.aiming or TPaiming then
							TS:Create(Waist, TweenInfo.new(gameRules.StanceSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, false, 0), {C0 = CFNew(0, TorsoYOffset, 0) * CFAng(Asin(CameraDirection.Y), -Asin(CameraDirection.X/1.5), LeanAmount) * CFAng(-.32,-.25,0) * PreCompAngle}):Play()
						else
							TS:Create(Waist, TweenInfo.new(gameRules.StanceSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, false, 0), {C0 = CFNew(0, TorsoYOffset, 0) * CFAng(Asin(CameraDirection.Y), -Asin(CameraDirection.X/1.5), LeanAmount) * CFAng(-.15,-.25,0) * PreCompAngle}):Play()
						end
					elseif ToolEquip and MB3 then
						if _G.aiming or TPaiming then
							TS:Create(Waist, TweenInfo.new(gameRules.StanceSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, false, 0), {C0 = CFNew(0, TorsoYOffset, 0) * CFAng(0, 0, LeanAmount) * CFAng(-.32,-.25,0)}):Play()
						else
							TS:Create(Waist, TweenInfo.new(gameRules.StanceSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, false, 0), {C0 = CFNew(0, TorsoYOffset, 0) * CFAng(0, 0, LeanAmount) * CFAng(-.15,-.25,0)}):Play()
						end
					end
					if gameRules.MoveTorsoWithHead then			
						Network:FireServer("MoveEvent",{Waist.C0})
					else
						if not ToolEquip then	
							Network:FireServer("MoveEvent",{CFNew(0,0,0) * CFAng(0,0,LeanAmount)})
						else				
							Network:FireServer("MoveEvent",{Waist.C0})
						end
					end
				end
			elseif Humanoid.Health > 0 and (Humanoid.WalkSpeed <= gameRules.ProneWalksSpeed and not Steady) and not Swimming then
				if not Leaning.Value then
					Network:FireServer("MoveEvent",{CFNew(0,0,0) * CFAng(0,0,0) * PreCompAngle})		
				end
			elseif Swimming then
				Network:FireServer("MoveEvent",{CFNew(0,0,0) * CFAng(0,0,0)})
			end	
		end

	end
	--if char and HumanoidRootPart and _G.ThirdPerson and ToolEquip then
	--	--If third person
	--end

	if Humanoid.WalkSpeed == gameRules.RunWalkSpeed then
		_G.sprinting = true
	else
		_G.sprinting = false
	end

	if IsFirstPerson() and not freelooking then
		if UpOrDown(cam.CFrame.LookVector) < -0.4 then
			CameraZ = -2
			TS:Create(char.Humanoid, TweenInfo.new(gameRules.StanceSpeed), {CameraOffset = CamOffset} ):Play()
		elseif UpOrDown(cam.CFrame.LookVector) >= -.4 and UpOrDown(cam.CFrame.LookVector) < .3 then
			CameraZ = -1.9
			TS:Create(char.Humanoid, TweenInfo.new(gameRules.StanceSpeed), {CameraOffset = CamOffset} ):Play()
		elseif UpOrDown(cam.CFrame.LookVector) >= .3 then
			CameraZ = -.9
			TS:Create(char.Humanoid, TweenInfo.new(gameRules.StanceSpeed), {CameraOffset = CamOffset} ):Play()
		end
	else
		CameraZ = 0
		TS:Create(char.Humanoid, TweenInfo.new(gameRules.StanceSpeed), {CameraOffset = CamOffset} ):Play()
	end

	local rayOrigin = Head.Position
	local rayDirection = Vector3.new(0, 90, 0)
	local soundChanges = game:GetService("SoundService")	
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {Head.Parent, workspace.CurrentCamera}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	local raycastResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams) 

	if raycastResult then
		local hitPart = raycastResult.Instance
		if hitPart:IsDescendantOf(workspace) and hitPart.Transparency == 0 then
			inside = true
			if not (soundChanges.AmbientReverb == gameRules.IndoorReverb) then
				soundChanges.AmbientReverb = gameRules.IndoorReverb
				if ToolEquip and WeaponInHand and Allow_Shooting and not _G.DontAllowShooting and WeaponData.ShootType ~= 2 and Ammo > 0 and not WeaponData.Jammed and _G.AnimDebounce == true then
					if _G.mouse1down and WeaponInHand.Handle.Muzzle:FindFirstChild("Loops") and shooting then
						LoopGunshots(3)
						Network:FireServer("Loope",{3,WeaponTool.Name,inside})
						LoopGunshots(1)
						Network:FireServer("Loope",{1,WeaponTool.Name,inside})
					end
				end
			end
		end
	else
		inside = false
		if not (soundChanges.AmbientReverb == gameRules.DefaultReverb) then
			soundChanges.AmbientReverb = gameRules.DefaultReverb
			if ToolEquip and WeaponInHand and Allow_Shooting and not _G.DontAllowShooting and WeaponData.ShootType ~= 2 and Ammo > 0 and not WeaponData.Jammed and _G.AnimDebounce == true then
				if _G.mouse1down and WeaponInHand.Handle.Muzzle:FindFirstChild("Loops") and shooting then
					LoopGunshots(3)
					Network:FireServer("Loope",{3,WeaponTool.Name,inside})
					LoopGunshots(1)
					Network:FireServer("Loope",{1,WeaponTool.Name,inside})
				end
			end
		end
	end

	if _G.ThirdPerson then
		if not ShiftLocked and ToolEquip then
			User.MouseBehavior = Enum.MouseBehavior.LockCenter
		end

		local SmoothingFactor = 1 -- Adjust this value between 0 and 1 (lower for smoother, higher for more responsive)
		local LastCrosshairPosition = Vector3.new()

		if ToolEquip and gameRules.ThirdPersonCrosshair then
			if CrosshairPart and CrosshairPart.Parent == workspace.Terrain then
				local Root = CrosshairPart:FindFirstChild('Root')
				local RootCFrame = AssignCFrame(Root)
				local StartCFrame2 = AssignCFrame(HeadRoot)
				local Ray1 = Ray.new(StartCFrame2.p,StartCFrame2.LookVector*700)

				local addtoignoreList = {CrosshairPart:FindFirstAncestorOfClass('Model') or CrosshairPart, plr.Character}
				if CrosshairPart:IsDescendantOf(workspace.CurrentCamera) then
					table.insert(addtoignoreList,workspace.CurrentCamera)
					table.insert(addtoignoreList,plr.Character)
				end

				local ag1,ag2

				local function CastWithIgnoreList()
					ag1,ag2 = workspace:FindPartOnRayWithIgnoreList(Ray1,addtoignoreList)
					if ag1 and ((ag1.Transparency*(ag1.LocalTransparencyModifier+1)) > .1) then
						table.insert(addtoignoreList,ag1)
						CastWithIgnoreList()
					end
				end
				CastWithIgnoreList()
				AssignCFrame(CrosshairPart,CFrame.new(ag2+(StartCFrame2.p-ag2).Unit*.05) * (RootCFrame-RootCFrame.p))
			end
		end

		if BSpread then
			local currTime = time()
			if currTime - LastSpreadUpdate > (60/WeaponData.ShootRate) * 2 and not shooting and BSpread > WeaponData.MinSpread * ModTable.MinSpread then
				BSpread = math.max(WeaponData.MinSpread * ModTable.MinSpread, BSpread - WeaponData.AimInaccuracyDecrease * ModTable.AimInaccuracyDecrease)
			end
			if currTime - LastSpreadUpdate > (60/WeaponData.ShootRate) * 1.5 and not shooting and RecoilPower > WeaponData.MinRecoilPower * ModTable.MinRecoilPower then
				RecoilPower =  math.max(WeaponData.MinRecoilPower * ModTable.MinRecoilPower, RecoilPower - WeaponData.RecoilPowerStepAmount * ModTable.RecoilPowerStepAmount)
			end
		end
	end

	if ViewModel and WeaponInHand and not freelooking then --Check if the viewmodel is loaded
		HeadBase.CFrame = cam.CFrame * CFNew(0, 0, -.5) * gunbobcf
		local currtick = tick()
		local tickdiff = currtick - OldTick
		local adjust = tickdiff * 60

		local Adj05 = math.min(1, 0.05 * adjust)
		local Adj15 = math.min(1, .15 * adjust)

		if EquipType == "Gun" and not _G.aiming then	
			local HitRayCast = Ray.new(HeadBase.Position, HeadBase.CFrame.LookVector*3)
			local Hit,HitPos,Norm,Mat = workspace:FindPartOnRayWithIgnoreList(HitRayCast,Ignore_Model)

			if Hit and _G.AnimDebounce then
				if Hit:IsA('BasePart') and Hit.Transparency ~= 1 and Hit.Name ~= "HitIgnore" then
					if Hit.Parent:GetAttribute("WallBang") then
						VM_Bump = true
						maincf = maincf:Lerp(CFrame.new(-.2,-1,0)*CFrame.Angles(1,.6,.3),.1)
					else
						VM_Bump = true
						maincf = maincf:Lerp(CFrame.new(-.2,-1,0)*CFrame.Angles(1,.6,.3),.1)
					end
				end
			elseif not Hit then
				VM_Bump = false
			end
		elseif EquipType == "Other" then
			local Hit, Pos = workspace:FindPartOnRayWithIgnoreList(Ray.new(Vector3.new(WeaponInHand.Handle.Position.X,WeaponInHand.Handle.Position.Y,WeaponInHand.Handle.Position.Z), WeaponInHand.Handle.CFrame.LookVector * 3), Ignore_Model)

			if Hit and _G.AnimDebounce then
				if Hit:IsA('BasePart') and Hit.Transparency ~= 1 and Hit.Name ~= "HitIgnore" then
					if Hit.Parent:GetAttribute("WallBang") then
						VM_Bump = true
						maincf = maincf:Lerp(CFrame.new(-.2,-1,0)*CFrame.Angles(1,.6,.3),.1)
					else
						VM_Bump = true
						maincf = maincf:Lerp(CFrame.new(-.2,-1,0)*CFrame.Angles(1,.6,.3),.1)
					end
				end
			elseif not Hit then
				VM_Bump = false
			end
		end

		if _G.reloading and (w or a or s or d) or VM_Bump then
			script.Parent:SetAttribute("aimcancel", true)
		else
			script.Parent:SetAttribute("aimcancel", false)
		end

		local currtick = tick()
		local tickdiff = currtick - OldTick
		local adjust = tickdiff * 60
		OldTick = currtick

		local mouseDelta = User:GetMouseDelta()
		SwaySpring:accelerate(Vector3.new((mouseDelta.x /24), (mouseDelta.y /24) , 0))

		local swayVec = SwaySpring.p
		local TSWAY = swayVec.z
		local XSSWY = swayVec.X
		local YSSWY = swayVec.Y
		local Sway = CFrame.Angles(YSSWY,XSSWY,XSSWY)
		local WalkT = Humanoid.WalkSpeed / 20

		if a then
			TVal = Lerp(0,(-.20*WalkT),math.min(1,.5*adjust))
		elseif d then
			TVal = Lerp(0,(.20*WalkT),math.min(1,.5*adjust))
		else
			TVal = Lerp(0,0,math.min(1,.5*adjust))
		end

		local swayVec2 = AnimationHandler.p
		local TSWAY2 = swayVec2.z
		local XSSWY2 = swayVec2.X
		local YSSWY2 = swayVec2.Y
		local AnimationSway = CFrame.Angles(YSSWY2,XSSWY2,TSWAY2)

		if running then
			WalkRate = WalkT
		else
			WalkRate = WalkT / 3
		end

		t = t + tickdiff*WalkRate

		if BipodAtt then

			local BipodRay
			if UnderBarrelAtt then
				BipodRay = Ray.new(UnderBarrelAtt.Main.Position, Vector3.new(0,-2,0))
			else
				BipodRay = Ray.new(WeaponInHand.BipodPoint.Position, Vector3.new(0,-2,0))
			end
			local BipodHit, BipodPos, BipodNorm = workspace:FindPartOnRayWithIgnoreList(BipodRay, Ignore_Model, false, true)

			if BipodHit then
				CanBipod = true
				if CanBipod and BipodActive and not runKeyDown then
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255,255,255), ImageTransparency = .123}):Play()
					if not _G.aiming then
						if UnderBarrelAtt then
							BipodCF = BipodCF:Lerp(CFrame.new(0,(((UnderBarrelAtt.Main.Position - BipodPos).magnitude)-1) * (-1.5), 0),.2)
						else
							BipodCF = BipodCF:Lerp(CFrame.new(0,(((WeaponInHand.BipodPoint.Position - BipodPos).magnitude)-1) * (-1.5), 0),.2)
						end
					else
						BipodCF = BipodCF:Lerp(CFrame.new(),.2)
					end				

				else
					BipodActive = false
					BipodCF = BipodCF:Lerp(CFrame.new(),.2)
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255,255,0), ImageTransparency = .5}):Play()
				end
			else
				BipodActive = false
				CanBipod = false
				BipodCF = BipodCF:Lerp(CFrame.new(),.2)
				TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255,0,0), ImageTransparency = .5}):Play()
			end
		end

		if not looking then
			AnimPart.CFrame = cam.CFrame * NearZ* BipodCF * maincf * gunbobcf * aimcf  * tiltaxis.CFrame * AnimationSway
		end

		if not AnimData.GunModelFixed then
			WeaponInHand:SetPrimaryPartCFrame(
				ViewModel.PrimaryPart.CFrame
					* guncf
			)
		end

		Spread.Adjust(step, (60/WeaponData.ShootRate), Allow_Shooting)

		if w and not s and not a and not d then
			MoveDirection2 = 0.1
			MoveDirection = 0
		elseif s and not w and not a and not d then
			MoveDirection2 = -.1
			MoveDirection = 0
		elseif w and s then
			MoveDirection = 0
		elseif w and d then
			MoveDirection = -2.5
			MoveDirection2 = .065
		elseif w and a then
			MoveDirection = 2.5
			MoveDirection2 = .065
		elseif s and d then
			MoveDirection = -2.5
			MoveDirection2 = -.065
		elseif s and a then
			MoveDirection = 2.5
			MoveDirection2 = -.065
		elseif a and not w and not d and not s then
			MoveDirection = 5
			MoveDirection2 = 0
		elseif d and not w and not a and not s then
			MoveDirection = -5
			MoveDirection2 = 0
		elseif not w and not a and not s and not d then MoveDirection = 0 MoveDirection2 = 0
		end

		if Humanoid.MoveDirection ~= V3(0,0,0) then
			if not _G.aiming then
				if not _G.sprinting then
					gunbobcf = gunbobcf:Lerp(CFrame.new(
						.015 * (charspeed/1) * math.sin(tick() * 10),
						-.008 * (charspeed/1) * math.sin(tick() * -20),
						0
						) * CFAng(
							RAD( 18 * (Humanoid.WalkSpeed/35) * SIN(tick() * 9) ), 
							RAD( -1.5 * (Humanoid.WalkSpeed/12) * COS(tick() * 9) ), 
							RAD(MoveDirection)
						), 0.05)
				else
					gunbobcf = gunbobcf:Lerp(CFrame.new(
						0.03 * math.sin(tick() * 12),
						0.08 * math.cos(tick() * 18),
						0 
						) * CFrame.Angles(
							math.rad(0), 
							math.rad(1 * (charspeed/8) * math.sin(tick() * 6)), 
							math.rad(1 * (charspeed/15) * math.sin(tick() * 4))
						), 0.15)
				end
			else
				gunbobcf = gunbobcf:Lerp(CFNew(
					0.005 * (charspeed/16) * SIN(tick() * 1.25),
					0.005 * (charspeed/16) *  COS(tick() * 2),
					MoveDirection2
					) * CFAng(
						RAD( 1 * (Humanoid.WalkSpeed/10) * SIN(tick() * 13) ), 
						RAD( 1 * (Humanoid.WalkSpeed/10) * COS(tick() * 7) ), 
						RAD(MoveDirection)
					), 0.08)
			end
		else
			if not _G.aiming then
				if not swayinterrupt then
					if ACS_Client.Variaveis.Stamina.Value <= (gameRules.MaxStamina/2.1) then
						gunbobcf = gunbobcf:Lerp(CFrame.new(
							0.05 * math.sin(tick() * 1.5),
							0.05 * math.cos(tick() * 3.5),
							0 
							), 0.1)
					else
						gunbobcf = gunbobcf:Lerp(CFNew(
							0.005 * SIN(tick() * 1.5),
							0.005 * COS(tick() * 2.5),
							0 
							), 0.1)
					end
				else
					gunbobcf = gunbobcf:Lerp(CFNew(
						0.005 * SIN(tick() * 6),
						0.005 * COS(tick() * 6),
						0 
						), 0.1)		
				end
			else
				if swayinterrupt then
					gunbobcf = gunbobcf:Lerp(CFNew(
						WeaponData.ADSsettings.ADSswaywobble * SIN(tick() * (WeaponData.ADSsettings.ADSXsway*2.5)),
						WeaponData.ADSsettings.ADSswaywobble * COS(tick() * 3),
						0 
						), .1)
				else
					if not aimfocus then
						gunbobcf = gunbobcf:Lerp(CFNew(
							WeaponData.ADSsettings.ADSswaywobble * SIN(tick() * WeaponData.ADSsettings.ADSXsway),
							WeaponData.ADSsettings.ADSswaywobble * COS(tick() * 2.5),
							0 
							), .1)
					else
						gunbobcf = gunbobcf:Lerp(CFNew(
							WeaponData.ADSsettings.ADSswaywobble * SIN(tick() * 1),
							WeaponData.ADSsettings.ADSswaywobble * COS(tick() * 1.5),
							0 
							), .1)
					end
				end
			end
		end

		if CurAimpart and _G.aiming and _G.AnimDebounce and not CheckingMag and not script.Parent:GetAttribute("aimcancel") then
			if not _G.NVG or WeaponInHand.AimPart:FindFirstChild("NVAim") == nil then
				if AimPartMode == 1 then
					if aimfocus then
						TS:Create(cam,AimTween,{FieldOfView = WeaponData.ADSsettings.ADSFocusFOV}):Play()
					else
						TS:Create(cam,AimTween,{FieldOfView = ModTable.ZoomValue}):Play()
					end
					if WeaponData.ADSsettings.LeanIntoAim then
						TS:Create(HeadAimingAngle, TweenInfo.new(.2,Enum.EasingStyle.Sine), {Value = -0.075}):Play()
					end
					if looking == false then
						maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 0.2)
					elseif looking == true then
						maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf  * CurAimpart.CFrame:toObjectSpace(CFrame.new(cam.CFrame.X ,cam.CFrame.Y,cam.CFrame.Z)), 0.2)
					end
				elseif AimPartMode == 2 then
					TS:Create(cam,AimTween,{FieldOfView = ModTable.Zoom2Value}):Play()
					if WeaponData.ADSsettings.LeanIntoAim then
						TS:Create(HeadAimingAngle, TweenInfo.new(.2,Enum.EasingStyle.Sine), {Value = 0}):Play()
					end
					if looking == false then
						maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 0.2)
					elseif looking == true then
						maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf  * CurAimpart.CFrame:toObjectSpace(CFrame.new(cam.CFrame.X ,cam.CFrame.Y,cam.CFrame.Z)), 0.2)
					end
				elseif AimPartMode == 3 then
					TS:Create(cam,AimTween,{FieldOfView = ModTable.Zoom3Value}):Play()
					if WeaponData.ADSsettings.LeanIntoAim then
						TS:Create(HeadAimingAngle, TweenInfo.new(.2,Enum.EasingStyle.Sine), {Value = 0}):Play()
					end
					if looking == false then
						maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 0.2)
					elseif looking == true then
						maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf  * CurAimpart.CFrame:toObjectSpace(CFrame.new(cam.CFrame.X ,cam.CFrame.Y,cam.CFrame.Z)), 0.2)
					end
				end
			else
				if gameRules.FOVs.adjustableFOV then
					if IsFirstPerson() then
						TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.FirstPersonFOV}):Play()
					else
						if plr.CameraMode ~= Enum.CameraMode.LockFirstPerson then
							TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.ThirdPersonFOV}):Play()
						end
					end
				else
					TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.ThirdPersonFOV}):Play()
				end
				if looking == false then
					maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * Sway:inverse() * (WeaponInHand.AimPart.CFrame * WeaponInHand.AimPart.NVAim.CFrame):toObjectSpace(cam.CFrame), 0.2)
				elseif looking == true then
					maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * recoilcf * (WeaponInHand.AimPart.CFrame * WeaponInHand.AimPart.NVAim.CFrame):toObjectSpace(CFrame.new(cam.CFrame.X ,cam.CFrame.Y,cam.CFrame.Z)), 0.2)
				end
			end

		else
			if gameRules.FOVs.adjustableFOV then
				if IsFirstPerson() then
					TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.FirstPersonFOV}):Play()
				else
					if plr.CameraMode ~= Enum.CameraMode.LockFirstPerson then
						TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.ThirdPersonFOV}):Play()
					end
				end
			else
				TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.ThirdPersonFOV}):Play()
			end
			if not VM_Bump then
				if looking == false then
					if not LeftHanded then
						maincf = maincf:Lerp(AnimData.MainCFrame * recoilcf * Sway, 0.07)  
					else
						maincf = maincf:Lerp((AnimData.MainCFrame*CFrame.new(-.575,0,0)) * recoilcf * Sway, 0.07)  
					end
				elseif looking == true then
					if not LeftHanded then
						maincf = maincf:Lerp(AnimData.MainCFrame * recoilcf, 0.07)
					else
						maincf = maincf:Lerp((AnimData.MainCFrame*CFrame.new(-.575,0,0)) * recoilcf, 0.07)
					end
				end
			end
		end

		for _, Part in WeaponInHand:GetDescendants() do
			if Part:IsA("BasePart") and Part.Name == "SightMark" then
				updateReticle(Part, cam)
			end
		end

		recoilcf = recoilcf:Lerp(CFrame.new() * CFrame.Angles( math.rad(RecoilSpring.p.X), math.rad(RecoilSpring.p.Y), math.rad(RecoilSpring.p.z)), 0.2)

		if BSpread then
			local currTime = time()
			if currTime - LastSpreadUpdate > (60/WeaponData.ShootRate) * 2 and not shooting and BSpread > WeaponData.MinSpread * ModTable.MinSpread then
				BSpread = math.max(WeaponData.MinSpread * ModTable.MinSpread, BSpread - WeaponData.AimInaccuracyDecrease * ModTable.AimInaccuracyDecrease)
			end
			if currTime - LastSpreadUpdate > (60/WeaponData.ShootRate) * 1.5 and not shooting and RecoilPower > WeaponData.MinRecoilPower * ModTable.MinRecoilPower then
				RecoilPower =  math.max(WeaponData.MinRecoilPower * ModTable.MinRecoilPower, RecoilPower - WeaponData.RecoilPowerStepAmount * ModTable.RecoilPowerStepAmount)
			end
		end

		local mouseLocation = game:GetService("UserInputService"):GetMouseLocation()

		if WeaponData.CrossHair then
			if _G.aiming then
				CHup = CHup:Lerp(UDim2.new(.5,0,.5,0),0.2)
				CHdown = CHdown:Lerp(UDim2.new(.5,0,.5,0),0.2)
				CHleft = CHleft:Lerp(UDim2.new(.5,0,.5,0),0.2)
				CHright = CHright:Lerp(UDim2.new(.5,0,.5,0),0.2)
			else
				if BSpread then
					local Normalized = ((WeaponData.CrosshairOffset + BSpread + (charspeed * WeaponData.WalkMult * ModTable.WalkMult) ) / 50)/10

					CHup = CHup:Lerp(UDim2.new(0.5, 0, 0.5 - Normalized,0),0.5)
					CHdown = CHdown:Lerp(UDim2.new(.5, 0, 0.5 + Normalized,0),0.5)
					CHleft = CHleft:Lerp(UDim2.new(.5 - Normalized, 0, 0.5, 0),0.5)
					CHright = CHright:Lerp(UDim2.new(.5 + Normalized, 0, 0.5, 0),0.5)
				end
			end

			Crosshair.Position = UDim2.fromOffset(mouseLocation.X,mouseLocation.Y)

			Crosshair.Up.Position = CHup
			Crosshair.Down.Position = CHdown
			Crosshair.Left.Position = CHleft
			Crosshair.Right.Position = CHright

		else

			CHup = CHup:Lerp(UDim2.new(.5,0,.5,0),0.2)
			CHdown = CHdown:Lerp(UDim2.new(.5,0,.5,0),0.2)
			CHleft = CHleft:Lerp(UDim2.new(.5,0,.5,0),0.2)
			CHright = CHright:Lerp(UDim2.new(.5,0,.5,0),0.2)

			Crosshair.Position = UDim2.fromOffset(mouseLocation.X,mouseLocation.Y)

			Crosshair.Up.Position = CHup
			Crosshair.Down.Position = CHdown
			Crosshair.Left.Position = CHleft
			Crosshair.Right.Position = CHright

		end
	elseif not ViewModel and WeaponInHand and _G.ThirdPerson then

		if HeadBase then
			HeadBase.CFrame = cam.CFrame * CFNew(0, 0, -.5)
		end

	end
end)

