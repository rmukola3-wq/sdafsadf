function AdjustSightMark()
	WeaponInHand.Handle.Click:Play()
	AnimationHandler:accelerate(Vector3.new( math.random(-3, 3)/5, -3/5,2))

	for _,v in WeaponInHand:GetChildren() do

		if v.Name == "SightMark" then
			if not SightBrightSw then
				v.SurfaceGui.LightInfluence = 1
			else
				v.SurfaceGui.LightInfluence = 0
			end
		end

	end

	SightBrightSw = not SightBrightSw
