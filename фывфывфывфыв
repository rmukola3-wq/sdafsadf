function TossGrenade()
	if WeaponTool and WeaponData and GRDebounce == true then
		local SKP_02 = SKP_01.."-"..plr.UserId
		local localmode = nil
		if gameRules.RigType ~= Enum.HumanoidRigType.R6 then
			if Power == 150 then --High Throw
				localmode = "HighThrow"
				CharAnims.KeyframeEvent("PlayAnims",localmode,WeaponTool,false,false,nil,false)
			elseif Power == 100 then --Mid Throw
				localmode = "MedThrow"
				CharAnims.KeyframeEvent("PlayAnims",localmode,WeaponTool,false,false,nil,false)
			elseif Power == 50 then --Low Throw
				localmode = "LowThrow"
				CharAnims.KeyframeEvent("PlayAnims",localmode,WeaponTool,false,false,nil,false)
			end
		end
		GrenadeThrow()
		if WeaponInHand.ServerAnims[localmode]:FindFirstChild("ThrowDelay") then
			wait(WeaponInHand.ServerAnims[localmode].ThrowDelay.Value)
		end
		if _G.ThirdPerson then
			shiftLock(false)
			CrosshairPart.Parent = Engine.Cache
			SE_GUI.GrenadeForce.Text = " "
			plr.PlayerGui.StatusUI.GrenadeForce.Visible = false
		end
		if WeaponTool and WeaponData then
			Network:FireServer("Equip",{WeaponTool,2,false,false})
			Network:FireServer("Grenade",{WeaponTool,WeaponData,cam.CFrame,cam.CFrame.LookVector,Power,SKP_02})
			unset(true,true,false,false,true)
