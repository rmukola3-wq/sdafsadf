User.InputBegan:Connect(function(key, gameProcessed)
	if gameProcessed then return end
	local func = onBegan[key.UserInputType.Name]
	if func then
		func(key.KeyCode.Name)
	end

	if (key.KeyCode == gameRules.TPSstancesKey) then
		if not stancesunlock then
			stancesunlock = true

			if _G.ThirdPerson then
				TweenThing(plr, 'CameraMaxZoomDistance', 5, .2)
				TweenThing(plr, 'CameraMinZoomDistance', 5, .2)
			end
		end
	end
	if (key.KeyCode == Enum.KeyCode.W) then
		if not w then
			w = true
		end
	end
	if (key.KeyCode == Enum.KeyCode.A) then
		if not a then
			a = true
			if _G.sprinting and not w then
				sprintcancel()
			end
		end
	end
	if (key.KeyCode == Enum.KeyCode.S) then
		if not s then
			s = true
			if _G.sprinting and not _G.ThirdPerson then
				sprintcancel()
			end
		end
	end
	if (key.KeyCode == Enum.KeyCode.D) then
		if not d then
			d = true
			if _G.sprinting and not w then
				sprintcancel()
			end
		end
	end
	if (key.KeyCode == gameRules.ThirdPersonFreelookKey) and _G.ThirdPerson and ToolEquip then
		if not MB3 then
			MB3 = true
			shiftLock(false)
			if not Seated then
				if gameRules.ThirdPersonCrosshair then
					CrosshairPart.Parent = Engine.Cache
				end
			end
		end
	end
	if (key.KeyCode == gameRules.Keybinds.AnimationWheelKeybind) and not _G.Yeet then
		if not AW_GUI then return end;
		if not AW_GUI.Enabled then
			AW_GUI.Enabled = true
			if not User.MouseIconEnabled then
				User.MouseIconEnabled = true
			end

			if not AW_Loaded then
				AW_Loaded = not AW_Loaded
				for _,Emote in AW_GUI.Emotes:GetChildren() do
					if Emote:IsA("TextButton") then
						Emote.Modal = true
						Emote.MouseButton1Click:Connect(function()
							AnimWheelBind(Emote.Name,Emote.LoopedAnim.Value)
						end)
					end
				end
			end
		end
	end
	if (key.KeyCode == Enum.KeyCode.Z) then
		if not (char:WaitForChild('Humanoid').Sit and char.Humanoid.SeatPart:IsA("VehicleSeat") or char:WaitForChild('Humanoid').Sit and char.Humanoid.SeatPart:IsA("Seat")) and not _G.sprinting then
			if not z and Stances == 0 then
				OrigWalkSpeed = Humanoid.WalkSpeed
				MaxSpeedRange = {OrigWalkSpeed-4,OrigWalkSpeed+4}
				if _G.ThirdPerson or not IsFirstPerson() then
					TweenThing(plr, 'CameraMaxZoomDistance', 5, .4)
					TweenThing(plr, 'CameraMinZoomDistance', 5, .4)
				end
				Steady = true
				z = true
				SE_GUI.MainFrame.Poses.Steady.Visible = true
				if Stances == 0 then
					Stand()
				end
			elseif z and Stances == 0 then
				Steady = false
				z = false
				SE_GUI.MainFrame.Poses.Steady.Visible = false
				Humanoid.WalkSpeed = OrigWalkSpeed
				OrigWalkSpeed = nil
				MaxSpeedRange[1],MaxSpeedRange[2] = nil,nil
				if _G.ThirdPerson then
					TweenThing(plr, 'CameraMaxZoomDistance', 8, .35)
					TweenThing(plr, 'CameraMinZoomDistance', 8, .35)
					delay(.35,function()
						TweenThing(plr, 'CameraMaxZoomDistance', 15, .2)
						TweenThing(plr, 'CameraMinZoomDistance', 5, .2)
					end)
				elseif not _G.ThirdPerson and not IsFirstPerson() then
					TweenThing(plr, 'CameraMaxZoomDistance', game:GetService("StarterPlayer").CameraMaxZoomDistance, .35)
					TweenThing(plr, 'CameraMinZoomDistance', game:GetService("StarterPlayer").CameraMinZoomDistance, .35)
				end
			end
		end
	end

	if (key.KeyCode == Enum.KeyCode.Equals) then
		if script.Parent.Stances.Rappeling.Value == true then
			Network:FireServer("RopeEvent",{'Up',true})
		end
	end
	if (key.KeyCode == Enum.KeyCode.Minus) then
		if script.Parent.Stances.Rappeling.Value == true then
			Network:FireServer("RopeEvent",{'Down',true})
		end
	end

	if not gameProcessed then

		if (key.KeyCode == Enum.KeyCode.Space) and not JumpDelay and not Crouched and not Proned then
			cameraspring:accelerate(Vector3.new(0, 0, -1))
			SwaySpring:accelerate(Vector3.new(0, -1, 1.5))
		end

		if (key.KeyCode == gameRules.ThirdPersonKey) and gameRules.AllowTPS == true and not TPswapcooldown and ToolEquip and _G.AnimDebounce and not _G.reloading and not gameRules.TPSonly and not (Seated and not AllowSeated) then
			if (workspace.CurrentCamera.Focus.p - workspace.CurrentCamera.CoordinateFrame.p).magnitude < 1 then
				_G.ThirdPerson = true
				TPswapFX()
				local ViewModel = workspace.CurrentCamera:FindFirstChild('Viewmodel')

				if WeaponData.CenterDot then
					TS:Create(Crosshair.Center, TweenInfo.new(.2,Enum.EasingStyle.Linear), {ImageTransparency = 1}):Play()
				end
				if  WeaponData.CrossHair then
					TS:Create(Crosshair.Up, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
					TS:Create(Crosshair.Down, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
					TS:Create(Crosshair.Left, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
					TS:Create(Crosshair.Right, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
				end

				if ViewModel then
					if _G.ThirdPerson == true then
						unset(false,false,false,true)
						WeaponData.AmmoInGun = Ammo
						WeaponData.StoredAmmo = StoredAmmo
						WeaponData.LauncherAmmo = GreAmmo
						ToolEquip = true
						_G.AnimDebounce = true
						User.MouseIconEnabled = false
						shiftLock(true)
						plr.CameraMode = Enum.CameraMode.Classic
						TweenThing(plr, 'CameraMaxZoomDistance', 15, .2)
						TweenThing(plr, 'CameraMinZoomDistance', 5, .2)
						if not char:FindFirstChild(WeaponTool.Name) then
							Humanoid:EquipTool(plr.Backpack[WeaponTool.Name])
						end
						WeaponInHand = char['S'..WeaponTool.Name]
						User.MouseDeltaSensitivity = .2
						if gameRules.ThirdPersonCrosshair then
							CrosshairPart.Parent = workspace.Terrain
						end
						if _G.TorchActive then
							TPhandler.SetTorch(_G.TorchMode,AnimationHandler,WeaponInHand,WeaponTool,WeaponData,SE_GUI,ToolEquip,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,Ammo,StoredAmmo)
						end
						UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
						if gameRules.AntiSpawnKill then
							task.wait()
							for _,safezones in ACS_Workspace.SafeZones:GetChildren() do
								if safezones:IsA("BasePart") and safezones.Name == "SafeZone" and safezones.BrickColor ~= plr.TeamColor then
									safezonecheck(safezones)	
								end
							end
						end
						task.wait()
						_G.LeanCameraX = 1.3
						_G.CameraX = _G.LeanCameraX + AimCameraOffset
					end
				end

			elseif (workspace.CurrentCamera.Focus.p - workspace.CurrentCamera.CoordinateFrame.p).magnitude > 1 then
				_G.ThirdPerson = false
				TPswapFX()
				shiftLock(false,Humanoid)
				User.MouseDeltaSensitivity = 1
				TweenThing(plr, 'CameraMaxZoomDistance', game:GetService("StarterPlayer").CameraMaxZoomDistance, .3)
				TweenThing(plr, 'CameraMinZoomDistance', game:GetService("StarterPlayer").CameraMinZoomDistance, .3)
				if gameRules.ThirdPersonCrosshair then
					CrosshairPart.Parent = Engine.Cache
				end

				--reset laser & flashlight
				if LaserActive then
					for _,v in WeaponInHand:GetChildren() do
						if v.Name == 'LaserPoint' and v:FindFirstChild('Enabled') then
							v.Enabled.Value = false
							WeaponInHand.Handle.Click:Play()
							Network:FireServer("LaserAct",{WeaponTool.Name,false,v})
						end
					end
				end
				if _G.TorchActive then
					_G.TorchMode = 'Off'
					_G.TorchActive = false

					Network:FireServer("SVFlash",{WeaponTool,"Remove",_G.ThirdPerson,nil})
				end
				if WeaponTool and char:FindFirstChild(WeaponTool.Name) then
					local ToolFromGun = char[WeaponTool.Name]
					WeaponData.AmmoInGun = Ammo
					WeaponData.StoredAmmo = StoredAmmo
					WeaponData.LauncherAmmo = GreAmmo
					if WeaponData.Type ~= "Grenade" then
						setup(ToolFromGun,false,false)
					else
						setup(ToolFromGun,true,false)
					end
				end
			end
		end

		TPhandler.GetFunction(key,ToolEquip,SE_GUI,plr,WeaponInHand,WeaponTool,GreAmmo,WeaponData,AnimData,LaserActive,AnimationHandler,_G.aiming,runKeyDown,Crosshair,chambering,_G.sprinting,AimCameraOffset,Ammo,StoredAmmo,TorchAtt,BipodAtt,Suppressor,SuppressorAct,Sens,LaserAtt)
		task.wait()
		if (key.KeyCode == gameRules.Keybinds.Reload) and _G.ThirdPerson and ToolEquip then
			Ammo,StoredAmmo = TPhandler.GetAmmo()
			UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
		end
	end
end)

Network:BindEvents({


	Spectating = function(Data)
		if Data[2] == plr then
			cameraspring:accelerate(Data[3])
		end
	end,

	LauncherHit = function(Data)	
		if Data[1] ~= plr then 
			HitMod.Explosion(Data[2], Data[3], Data[4])
			HitMod.CreateEffect(plr, Data[2], Data[3], Data[4], Data[3].Material, "Explosion", Data[6].BulletType)
		end
	end,

	Refil = function(Data)
		print(Data)

		local data = require(Data[1].ACS_Settings)
		local NewStored = math.min(data.MaxStoredAmmo - StoredAmmo, Data[3].Value) 

		StoredAmmo = StoredAmmo + NewStored
		data.StoredAmmo = StoredAmmo

		UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)

	end,

	Share = function(Data)
		print(Data)

		spawn(function()
			local candest = false
			if plr == Data[2] then
				if ToolEquip and WeaponData and WeaponData.BulletType == Data[3] then
					candest = true
					StoredAmmo += Data[4]
					UIhandler.UpdateGui(true,plr.PlayerGui:WaitForChild("StatusUI"),ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
					Network:FireServer("UnShare", {Data[5]})
				end
			end
		end)

	end,

	LaserAct = function(Data)

		if Data[1].Character and Data[1].Character:FindFirstChild('S'..Data[2]) then
			if Data[1] == plr then LaserActive = Data[3]
				UIhandler.UpdateGui(true,plr.PlayerGui:WaitForChild("StatusUI"),ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo) 
			end
			local p = Data[1].Character['S'..Data[2]]
			for _,v in p:GetChildren() do
				if v:IsA("BasePart") and v.Name == "LaserPoint" then
					v.On.Value = Data[3]
				end
			end
		end

	end,


})

