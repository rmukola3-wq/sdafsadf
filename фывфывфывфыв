			end
			ViewModel.Name = "Viewmodel"
			ViewmodelHuman = ViewModel:FindFirstChildOfClass("Humanoid")
		end

		if not plr:FindFirstChild("WeaponsCache") or not plr:FindFirstChild("WeaponsCache"):FindFirstChild(Tool.Name) and not WeaponData.Keyframebased then
			WeaponInHand = GunModels:WaitForChild(Tool.Name):Clone()
			EquippingGunFromCache = false
		elseif plr:FindFirstChild("WeaponsCache") and plr:FindFirstChild("WeaponsCache"):FindFirstChild(Tool.Name) and not WeaponData.Keyframebased then
			WeaponInHand = plr.WeaponsCache[Tool.Name]
			task.wait(.35)
			EquippingGunFromCache = true
		elseif WeaponData.Keyframebased then
			WeaponInHand = ViewModel:WaitForChild(Tool.Name)
		end

		if FireServer then
			Network:FireServer("Equip", {WeaponTool,1})
		end

		if not WeaponData.Keyframebased then
			AnimPart = Instance.new("Part",ViewModel)
			AnimPart.Name = "AnimPart"
			AnimPart.Size = Vector3.new(0.1,0.1,0.1)
			AnimPart.Anchored = true
			AnimPart.CanCollide = false
			AnimPart.Transparency = 1

			LArmWeld = Instance.new("Motor6D",AnimPart)
			LArmWeld.Name = "LeftArm"
			LArmWeld.Part0 = AnimPart

			RArmWeld = Instance.new("Motor6D",AnimPart)
			RArmWeld.Name = "RightArm"
			RArmWeld.Part0 = AnimPart

			GunWeld = Instance.new("Motor6D",AnimPart)
			GunWeld.Name = "Handle"
		else
			if EquippingGunFromCache then
				AnimPart = ViewModel.AnimPart
				LArmWeld = AnimPart.LeftUpperArm
				RArmWeld = AnimPart.RightUpperArm
				GunWeld = AnimPart.Handle
			else
				AnimPart = ViewModel:WaitForChild("AnimPart")
				LArmWeld = AnimPart:WaitForChild("LeftUpperArm")
				RArmWeld = AnimPart:WaitForChild("RightUpperArm")
				GunWeld = AnimPart:WaitForChild("Handle")
			end
		end

		local TranPart = Instance.new("StringValue", AnimPart)
		TranPart.Name = "Transparent"
		ViewModel.PrimaryPart = AnimPart
		ViewModel.PrimaryPart.CFrame = ViewModel.PrimaryPart.CFrame*CFrame.new(0,10,-10)

		maincf = AnimData.MainCFrame
		guncf = AnimData.GunCFrame

		larmcf = AnimData.LArmCFrame
		rarmcf = AnimData.RArmCFrame

		if char:FindFirstChild("Body Colors") ~= nil then
			local Colors = char:WaitForChild("Body Colors"):Clone()
			Colors.Parent = ViewModel
		end

		if char:FindFirstChild("Shirt") ~= nil then
			local Shirt = char:FindFirstChild("Shirt"):Clone()
			Shirt.Parent = ViewModel
		end


		for _,v in ViewModel:GetChildren() do
			if v:IsA("MeshPart") then
				v.BrickColor = char["Head"].BrickColor
				if v.Name == "LeftUpperArm"	then
					LArmWeld.Part1 = v
					LArm = v
				elseif v.Name == "RightUpperArm" then
					RArmWeld.Part1 = v 
					RArm = v
				end
			end
			v.Parent = ViewModel
		end

		shelljecttable = {ShellEjection,plr,WeaponInHand,ACS_Workspace,WeaponData.DropCasings,WeaponData.BulletType,Engine,CasingConfig,PastaFx,Ignore_Model}
		ViewModel.PrimaryPart = AnimPart
		ViewModel.PrimaryPart.CFrame = ViewModel.PrimaryPart.CFrame*CFrame.new(0,10,-10)
		WeaponInHand.PrimaryPart = WeaponInHand:WaitForChild("Handle")
		WeaponInHand.Parent = ViewModel
		task.wait(.35)
		ViewModel.Parent = cam
		TS:Create(ViewModel.PrimaryPart, TweenInfo.new(.01,Enum.EasingStyle.Linear), {CFrame = ViewModel.PrimaryPart.CFrame*CFrame.new(0,10,-10)}):Play()

		CharAnims.KeyframeEvent("LoadAnims",nil,WeaponTool)
		if WeaponData.Keyframebased then
			if WeaponData.Animations.NewSystem then
				AnimData.PreloadAnims(ViewmodelHuman,WeaponInHand,Animations:FindFirstChild(WeaponData.Animations.GunPlatform.."Platform").ViewmodelAnims,shelljecttable,{cameraspring,AnimationHandler})
			else
				AnimData.PreloadAnims(ViewmodelHuman,WeaponInHand,WeaponInHand:WaitForChild("ViewmodelAnims"),shelljecttable,{cameraspring,AnimationHandler})
			end
		end

		if WeaponData.Keyframebased then
			LArm = ViewModel:WaitForChild("LeftUpperArm")
			RArm = ViewModel:WaitForChild("RightUpperArm")
			GunWeld.Part1 = WeaponInHand:WaitForChild("Handle")
		else
			LArm = ViewModel:WaitForChild("Left Arm")
			LArmWeld.Part1 = LArm
			LArmWeld.C0 = CFrame.new()
			LArmWeld.C1 = larmcf--CFrame.new(1,-1,-5) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)):Inverse()

			RArm = ViewModel:WaitForChild("Right Arm")
			RArmWeld.Part1 = RArm
			RArmWeld.C0 = CFrame.new()
			RArmWeld.C1 = rarmcf--CFrame.new(-1,-1,-5) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)):Inverse()
			GunWeld.Part0 = RArm
			LArm.Anchored = false
			RArm.Anchored = false

			GunWeld.Part1 = WeaponInHand:WaitForChild("Handle")
			GunWeld.C1 = guncf
		end

		if WeaponData.CrossHair then
			TS:Create(Crosshair.Up, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 0}):Play()
			TS:Create(Crosshair.Down, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 0}):Play()
			TS:Create(Crosshair.Left, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 0}):Play()
			TS:Create(Crosshair.Right, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 0}):Play()	

			if WeaponData.Bullets > 1 then
				Crosshair.Up.Rotation = 90
				Crosshair.Down.Rotation = 90
				Crosshair.Left.Rotation = 90
				Crosshair.Right.Rotation = 90
			else
				Crosshair.Up.Rotation = 0
				Crosshair.Down.Rotation = 0
				Crosshair.Left.Rotation = 0
				Crosshair.Right.Rotation = 0
			end

		else
			TS:Create(Crosshair.Up, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
			TS:Create(Crosshair.Down, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
			TS:Create(Crosshair.Left, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
			TS:Create(Crosshair.Right, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
		end

		if WeaponData.CenterDot then
			TS:Create(Crosshair.Center, TweenInfo.new(.2,Enum.EasingStyle.Linear), {ImageTransparency = 0}):Play()
		else
			TS:Create(Crosshair.Center, TweenInfo.new(.2,Enum.EasingStyle.Linear), {ImageTransparency = 1}):Play()
		end

		--setup weapon to camera
		ModTable.ZoomValue = WeaponData.Zoom
		ModTable.Zoom2Value 	= WeaponData.Zoom2
		ModTable.Zoom3Value 	= WeaponData.Zoom3
		IREnable 		 = WeaponData.InfraRed

		--CAS:BindAction("Fire", handleAction, true, Enum.UserInputType.MouseButton1, Enum.KeyCode.ButtonR2)
		CAS:BindAction("ADS", handleAction, true, Enum.UserInputType.MouseButton2, Enum.KeyCode.ButtonL2) 
		CAS:BindAction("Reload", handleAction, true, gameRules.Keybinds.Reload, Enum.KeyCode.ButtonB)
		CAS:BindAction("CycleAimpart", handleAction, true, gameRules.Keybinds.CycleAimpart)
		CAS:BindAction("Chamber", handleAction, true, gameRules.Keybinds.Chamber)
		CAS:BindAction("LeftHand", handleAction, true, gameRules.Keybinds.LeftHandToggle)

		if WeaponInHand:FindFirstChild("FlashPoint") then
			CAS:BindAction("CycleLight", handleAction, true, gameRules.Keybinds.CycleLight)
		end
		if WeaponInHand:FindFirstChild("LaserPoint") then
			CAS:BindAction("CycleLaser", handleAction, true, gameRules.Keybinds.CycleLaser)
		end
		if WeaponInHand:FindFirstChild("SightMark") then
			CAS:BindAction("SightMark", handleAction, false, gameRules.Keybinds.SightMarkBrightness)
		end
		if (WeaponInHand:FindFirstChild("Silencer") or WeaponInHand:FindFirstChild("Suppressor") or WeaponInHand:FindFirstChild("Supressor")) then
			CAS:BindAction("CycleSilencer", handleAction, true, gameRules.Keybinds.CycleSilencer)
		end

		CAS:BindAction("CycleFiremode", handleAction, true, gameRules.Keybinds.CycleFiremode)
		CAS:BindAction("CheckMag", handleAction, false, gameRules.Keybinds.CheckMag)
		CAS:BindAction("ZeroDown", handleAction, false, gameRules.Keybinds.ZeroDown)
		CAS:BindAction("ZeroUp", handleAction, false, gameRules.Keybinds.ZeroUp)
		CAS:BindAction("DropWeapon", handleAction, false, gameRules.Keybinds.WeaponDropKeybind)

		Suppressor,LaserAtt,TorchAtt = false,false,false
		loadAttachment(WeaponInHand)
		Spread.Setup(WeaponData)
		SpringsModule.Setup(WeaponData)

		if not BipodAtt and WeaponInHand:FindFirstChild("BipodPoint") then
			BipodAtt = true
			CAS:BindAction("ToggleBipod", handleAction, true, gameRules.Keybinds.ToggleBipod)
		end

		BSpread		 = math.min(WeaponData.MinSpread * ModTable.MinSpread, WeaponData.MaxSpread * ModTable.MaxSpread)
		RecoilPower = math.min(WeaponData.MinRecoilPower * ModTable.MinRecoilPower, WeaponData.MaxRecoilPower * ModTable.MaxRecoilPower)

		if WeaponData.ShootType ~= 6 and WeaponData.ShootType ~= 7 then
			Lethal = true
		else
			Lethal = false
		end

		Ammo = WeaponData.AmmoInGun
		StoredAmmo = WeaponData.StoredAmmo
		GreAmmo = WeaponData.LauncherAmmo

		CurAimpart = WeaponInHand:FindFirstChild("AimPart")

		if (WeaponInHand:FindFirstChild("Silencer") or WeaponInHand:FindFirstChild("Suppressor") or WeaponInHand:FindFirstChild("Supressor")) then
			WeaponData.AllowSilencerToggle = true
			Suppressor = true
		else
			WeaponData.AllowSilencerToggle = false
			Suppressor = false
		end

		for index, Key in WeaponInHand:GetDescendants() do
			if Key:IsA("BasePart") and Key.Name == "FlashPoint" then
				TorchAtt = true
			end
			if Key:IsA("BasePart") and Key.Name == "LaserPoint" then
				LaserAtt = true
			end
		end

		for index, Key in WeaponInHand:GetDescendants() do
			if Key:IsA("BasePart") and (Key.Name == "REG" or Key.Name == "REG2") then
				if not Key:FindFirstChild("OrigTrans") then
					local OrigTrans = Instance.new("NumberValue",Key)
					OrigTrans.Name = "OrigTrans"
					OrigTrans.Value = Key.Transparency
				end
			end
		end

		if LaserActive then
			for _,v in WeaponInHand:GetChildren() do
				if v.Name == 'LaserPoint' and v:FindFirstChild('On') then
					v.On.Value = true
					Network:FireServer("LaserAct",{WeaponTool.Name,true,v})
				end
			end
		end
		if _G.TorchActive then
			TPhandler.QuickSetTorch(_G.TorchMode,AnimationHandler,WeaponInHand,WeaponTool,WeaponData,SE_GUI,ToolEquip,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt)
		else
			if TorchAtt then
				TPhandler.QuickSetTorch(_G.TorchMode,AnimationHandler,WeaponInHand,WeaponTool,WeaponData,SE_GUI,ToolEquip,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt)
			end
		end

		if (WeaponData.ShootType == 4 or WeaponData.ShootType == 5) and Ammo > 0 and not WeaponData.Jammed then
			_G.racked = true
		end

		if not EquippingGunFromCache then
			for index, key in WeaponInHand:GetChildren() do
				if key:IsA('BasePart') and key.Name ~= 'Handle' then

					if key.Name ~= "Bolt" and key.Name ~= 'Lid' and key.Name ~= "Slide" then
						Ultil.Weld(WeaponInHand:WaitForChild("Handle"), key)
					end

					if key.Name == "Bolt" or key.Name == "Slide" then
						Ultil.WeldComplex(WeaponInHand:WaitForChild("Handle"), key, key.Name)
					end;

					if key.Name == 'Chamber' then
						Ultil.WeldComplex(WeaponInHand:WaitForChild("Handle"), key, "Cham")
					end;

					if key.Name == "Lid" then
						if WeaponInHand:FindFirstChild('LidHinge') then
							Ultil.Weld(key, WeaponInHand:WaitForChild("LidHinge"))
						else
							Ultil.Weld(key, WeaponInHand:WaitForChild("Handle"))
						end
					end
				end
			end;

			for L_213_forvar1, L_214_forvar2 in WeaponInHand:GetChildren() do
				if L_214_forvar2:IsA('BasePart') then
					L_214_forvar2.Anchored = false
					L_214_forvar2.CanCollide = false
					L_214_forvar2.CastShadow = false
				end
			end;

			for _,everything in ViewModel:GetDescendants()do
				if everything:IsA('BasePart') then
					everything.CanCollide = false
					everything.CastShadow = false
				end
			end

			if WeaponInHand:FindFirstChild("Nodes") then
				for L_213_forvar1, L_214_forvar2 in WeaponInHand.Nodes:GetChildren() do
					if L_214_forvar2:IsA('BasePart') then
						Ultil.Weld(WeaponInHand:WaitForChild("Handle"), L_214_forvar2)
						L_214_forvar2.Anchored = false
						L_214_forvar2.CanCollide = false
					end
				end;
			end
		end

		if WeaponData.EnableHUD then
			SE_GUI.GunHUD.Visible = true
		end

		if LaserAtt and WeaponInHand.LaserPoint:FindFirstChild("IR") then
			_G.IRmode = true
		end
		WeaponInHand.DescendantAdded:Connect(function(Desc)
			if Desc:IsA("BoolValue") and Desc.Name == "IR" then
				_G.IRmode = true
			end
		end)
		WeaponInHand.DescendantRemoving:Connect(function(Desc)
			if Desc:IsA("BoolValue") and Desc.Name == "IR" then
				_G.IRmode = false
			end
		end)

		UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)

		if gameRules.AntiSpawnKill then
			local message = Essential.Message:Clone()
			message.Parent = WeaponInHand.Handle.Muzzle
		end

		if EquipType ~= "Other" then
			if WeaponData.ADSsettings.CoverSight then
				for _,sightmark in WeaponInHand:GetChildren() do
					if sightmark.Name == "SightMark" and sightmark.SurfaceGui:FindFirstChild("SightCover") then
						sightmark.SurfaceGui.Border.Visible = true
						sightmark.SurfaceGui.SightCover.Visible = true
						sightmark.SurfaceGui.Border.ImageTransparency = 1
						sightmark.SurfaceGui.Border.Scope.ImageTransparency = 1
						sightmark.SurfaceGui.SightCover.ImageTransparency = 0
					end
				end
			end
		end

		--WeaponInHand:SetPrimaryPartCFrame( RArm.CFrame * guncf)
		if gameRules.RigType == Enum.HumanoidRigType.R15 then
			CharAnims.KeyframeEvent("PlayAnims","Equip",WeaponTool,false,false,"Idle",true)
		end

		WeaponInHand.Parent = ViewModel
		Tween(tiltaxis,1,{CFrame = CFrame.new(0,0,0)*CFrame.Angles(0,0,0)})
		if Ammo <= 0 and WeaponData.Type == "Gun" then	
			WeaponInHand.Handle.Slide.C0 = WeaponData.SlideEx:Inverse()
		end
		if PlayEquip then
			if gameRules.WeaponCheck and not WeaponData.HasEquip then
				EquipAnim()
				PumpAnim()
				WeaponData.HasEquip = true
			else
				EquipAnim()
			end
		end		
		if WeaponData and WeaponData.Type ~= "Grenade" then
			RunCheck()
		end

		if gameRules.AntiSpawnKill then
			for _,sz in ACS_Workspace.SafeZones:GetChildren() do
				if sz:IsA("BasePart") and sz.Name == "SafeZone" and sz.BrickColor ~= plr.TeamColor then
					safezonecheck(sz)
				end
			end
		end

		Allow_Shooting = true

		if EquippingGunFromCache then
			EquippingGunFromCache = false
		end
	end
end

function unset(CheckIfThirdPerson,died,dropping,keepdata,skipequip)
	UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)

	if not keepdata and not (died and not ToolEquip) then
		if not skipequip then
			Network:FireServer("Equip", {WeaponTool,2,died,dropping})
			if _G.ThirdPerson then
				TPYOffset = 0
				User.MouseBehavior = Enum.MouseBehavior.Default
			end
		end
	end
	ToolEquip = false
	ViewmodelHuman = nil
	--unsetup weapon data module
	CAS:UnbindAction("ADS") 
	CAS:UnbindAction("Reload")
	CAS:UnbindAction("CycleAimpart")
	CAS:UnbindAction("CycleSilencer")
	CAS:UnbindAction("Chamber")
	CAS:UnbindAction("CycleLight")
	CAS:UnbindAction("CycleLaser")
	CAS:UnbindAction("SightMark")
	CAS:UnbindAction("CycleFiremode")
	CAS:UnbindAction("CheckMag")
	CAS:UnbindAction("ZeroDown")
	CAS:UnbindAction("ZeroUp")
	CAS:UnbindAction("DropWeapon")

	_G.mouse1down = false
	_G.aiming = false
	TPaiming = false

	if gameRules.FOVs.adjustableFOV then
		if IsFirstPerson() then
			TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.FirstPersonFOV}):Play()
		else
			TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.ThirdPersonFOV}):Play()
		end
	else
		TS:Create(cam,AimTween,{FieldOfView = gameRules.FOVs.ThirdPersonFOV}):Play()
	end
	TS:Create(Crosshair.Up, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
	TS:Create(Crosshair.Down, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
	TS:Create(Crosshair.Left, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
	TS:Create(Crosshair.Right, TweenInfo.new(.2,Enum.EasingStyle.Linear), {BackgroundTransparency = 1}):Play()
	TS:Create(HeadAimingAngle, TweenInfo.new(.25,Enum.EasingStyle.Sine), {Value = 0}):Play()
	AimCameraOffset = 0
	_G.CameraX = _G.LeanCameraX
	User.MouseBehavior = Enum.MouseBehavior.Default

	if CheckIfThirdPerson and not (gameRules.AllowTPS and gameRules.TPSonly) then
		TS:Create(Crosshair.Center, TweenInfo.new(.2,Enum.EasingStyle.Linear), {ImageTransparency = 1}):Play()

		plr.CameraMaxZoomDistance = game:GetService("StarterPlayer").CameraMaxZoomDistance
		plr.CameraMinZoomDistance = game:GetService("StarterPlayer").CameraMinZoomDistance
		plr.CameraMode = game:GetService("StarterPlayer").CameraMode
		User.MouseDeltaSensitivity = 1
		if game:GetService("StarterPlayer").CameraMode == Enum.CameraMode.Classic then
			User.MouseIconEnabled = true
		end
	elseif CheckIfThirdPerson and gameRules.AllowTPS and not gameRules.TPSonly then
		TS:Create(Crosshair.Center, TweenInfo.new(.2,Enum.EasingStyle.Linear), {ImageTransparency = 0}):Play()

		plr.CameraMaxZoomDistance = game:GetService("StarterPlayer").CameraMaxZoomDistance
		plr.CameraMinZoomDistance = game:GetService("StarterPlayer").CameraMinZoomDistance
		plr.CameraMode = game:GetService("StarterPlayer").CameraMode
		User.MouseDeltaSensitivity = 1
		if game:GetService("StarterPlayer").CameraMode == Enum.CameraMode.Classic then
			User.MouseIconEnabled = true
		end
	elseif CheckIfThirdPerson and gameRules.AllowTPS and gameRules.TPSonly then
		TS:Create(Crosshair.Center, TweenInfo.new(.2,Enum.EasingStyle.Linear), {ImageTransparency = 1}):Play()

		plr.CameraMaxZoomDistance = 15
		plr.CameraMinZoomDistance = 5
		plr.CameraMode = Enum.CameraMode.Classic
		User.MouseDeltaSensitivity = .2
		if game:GetService("StarterPlayer").CameraMode == Enum.CameraMode.Classic then
			User.MouseIconEnabled = true
		end
	end

	UnloadClientMods()

	if HeadBase:FindFirstChild('Attach') then
		HeadBase.Attach:Destroy()
	end

	if WeaponInHand and WeaponInHand:findFirstChild("Handle") then
		if ViewModel then
			--cache weapon model
			for _,gunpart in WeaponInHand:GetDescendants() do
				if gunpart:IsA("Sound") and gunpart.IsPlaying then
					gunpart:Stop()
				else
					if gunpart.Name == "AimTransparency" or gunpart.Name == "OriginalTransparency" or gunpart.Name == "FlashLoaded" then --blacklist
						gunpart:Destroy()
					end
				end
			end
			if not WeaponData.Keyframebased then
				WeaponInHand.Parent = plr:WaitForChild("WeaponsCache")
				WeaponInHand.PrimaryPart.CFrame = CFNew(0,0,0)*CFAng(0,0,0)
				--WeaponInHand
				ViewModel:Destroy()
				ViewModel = nil
			else
				WeaponInHand.PrimaryPart.CFrame = CFNew(0,0,0)*CFAng(0,0,0)
				ViewModel.Parent = plr:WaitForChild("WeaponsCache")
				ViewModel.Name = WeaponInHand.Name
				ViewModel.PrimaryPart.CFrame = CFNew(0,10,-10)*CFAng(0,0,0)
				ViewModel = nil
			end
		else
			ViewModel = cam:FindFirstChild('Viewmodel')
		end
	end
	if WeaponInHand and not keepdata then
		WeaponData.AmmoInGun = Ammo
		WeaponData.StoredAmmo = StoredAmmo
		WeaponData.LauncherAmmo = GreAmmo

		Allow_Shooting = false
		ViewModel = nil
		WeaponInHand	= nil
		WeaponTool = nil
		LArm = nil
		RArm = nil
		LArmWeld = nil
		RArmWeld = nil
		WeaponData = nil
		AnimData = nil
		SightAtt = nil
		reticle	 = nil
		BarrelAtt = nil
		UnderBarrelAtt = nil
		OtherAtt = nil
		LaserAtt = false
		LaserActive = false
		TorchAtt = false
		_G.TorchActive 	= false
		BipodAtt = false
		BipodActive 	= false
		LaserDist = 0
		Pointer = nil
		BSpread = nil
		RecoilPower 	= nil
		Suppressor = false
		SuppressorAct = false
		Lethal = false
		SightBrightSw = false
		FlashHider = false
		_G.CancelReload 	= false
		_G.reloading = false
		chambering = false
		_G.SafeMode = false
		CheckingMag = false
		GRDebounce = false
		CookGrenade 	= false
		_G.GunStance = 0
		resetMods()
		generateBullet = 1
		AimPartMode = 1
		shelljecttable = nil
		ToolEquip = false

		if not _G.ThirdPerson then
			SE_GUI.GunHUD.Visible = false
			SE_GUI.GrenadeForce.Visible = false
		elseif _G.ThirdPerson and CheckIfThirdPerson then
			_G.ThirdPerson = false
		end
		BipodCF = CFrame.new()
	end
end

local HalfStep = false
function HeadMovement()
	if plr:GetAttribute("InLockerMenu") then return end
	if dead then return end
	if char.Humanoid.Health <= 0 then return end
	local CameraDirection = char.HumanoidRootPart.CFrame:toObjectSpace(cam.CFrame).lookVector
	if not Neck then return end
	if char.Humanoid.PlatformStand then return end
	if char.Humanoid.RigType == Enum.HumanoidRigType.R15 then
		HalfStep = not HalfStep
		local neckCFrame = nil
		local LarmCFrame = nil
		local RarmCFrame = nil
