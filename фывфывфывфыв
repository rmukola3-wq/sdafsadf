	if char and Humanoid.Health > 0 then

		if (cam.CFrame.p - cam.Focus.p).magnitude < 0.75 and _G.LeanCameraX ~= 0 then
			if Virar == 0 then
				_G.LeanCameraX = 0
				_G.CameraX = _G.LeanCameraX + AimCameraOffset
				if plr.Character:FindFirstChild("Vest") then
					for i,v in plr.Character.Vest:GetChildren() do
						v.LocalTransparencyModifier = 0
					end
				end
			end
		end

		return (cam.CFrame.p - cam.Focus.p).magnitude <= 0.75
	end
end

