local SWAY_SPEED = 2
local SWAY_MAGNITUDE_X = 0.01
local SWAY_MAGNITUDE_Y = 0.01
local SMOOTHING_FACTOR = 0.1

local currentOffset = Vector2.new(0, 0)
local targetOffset = Vector2.new(0, 0)

local function updateReticle(Part, cam)
	local dist_scale = Part.CFrame:pointToObjectSpace(cam.CFrame.Position)/Part.Size

	local time = tick() * SWAY_SPEED

	targetOffset = targetOffset + Vector2.new(
		(math.random() - 0.5) * 0.002,
		(math.random() - 0.5) * 0.002
	)

	currentOffset = currentOffset:Lerp(targetOffset, SMOOTHING_FACTOR)

	local finalOffset = Vector2.new(dist_scale.x, -dist_scale.y) + currentOffset

	local reticle = Part.SurfaceGui.Border.Scope
	reticle.Position = UDim2.fromScale(0.5 + finalOffset.X, 0.5 + finalOffset.Y)

	if Part.SurfaceGui:FindFirstChild("Shadow") then
		local reticle2 = Part.SurfaceGui.Shadow.Scope
		reticle2.Position = UDim2.fromScale(0.5 + finalOffset.X, 0.5 + finalOffset.Y)
	end
end
