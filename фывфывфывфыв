		end
	end

	char.Humanoid.JumpPower = 0 
end

function Lean()
	Network:FireServer("Stance",{Stances,Virar})

	if not tiltaxis then
		tiltaxis = Instance.new('Part')
	end

	if Virar == 0 then
		Tween(tiltaxis,1,{CFrame = CFrame.new(0,0,0)*CFrame.Angles(0,0,0)})
	end

	Tween(tiltaxis,.7,{CFrame = CFrame.new(0,0,0)*CFrame.Angles(0,0,-math.rad(_G.LeanCameraX*13))})

	if Virar == 0 then
		SE_GUI.MainFrame.Poses.Esg_Left.Visible = false
		SE_GUI.MainFrame.Poses.Esg_Right.Visible = false
	elseif Virar == 1 then
		SE_GUI.MainFrame.Poses.Esg_Left.Visible = false
		SE_GUI.MainFrame.Poses.Esg_Right.Visible = true
	elseif Virar == -1 then
		SE_GUI.MainFrame.Poses.Esg_Left.Visible = true
		SE_GUI.MainFrame.Poses.Esg_Right.Visible = false
	end
end

function HideUI()
	if not Hidden then
		Hidden = not Hidden

		if StarGui:GetCoreGuiEnabled(Enum.CoreGuiType.Chat) then
			CoreUIsEnabled[1] = true
		end
		if StarGui:GetCoreGuiEnabled(Enum.CoreGuiType.Backpack) then
			CoreUIsEnabled[2] = true
		end

		if gameRules.HideCoreUIonCinematics then
			StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat,false)
			StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList,false)
		end
		StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.Health,false)
		StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack,false)

		for _,v in plr.PlayerGui:GetChildren() do
			if v:IsA("ScreenGui") and v:FindFirstChild("Hide") then
				v.Enabled = false
			end 
		end
	else

		if CoreUIsEnabled[1] then
			StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat,true)
			CoreUIsEnabled[1] = false
		end
		if CoreUIsEnabled[2] then
			StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack,true)
			CoreUIsEnabled[2] = false
		end
		if gameRules.CoreGuiPlayerList then
			StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList,true)
		end
		if gameRules.CoreGuiHealth then
			StarGui:SetCoreGuiEnabled(Enum.CoreGuiType.Health,true)
		end

		Hidden = not Hidden
		for _,v in plr.PlayerGui:GetChildren() do
			if v:IsA("ScreenGui") and v:FindFirstChild("Hide") then
				v.Enabled = true
			end 
		end
	end
	if gameRules.CinematicBars then
		Cinematics()
	end
end
