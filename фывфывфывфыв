function handleAction(actionName, inputState, inputObject)

	if actionName == "Fire" and inputState == Enum.UserInputState.Begin and _G.AnimDebounce then
		if WeaponData and WeaponData.Type == "Gun" and not shooting and not _G.reloading then
			WeaponInHand.Handle.TriggerPull:Play()
		end

		if Allow_Shooting then
			Shoot()
		end

	elseif actionName == "Fire" and inputState == Enum.UserInputState.End then
		StopShooting()
		if WeaponData and WeaponData.Type == "Gun" and not shooting and not _G.reloading and _G.AnimDebounce then
			WeaponInHand.Handle.TriggerRelease:Play()
		end
	end

	if actionName == "HideGUIs" and inputState == Enum.UserInputState.Begin then
		HideUI()
	end

	if actionName == "Reload" and inputState == Enum.UserInputState.Begin and _G.AnimDebounce and not CheckingMag and not _G.reloading and not chambering and not _G.sprinting then
		if WeaponData.Jammed then
			Jammed()
		else
			Reload()
		end
	end

	if actionName == "SightMark" and inputState == Enum.UserInputState.Begin and _G.AnimDebounce and not chambering and not _G.reloading then
		AdjustSightMark()
	end

	if actionName == "DropWeapon" and inputState == Enum.UserInputState.Begin and _G.AnimDebounce and not chambering and not _G.reloading then
		if WeaponData and WeaponInHand then
			if WeaponTool.CanBeDropped then
				local GunToClone = GunModels[WeaponInHand.Name]
				unset(true,false,true)
				Network:FireServer("Send", {GunToClone})
			end		
		end		
	end

	if actionName == "Reload" and inputState == Enum.UserInputState.Begin and _G.reloading and WeaponData.ShellInsert then
		_G.CancelReload = true
	end

	if actionName == "CycleLaser" and inputState == Enum.UserInputState.Begin and LaserAtt and _G.AnimDebounce then
		if WeaponInHand.LaserPoint:FindFirstChild("IR") and (not WeaponInHand.LaserPoint:FindFirstChild("HighDual") and not WeaponInHand.LaserPoint:FindFirstChild("LowDual") and not WeaponInHand.LaserPoint:FindFirstChild("Visi") and not WeaponInHand.LaserPoint:FindFirstChild("IRLow")) then
			LaserToggleFunc("IRLow")
		end
		Registers.SetLaser(_G.ThirdPerson,WeaponInHand,WeaponTool,char,AnimationHandler)
	end

	if actionName == "CycleLight" and inputState == Enum.UserInputState.Begin and TorchAtt and _G.AnimDebounce and WeaponData.FlashlightConfigs.AllowFlashlight then
		TPhandler.SetTorch(_G.TorchMode,AnimationHandler,WeaponInHand,WeaponTool,WeaponData,SE_GUI,ToolEquip,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,Ammo,StoredAmmo)
	end

	if actionName == "CycleFiremode" and inputState == Enum.UserInputState.Begin and WeaponData and WeaponData.FireModes.ChangeFiremode and _G.AnimDebounce then
		Firemode()
	end

	if actionName == "CycleSilencer" and inputState == Enum.UserInputState.Begin and WeaponData and WeaponData.AllowSilencerToggle then
		CycleSilencer()
	end

	if actionName == "CycleAimpart" and inputState == Enum.UserInputState.Begin then
		SetAimpart()
	end

	if actionName == "Chamber" and inputState == Enum.UserInputState.Begin and not chambering and not _G.reloading then
		Chamber()
	end

	if actionName == "ZeroUp" and inputState == Enum.UserInputState.Begin and WeaponData and WeaponData.EnableZeroing  then
		if WeaponData.CurrentZero < WeaponData.MaxZero then
			WeaponInHand.Handle.Click:Play()
			WeaponData.CurrentZero = math.min(WeaponData.CurrentZero + WeaponData.ZeroIncrement, WeaponData.MaxZero) 
			UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
			UIhandler.BindToFunc(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,"SwitchZeroing")
		end
	end

	if actionName == "ZeroDown" and inputState == Enum.UserInputState.Begin and WeaponData and WeaponData.EnableZeroing  then
		if WeaponData.CurrentZero > 0 then
			WeaponInHand.Handle.Click:Play()
			WeaponData.CurrentZero = math.max(WeaponData.CurrentZero - WeaponData.ZeroIncrement, 0) 
			UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
			UIhandler.BindToFunc(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,"SwitchZeroing")
		end
	end

	if actionName == "CheckMag" and inputState == Enum.UserInputState.Begin and not CheckingMag and not _G.reloading and not runKeyDown and _G.AnimDebounce then
		CheckMagFunction()
	end

	if actionName == "ToggleBipod" and inputState == Enum.UserInputState.Begin and CanBipod then
		if not BipodActive then
			BipodActive = true
			for _,bpod in WeaponInHand:GetChildren() do
				if bpod:IsA("BasePart") then
					if bpod.Name == "BipodUp" then
						bpod.Transparency = 1
					elseif bpod.Name == "BipodDown" then
						bpod.Transparency = 0
					end
				end
			end
		else
			BipodActive = false
			for _,bpod in WeaponInHand:GetChildren() do
				if bpod:IsA("BasePart") then
					if bpod.Name == "BipodUp" then
						bpod.Transparency = 0
					elseif bpod.Name == "BipodDown" then
						bpod.Transparency = 1
					end
				end
			end
		end
		UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
	end

	if actionName == "ToggleNVG" and inputState == Enum.UserInputState.Begin and not NVGdebounce then
		if char then
			for _,nvg in char:GetDescendants() do
				if nvg:IsA("Model") and nvg.Name == "Up" then
					NVGdebounce = true
					NightVis = not NightVis
					--Evt.NVGlocal:Fire(_G.NVG)
					Network:FireServer("NVG", {nvg,NightVis})
					delay(1,function()
						NVGdebounce = false		
					end)
				end
			end
		end
	end

	if actionName == "ADS" and inputState == Enum.UserInputState.Begin and _G.AnimDebounce then
		if WeaponData and WeaponData.canAim and _G.GunStance > -2 and not runKeyDown and not CheckingMag then
			if gameRules.HoldToADS and not MobileDevice then
				_G.aiming = true
				ADS(_G.aiming)
			elseif not gameRules.HoldToADS or MobileDevice then
				_G.aiming = not _G.aiming
				ADS(_G.aiming)
			end
		end

		if WeaponData.Type == "Grenade" then
			GrenadeMode()
		end
	end

	if actionName == "ADS" and inputState == Enum.UserInputState.End and _G.AnimDebounce and gameRules.HoldToADS and not MobileDevice then
		if WeaponData and WeaponData.canAim and _G.GunStance > -2 and not runKeyDown and not CheckingMag then
			_G.aiming = false
			ADS(_G.aiming)
		end
	end

	if actionName == "LeftHand" and inputState == Enum.UserInputState.Begin and _G.AnimDebounce then
		if WeaponData and not runKeyDown and not CheckingMag then
			if not LeftHanded then
				LeftHanded = true
			else
				LeftHanded = false
			end
		end
	end

	if actionName == "FreeLook" and inputState == Enum.UserInputState.Begin and not Seated and not _G.ThirdPerson then
		if looking == false then
			looking = true
			Humanoid.AutoRotate = false

			oldY,oldX,oldZ = cam.CFrame:ToOrientation()
			prevAngle = cam.CFrame

		end
	end

	if actionName == "FreeLook" and inputState == Enum.UserInputState.End and not Seated and not _G.ThirdPerson then
		if looking == true then
			looking = false
			if Virar == 0 then
				Humanoid.AutoRotate = true
			end
			oldY,oldX,oldZ = cam.CFrame:ToOrientation()
			prevAngle = cam.CFrame
		end
	end

	if actionName == "Stance" and inputState == Enum.UserInputState.Begin and ChangeStance and not Swimming and not Seated and not runKeyDown and not plr:GetAttribute("InLockerMenu") then
		StarGui:SetCore("ChatMakeSystemMessage", {
			Text = "[SYSTEM] Test Message";
			Color = Color3.fromRGB(170, 0, 0); 
			Font = Enum.Font.Roboto; 
			TextSize = 14
		})
		holdStartTime = tick()
		isHolding = true
		active = true
		counter = counter + 1
		local copy = counter
		task.spawn(function()
			task.wait(gameRules.ProneHoldTime)
			if isHolding and active and copy == counter and Stances ~= 2 then
				Stances = 2
				if IsFirstPerson() then
					_G.LeanCameraX = 0
					_G.CameraX = AimCameraOffset
				elseif _G.ThirdPerson or not IsFirstPerson() then
					_G.LeanCameraX = _G.LeanCameraX
					_G.CameraX = _G.LeanCameraX + AimCameraOffset
				end
				CameraY = -3.25
				Virar = 0
				Lean()
				Prone()
				Crouched = false
				Proned = true
				cameraspring:accelerate(Vector3.new(0,0,-5))
			end
		end)
	end

	if actionName == "Stance" and inputState == Enum.UserInputState.End and ChangeStance and not Swimming and not Seated and not runKeyDown and not plr:GetAttribute("InLockerMenu") then
		local holdDuration = tick() - holdStartTime
		isHolding = false
		active = false

		if holdDuration < gameRules.ProneHoldTime then
			if Stances == 0 or Stances == 2 then
				if _G.ThirdPerson or not IsFirstPerson() then
					_G.LeanCameraX = _G.LeanCameraX
					_G.CameraX = _G.LeanCameraX
				end
