User.InputEnded:Connect(function(key, gameProcessed)
	if gameProcessed then return end
	local func = onEnded[key.UserInputType.Name]
	if func then
		func(key.KeyCode.Name)
	end

	if (key.KeyCode == gameRules.Keybinds.Chamber) and _G.ThirdPerson and ToolEquip and _G.AnimDebounce and not _G.reloading and not chambering and not _G.sprinting then
		if shooting then return end;
		if Ammo > 0 and not chambering then
			chambering = true
			_G.SafeMode = true
			_G.DontAllowShooting = true
			StopShooting()
			UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)

			if gameRules.RigType == Enum.HumanoidRigType.R15 then
				CharAnims.KeyframeEvent("PlayAnims","Chamber",WeaponTool,true,false,"Idle",true,shelljecttable)
			else
				Network:FireServer("GunStance", {_G.GunStance,AnimData})
			end

			WeaponData.Jammed = false
			if (WeaponData.ShootType == 4 or WeaponData.ShootType == 5) and Ammo-1 > 0 then
				_G.racked = true
			end
			_G.GunStance = 0
			Ammo -= 1
			chambering = false
			_G.SafeMode = false
			_G.DontAllowShooting = false
			if gameRules.RigType ~= Enum.HumanoidRigType.R15 then
				Network:FireServer("GunStance", {_G.GunStance,AnimData})
			end
			UIhandler.UpdateGui(true,SE_GUI,ToolEquip,WeaponData,StoredAmmo,Ammo,Suppressor,SuppressorAct,Sens,LaserAtt,LaserActive,TorchAtt,BipodAtt,GreAmmo)
			RunCheck()
		end
	end

	if (key.KeyCode == gameRules.TPSstancesKey) then
		if stancesunlock then
			stancesunlock = false

			if _G.ThirdPerson and not Steady then
				TweenThing(plr, 'CameraMaxZoomDistance', 8, .15)
				TweenThing(plr, 'CameraMinZoomDistance', 8, .15)
				delay(.35,function()
					TweenThing(plr, 'CameraMaxZoomDistance', 15, .1)
					TweenThing(plr, 'CameraMinZoomDistance', 5, .1)
				end)
			end
		end
	end
	if (key.KeyCode == Enum.KeyCode.W) then
		if w then
			w = false
			if _G.sprinting and a or d then
				sprintcancel()
			end
		end
	end
	if (key.KeyCode == Enum.KeyCode.A) then
		if a then
			a = false
		end
	end
	if (key.KeyCode == Enum.KeyCode.S) then
		if s then
			s = false
		end
	end
	if (key.KeyCode == Enum.KeyCode.D) then
		if d then
			d = false
		end
	end
	if (key.KeyCode == gameRules.Keybinds.AnimationWheelKeybind) and not _G.Yeet then
		if not AW_GUI then return end;
		if AW_GUI.Enabled then
			AW_GUI.Enabled = false

			if ToolEquip then
				User.MouseIconEnabled = false
			end
		end
	end
	if (key.KeyCode == gameRules.ThirdPersonFreelookKey) and _G.ThirdPerson and ToolEquip then
		if MB3 then
			MB3 = false
			if gameRules.ThirdPersonCrosshair then
				CrosshairPart.Parent = workspace.Terrain
			end
			if not Seated then
				shiftLock(true)
			end
		end
	end

	if (key.KeyCode == Enum.KeyCode.Equals) then
		if script.Parent.Stances.Rappeling.Value == true then
			Network:FireServer("RopeEvent",{'Up',false})
		end
	end
	if (key.KeyCode == Enum.KeyCode.Minus) then
		if script.Parent.Stances.Rappeling.Value == true then
			Network:FireServer("RopeEvent",{'Down',false})
		end
	end

	if (key.KeyCode == gameRules.Keybinds.Reload) then
		if _G.ThirdPerson and ToolEquip and _G.reloading and WeaponData.ShellInsert then
			_G.CancelReload = true
		end	
	end
