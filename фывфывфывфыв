function sprintcancel()
	if not _G.sprinting then return end;
	if _G.ThirdPerson or not IsFirstPerson() then return end;
	if LeftShift then LeftShift = false end
	if aimfocus then aimfocus = false end
	if gameRules.ThirdPersonCrosshair then
		CrosshairPart.Parent = workspace.Terrain
	end
	runKeyDown 	= false
	Stand()
	if not CheckingMag and not _G.reloading and WeaponData and WeaponData.Type ~= "Grenade" and (_G.GunStance == 0 or _G.GunStance == 2 or _G.GunStance == 3) then
		_G.GunStance = 0
		if gameRules.RigType == Enum.HumanoidRigType.R15 then
			CharAnims.KeyframeEvent("PlayAnims","Idle",WeaponTool,false,true,nil,false)
		else
			Network:FireServer("GunStance", {_G.GunStance,AnimData})
		end
		IdleAnim()
	end
end

function aimcancel()
	if WeaponData.Type == "Grenade" or WeaponData.Type == "Melee" then return end;
	if not _G.ThirdPerson then
		for _,meshes in WeaponInHand:GetChildren() do
			if meshes.Name == 'REG' then
				meshes.Transparency = meshes:WaitForChild("OrigTrans").Value
			end
			if meshes.Name == 'REG2' then
				meshes.Transparency = meshes:WaitForChild("OrigTrans").Value
			end
			if meshes.Name == 'ADS' then
				TS:Create(meshes, TweenInfo.new(0.1), {Transparency = 1}):Play()
			end
			if meshes.Name == 'ADS2' then
				TS:Create(meshes, TweenInfo.new(0.1), {Transparency = 1}):Play()
			end
		end
	end
	if gameRules.DoF and WeaponData.ADSsettings.DoF == true and game.Lighting:FindFirstChildOfClass("DepthOfFieldEffect") then
		TS:Create(game.Lighting:FindFirstChildOfClass("DepthOfFieldEffect"), TweenInfo.new(0.3), {FocusDistance = 0}):Play()
	end
	if Stances == 0 and not Steady then
		if gameRules.UseMomentum then
