function Recoil()
	local name = WeaponData and WeaponData.RecoilProfile or "Rifle556"
	local profile = GetRecoilProfile(name) or GetRecoilProfile("Rifle556")
	if not profile then return end

	if gunRecoilState.currentProfile ~= profile then
		gunRecoilState:SetProfile(profile)
	end

	local adsViewKickScale  = (profile and profile.adsViewKickScale)  or 0.35
	local adsRecoilCFScale  = (profile and profile.adsRecoilCFScale)  or 0.45
	local adsSwayScale      = (profile and profile.adsSwayScale)      or 0.22
	local adsLagScale       = (profile and profile.adsLagScale)       or 0.15
	local adsCamRecoilPower = (profile and profile.adsCamRecoilPower) or 0.18

	local mult = 1.0
	if aimming     then mult = mult * (profile.aimMultiplier   or 0.3)  end
	if Crouched    then mult = mult * (profile.crouchMultiplier or 0.65) end
	if BipodActive then mult = mult * 0.3 end
	if charspeed > 0.1 then mult = mult * (profile.moveMultiplier or 1.2) end

	mult = mult * (RecoilPower or 1) * 5.5

	local hipRecoilScale = (profile and profile.hipRecoilScale) or 0.20
	if not aimming then mult = mult * hipRecoilScale end
	if aimming     then mult = mult * adsRecoilCFScale end

	gunRecoilState:Kick(profile, mult)

	if aimming then
		local camRecoil = gunRecoilState:GetCameraRecoil()
		cameraspring:accelerate(Vector3.new(
			math.rad(camRecoil.Y) * adsCamRecoilPower,
			math.rad(camRecoil.X) * adsCamRecoilPower,
			0
		))
	end

	local kick = aimming and 0.55 or 1.0
	if BipodActive then kick = kick * 0.4 end
	local hipMult = (not aimming) and (WeaponData.HipRecoilMult or 1.15) or 1
	local adsMult = aimming and (WeaponData.ADSRecoilMult or 0.85) or 1
	kick = kick * hipMult * adsMult

	local hipVMKickScale = (profile and profile.hipVMKickScale) or 0.20
	if not aimming then kick = kick * hipVMKickScale end

	local viewKickScale = aimming and adsViewKickScale or 1
	local kickVM = kick * viewKickScale
	local vm = 0.75
	local hitScale = 0.345
	local vertScale = 0.83

	VMKickPos:accelerate(Vector3.new(
		0,
		1.15 * kickVM * vm * hitScale * vertScale,
		-1.55 * kickVM * vm * hitScale
	))
	VMKickRot:accelerate(Vector3.new(
		math.rad(3.4) * kickVM * vm * hitScale * vertScale,
		math.rad(RAND(-2.2, 2.2, 0.5)) * kickVM * vm * hitScale,
		math.rad(RAND(-1.5, 2.2, 0.5)) * kickVM * vm * hitScale
	))
end

