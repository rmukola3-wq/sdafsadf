-- AnimationController и Animator (заполняются в setup)
local AnimController = nil
local Animator       = nil

-- Текущий активный трек (чтобы останавливать предыдущий при необходимости)
local currentTrack   = nil

-- Треки, помеченные как "прерываемые" (Idle, Sprint)
local INTERRUPTIBLE = {
	IdleAnim   = true,
	SprintAnim = true,
	HighReady  = true,
	LowReady   = true,
	Patrol     = true,
}

--- Проиграть анимацию по имени.
--- @param animType  string   — имя Animation-инстанса в Workspace.Animations
--- @param fadeTime  number?  — время плавного перехода (default 0.1)
--- @param looped    boolean? — форсировать зацикливание (override)
--- @return AnimationTrack | nil
local function PlayAnim(animType, fadeTime, looped)
	if not AnimController or not Animator then
		warn("[ACS Anim] AnimController не инициализирован при попытке: " .. tostring(animType))
		return nil
	end

	local animObj = AnimationMap[animType]
	if not animObj then
		warn("[ACS Anim] Анимация не найдена в Workspace.Animations: " .. tostring(animType))
		return nil
	end

	-- Останавливаем текущий трек только если он прерываемый
	if currentTrack and currentTrack.IsPlaying then
		local prevName = currentTrack.Name
		if INTERRUPTIBLE[prevName] then
			currentTrack:Stop(fadeTime or 0.1)
		end
	end

	local ok, track = pcall(function()
		return Animator:LoadAnimation(animObj)
	end)
	if not ok then
		warn("[ACS Anim] Ошибка LoadAnimation:", animType, track)
		return nil
	end

	track.Name = animType
	if looped ~= nil then
		track.Looped = looped
	end

	track:Play(fadeTime or 0.1)
	currentTrack = track
	return track
end

--- Остановить все треки Animator-а
local function StopAllAnims(fadeTime)
	if not Animator then return end
	for _, t in pairs(Animator:GetPlayingAnimationTracks()) do
		t:Stop(fadeTime or 0.15)
	end
	currentTrack = nil
end

