			CurAimpart = WeaponInHand:FindFirstChild('AimPart2') or CurAimpart
		else
			AimPartMode = 1
			CurAimpart = WeaponInHand:FindFirstChild('AimPart')
		end
	end
end

function Firemode()
	WeaponInHand.Handle.SafetyClick:Play()
	mouse1down = false
	local st = WeaponData.ShootType
	local fm = WeaponData.FireModes
	if     st==1 and fm.Burst                        then WeaponData.ShootType=2
	elseif st==1 and not fm.Burst and fm.Auto        then WeaponData.ShootType=3
	elseif st==2 and fm.Auto                         then WeaponData.ShootType=3
	elseif st==2 and fm.Semi and not fm.Auto         then WeaponData.ShootType=1
	elseif st==3 and fm.Semi                         then WeaponData.ShootType=1
	elseif st==3 and not fm.Semi and fm.Burst        then WeaponData.ShootType=2
	end
	UpdateGui()
end

