-- ═══════════════════════════════════════════════════════
--  RENDER STEPPED
-- ═══════════════════════════════════════════════════════

Run.RenderStepped:Connect(function(step)
	HeadMovement()
	if aimming then renderCam() end

	if ViewModel and LArm and RArm and WeaponInHand then
		local mouseDelta = User:GetMouseDelta()

		local adsSwayScale = aimming and 0.22 or 1
		SwaySpring:accelerate(Vector3.new((mouseDelta.x/60)*adsSwayScale, (mouseDelta.y/60)*adsSwayScale, 0))

		local rotK  = aimming and LAG_ROT_ADS or LAG_ROT_HIP
		local posK  = aimming and LAG_POS_ADS or LAG_POS_HIP
		local lagMax = aimming and LAG_MAX_ADS or LAG_MAX_HIP

		LagSpring.t = Vector3.new(
			math.clamp(-mouseDelta.Y * rotK, -lagMax, lagMax),
			math.clamp(-mouseDelta.X * rotK, -lagMax, lagMax),
			0
		)
		local lp = LagSpring.p
		local lagPosX = math.clamp(-mouseDelta.X * posK, -0.08, 0.08)
		local lagPosY = math.clamp(-mouseDelta.Y * posK, -0.06, 0.06)
		local lagCF = CFrame.new(lagPosX, lagPosY, 0) * CFrame.Angles(lp.X, lp.Y, 0)

		local swayVec = SwaySpring.p
		local Sway = CFrame.Angles(swayVec.Y, swayVec.X, swayVec.X)

		-- Bipod
		if BipodAtt then
			local BipodRay = Ray.new(UnderBarrelAtt.Main.Position, Vector3.new(0,-1.75,0))
			local BipodHit, BipodPos = workspace:FindPartOnRayWithIgnoreList(BipodRay, Ignore_Model, false, true)
			if BipodHit then
				CanBipod = true
				if BipodActive and not runKeyDown and (GunStance == 0 or GunStance == 2) then
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3=Color3.fromRGB(255,255,255), ImageTransparency=.123}):Play()
					if not aimming then
						BipodCF = lerpCF_dt(BipodCF, CFrame.new(0,(((UnderBarrelAtt.Main.Position-BipodPos).Magnitude)-1)*(-1.5),0), 14, step)
					else
						BipodCF = BipodCF:Lerp(CFrame.new(), .2)
					end
				else
					BipodActive = false; BipodCF = BipodCF:Lerp(CFrame.new(),.2)
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3=Color3.fromRGB(255,255,0), ImageTransparency=.5}):Play()
				end
			else
				BipodActive=false; CanBipod=false; BipodCF=BipodCF:Lerp(CFrame.new(),.2)
				TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1,Enum.EasingStyle.Linear), {ImageColor3=Color3.fromRGB(255,0,0), ImageTransparency=.5}):Play()
			end
		end

		-- VMKick CF
		local kp = VMKickPos.p; local kr = VMKickRot.p
		vmKickCF = CFrame.new(kp) * CFrame.Angles(kr.X, kr.Y, kr.Z)

		-- VM_Bump
		do
			local bumpTarget = CFrame.new(); local pushTarget = CFrame.new()
			VM_Bump = false
			local PUSH_START_DIST = 2.5; local PUSH_MAX = 1.5; local PUSH_SPEED = 22

			if ToolEquip and WeaponInHand and WeaponData and WeaponData.Type == "Gun"
				and AnimDebounce and not reloading and not CheckingMag then
				local headBaseCF = cam.CFrame * CFrame.new(0,0,-0.5) * gunbobcf
				local hit = workspace:Raycast(headBaseCF.Position, headBaseCF.LookVector * BUMP_DIST, (function()
					local p = RaycastParams.new()
					p.FilterType = Enum.RaycastFilterType.Exclude
					p.FilterDescendantsInstances = {char, cam, ViewModel, WeaponInHand, ACS_Workspace.Client, ACS_Workspace.Server}
					p.IgnoreWater = true
					return p
				end)())
				if hit and hit.Instance and hit.Instance:IsA("BasePart") and hit.Instance.Transparency < 1 and hit.Instance.Name ~= "HitIgnore" then
					VM_Bump = true; bumpTarget = BUMP_POSE
					local dist = (hit.Position - headBaseCF.Position).Magnitude
					if dist < PUSH_START_DIST then
						local t = math.clamp((PUSH_START_DIST - dist)/PUSH_START_DIST, 0, 1)
						pushTarget = CFrame.new(0, 0, t * PUSH_MAX)
					end
				end
			end

			bumpCF     = lerpCF_dt(bumpCF, bumpTarget, BUMP_SPEED, step)
			bumpPushCF = lerpCF_dt(bumpPushCF, pushTarget, PUSH_SPEED, step)

			if VM_Bump then
				if aimming then
					if not BumpAdsCut then
						BumpAdsCut = true; aimming = false; ADS(false)
					else
						aimming = false
					end
				end
			else
				BumpAdsCut = false
			end
		end

		AnimPart.CFrame = cam.CFrame * NearZ * BipodCF * maincf * bumpPushCF * bumpCF * lagCF * gunbobcf * aimcf * recoilcf * vmKickCF

		-- AimPart / maincf
		if CurAimpart and aimming and AnimDebounce and not CheckingMag then
			if not NVG or not WeaponInHand.AimPart:FindFirstChild("NVAim") then
				local zoom = AimPartMode == 1 and ModTable.ZoomValue or ModTable.Zoom2Value
				TS:Create(cam, AimTween, {FieldOfView = zoom}):Play()
				maincf = lerpCF_dt(maincf, maincf * CFrame.new(0,0,-.5) * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 14, step)
			else
				TS:Create(cam, AimTween, {FieldOfView = 70}):Play()
				maincf = maincf:Lerp(maincf * CFrame.new(0,0,-.5) * Sway:inverse() * (WeaponInHand.AimPart.CFrame * WeaponInHand.AimPart.NVAim.CFrame):toObjectSpace(cam.CFrame), 0.2)
			end
		else
			TS:Create(cam, AimTween, {FieldOfView = 70}):Play()
			maincf = lerpCF_dt(maincf, (WeaponData and WeaponData.MainCFrame or CFrame.new()) * Sway:inverse(), 14, step)
		end

		-- Reticle
		for _, Part in pairs(WeaponInHand:GetDescendants()) do
			if Part:IsA("BasePart") and Part.Name == "SightMark" then
				local ds = Part.CFrame:pointToObjectSpace(cam.CFrame.Position)/Part.Size
				Part.SurfaceGui.Border.Scope.Position = UDim2.new(.5+ds.x,0,.5-ds.y,0)
			end
		end

		-- Recoil CF
		recoilcf = gunRecoilState:Update(step)

		-- Crosshair
		if WeaponData and WeaponData.CrossHair then
			if aimming then
				CHup    = lerpUDim2_dt(CHup,    UDim2.new(.5,0,.5,0), 14, step)
				CHdown  = lerpUDim2_dt(CHdown,  UDim2.new(.5,0,.5,0), 14, step)
				CHleft  = lerpUDim2_dt(CHleft,  UDim2.new(.5,0,.5,0), 14, step)
				CHright = lerpUDim2_dt(CHright, UDim2.new(.5,0,.5,0), 14, step)
			else
				local N = ((WeaponData.CrosshairOffset + BSpread + charspeed*WeaponData.WalkMult*ModTable.WalkMult)/50)/10
				CHup    = lerpUDim2_dt(CHup,    UDim2.new(.5,0,.5-N,0), 35, step)
				CHdown  = lerpUDim2_dt(CHdown,  UDim2.new(.5,0,.5+N,0), 35, step)
				CHleft  = lerpUDim2_dt(CHleft,  UDim2.new(.5-N,0,.5,0), 35, step)
				CHright = lerpUDim2_dt(CHright, UDim2.new(.5+N,0,.5,0), 35, step)
			end
		else
			CHup    = lerpUDim2_dt(CHup,    UDim2.new(.5,0,.5,0), 14, step)
			CHdown  = lerpUDim2_dt(CHdown,  UDim2.new(.5,0,.5,0), 14, step)
			CHleft  = lerpUDim2_dt(CHleft,  UDim2.new(.5,0,.5,0), 14, step)
			CHright = lerpUDim2_dt(CHright, UDim2.new(.5,0,.5,0), 14, step)
		end
		Crosshair.Position = UDim2.new(0, mouse.X, 0, mouse.Y)
		Crosshair.Up.Position    = CHup
		Crosshair.Down.Position  = CHdown
		Crosshair.Left.Position  = CHleft
		Crosshair.Right.Position = CHright

		-- Spread decay
		if BSpread and WeaponData then
			local ct = time()
			if ct - LastSpreadUpdate > (60/WeaponData.ShootRate)*2 and not shooting and BSpread > WeaponData.MinSpread*ModTable.MinSpread then
				BSpread = math.max(WeaponData.MinSpread*ModTable.MinSpread, BSpread - WeaponData.AimInaccuracyDecrease*ModTable.AimInaccuracyDecrease)
			end
			if ct - LastSpreadUpdate > (60/WeaponData.ShootRate)*1.5 and not shooting and RecoilPower > WeaponData.MinRecoilPower*ModTable.MinRecoilPower then
				RecoilPower = math.max(WeaponData.MinRecoilPower*ModTable.MinRecoilPower, RecoilPower - WeaponData.RecoilPowerStepAmount*ModTable.RecoilPowerStepAmount)
			end
		end

		-- Gun bob
		if running then
			gunbobcf = lerpCF_dt(gunbobcf, CFrame.new(
				.025*(charspeed/10)*math.sin(tick()*8),
				.025*(charspeed/10)*math.cos(tick()*16),0)
				* CFrame.Angles(math.rad(math.sin(tick()*16)*(charspeed/10)), math.rad(math.cos(tick()*8)*(charspeed/10)), 0),
				6.3, step)
		else
			gunbobcf = lerpCF_dt(gunbobcf, CFrame.new(.005*math.sin(tick()*1.5), .005*math.cos(tick()*2.5), 0), 6.3, step)
		end

		-- Laser update
		if LaserActive and Pointer then
			Pointer.Transparency = (IRmode and not NVG) and 1 or 0
			if not gameRules.RealisticLaser then
				Pointer.Beam.Enabled = true
			elseif NVG then
				Pointer.Beam.Enabled = true
			else
				Pointer.Beam.Enabled = false
			end
			for _, Key in pairs(WeaponInHand:GetDescendants()) do
				if Key:IsA("BasePart") and Key.Name == "LaserPoint" then
					local lr = Ray.new(Key.CFrame.Position, Key.CFrame.LookVector * 1000)
					local Hit, Pos, Normal = workspace:FindPartOnRayWithIgnoreList(lr, Ignore_Model, false, true)
					Pointer.CFrame = Hit and CFrame.new(Pos, Pos+Normal) or CFrame.new(cam.CFrame.Position+Key.CFrame.LookVector*2000, Key.CFrame.LookVector)
					if HalfStep and gameRules.ReplicatedLaser then
						Evt.SVLaser:FireServer(Pos, 1, Pointer.Color, IRmode, WeaponTool)
					end
					break
				end
			end
		end
	end
end)

