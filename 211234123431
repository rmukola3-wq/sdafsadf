		equipTrack.Stopped:Connect(function()
			AnimDebounce = true
			PlayAnim("IdleAnim", 0.15, true)
		end)
	else
		AnimDebounce = true
		PlayAnim("IdleAnim", 0.15, true)
	end

	RunCheck()
