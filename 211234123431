function CheckForHumanoid(inst)
	if not inst then return false, nil end
	local hum = inst.Parent:FindFirstChildOfClass("Humanoid")
		or inst.Parent.Parent:FindFirstChildOfClass("Humanoid")
	return hum ~= nil, hum
end

function CastRay(Bullet, Origin)
	if not Bullet then return end

	local Bpos  = Bullet.Position
	local Bpos2 = cam.CFrame.Position
	local Debounce = false

	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = Ignore_Model
	raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
	raycastParams.IgnoreWater = true

	while Bullet do
		Run.Heartbeat:Wait()
		if not Bullet.Parent then break end

		Bpos = Bullet.Position
		local TotalDistTraveled = (Bullet.Position - Origin).Magnitude

		if TotalDistTraveled > 7000 then Bullet:Destroy(); break end

		for _, plyr in pairs(game.Players:GetChildren()) do
			if not Debounce and plyr:IsA('Player') and plyr ~= plr and plyr.Character and plyr.Character:FindFirstChild('Head') and (plyr.Character.Head.Position - Bpos).magnitude <= 25 then
				Evt.Whizz:FireServer(plyr)
				Evt.Suppression:FireServer(plyr, 1, nil, nil)
				Debounce = true
			end
		end

		local raycastResult = workspace:Raycast(Bpos2, (Bpos - Bpos2) * 1, raycastParams)
		if raycastResult then
			local Hit2 = raycastResult.Instance

			local function isIgnorable(h)
				if not h then return false end
				local pn = h.Parent and h.Parent.Name or ""
				return h.Name == "Ignorable" or h.Name == "Glass" or h.Name == "Ignore"
					or pn == "Top" or pn == "Helmet" or pn == "Up" or pn == "Down"
					or pn == "Face" or pn == "Olho" or pn == "Headset" or pn == "Numero"
					or pn == "Vest" or pn == "Chest" or pn == "Waist" or pn == "Back"
					or pn == "Belt" or pn == "Leg1" or pn == "Leg2" or pn == "Arm1" or pn == "Arm2"
			end

			if Hit2 and (Hit2.Parent:IsA('Accessory') or Hit2.Parent:IsA('Hat')) then
				for _, pl in pairs(game.Players:GetPlayers()) do
					if pl.Character then
						for _, hat in pairs(pl.Character:GetChildren()) do
							if hat:IsA("Accessory") then table.insert(Ignore_Model, hat) end
						end
					end
				end
				CastRay(Bullet, Origin)
				break
			end

			if isIgnorable(Hit2) then
				table.insert(Ignore_Model, Hit2)
				CastRay(Bullet, Origin)
				break
			end

			local bodyNames = {"Head","Right Arm","Left Arm","Right Leg","Left Leg",
				"UpperTorso","LowerTorso","RightUpperArm","RightLowerArm","RightHand",
				"LeftUpperArm","LeftLowerArm","LeftHand","RightUpperLeg","RightLowerLeg",
				"RightFoot","LeftUpperLeg","LeftLowerLeg","LeftFoot","Armor","EShield"}
			local isBody = false
			for _, n in pairs(bodyNames) do
				if Hit2.Name == n then isBody = true; break end
			end

			if not isBody and (Hit2.Transparency >= 1 or Hit2.CanCollide == false) then
				table.insert(Ignore_Model, Hit2)
				CastRay(Bullet, Origin)
				break
			end

			Bullet:Destroy()
			Debounce = true

			local FoundHuman, VitimaHuman = CheckForHumanoid(Hit2)
			HitMod.HitEffect(Ignore_Model, raycastResult.Position, Hit2, raycastResult.Normal, raycastResult.Material, WeaponData)
			Evt.HitEffect:FireServer(raycastResult.Position, Hit2, raycastResult.Normal, raycastResult.Material, WeaponData)

			local dist = (raycastResult.Position - Origin).Magnitude
			local SKP_02 = SKP_01.."-"..plr.UserId

			if FoundHuman and VitimaHuman.Health > 0 and WeaponData then
				local zone
				if Hit2.Name == "Head" or Hit2.Parent.Name == "Top" or Hit2.Parent.Name == "Headset"
					or Hit2.Parent.Name == "Olho" or Hit2.Parent.Name == "Face" or Hit2.Parent.Name == "Numero" then
					zone = 1
				elseif Hit2.Name == "Torso" or Hit2.Name == "UpperTorso" or Hit2.Name == "LowerTorso"
					or Hit2.Name == "Right Arm" or Hit2.Name == "Left Arm" or Hit2.Name == "RightUpperArm"
					or Hit2.Name == "RightLowerArm" or Hit2.Name == "RightHand" or Hit2.Name == "LeftUpperArm"
					or Hit2.Name == "LeftLowerArm" or Hit2.Name == "LeftHand"
					or Hit2.Parent.Name == "Chest" or Hit2.Parent.Name == "Waist" then
					zone = 2
				else
					zone = 3
				end
				Evt.Damage:InvokeServer(WeaponTool, VitimaHuman, dist, zone, WeaponData, ModTable, nil, nil, SKP_02)
			end
			break
		end

		Bpos2 = Bpos
	end
end

local Tracers = 0
function TracerCalculation()
	if WeaponData.Tracer or WeaponData.BulletFlare then
		if WeaponData.RandomTracer.Enabled then
			return math.random(1, 100) <= WeaponData.RandomTracer.Chance
		else
			if Tracers >= WeaponData.TracerEveryXShots then
				Tracers = 0; return true
			else
				Tracers = Tracers + 1; return false
			end
		end
	end
end

function CreateBullet()
	local Bullet = Instance.new("Part", ACS_Workspace.Client)
	Bullet.Name = plr.Name.."_Bullet"
	Bullet.CanCollide = false
	Bullet.Shape = Enum.PartType.Ball
	Bullet.Transparency = 1
	Bullet.Size = Vector3.new(1,1,1)

	local Origin    = WeaponInHand.Handle.Muzzle.WorldPosition
	local Direction = WeaponInHand.Handle.Muzzle.WorldCFrame.LookVector
		+ (WeaponInHand.Handle.Muzzle.WorldCFrame.UpVector
			* (((WeaponData.BulletDrop * WeaponData.CurrentZero/4)/WeaponData.MuzzleVelocity))/2)
	local WalkMul   = WeaponData.WalkMult * ModTable.WalkMult
	local BColor    = Color3.fromRGB(255,255,255)
	local balaspread

	if aimming and WeaponData.Bullets <= 1 then
		balaspread = CFrame.Angles(
			math.rad(RAND(-BSpread-(charspeed/1)*WalkMul, BSpread+(charspeed/1)*WalkMul) / (10*WeaponData.AimSpreadReduction)),
			math.rad(RAND(-BSpread-(charspeed/1)*WalkMul, BSpread+(charspeed/1)*WalkMul) / (10*WeaponData.AimSpreadReduction)),
			math.rad(RAND(-BSpread-(charspeed/1)*WalkMul, BSpread+(charspeed/1)*WalkMul) / (10*WeaponData.AimSpreadReduction))
		)
	else
		balaspread = CFrame.Angles(
			math.rad(RAND(-BSpread-(charspeed/1)*WalkMul, BSpread+(charspeed/1)*WalkMul) / 10),
			math.rad(RAND(-BSpread-(charspeed/1)*WalkMul, BSpread+(charspeed/1)*WalkMul) / 10),
			math.rad(RAND(-BSpread-(charspeed/1)*WalkMul, BSpread+(charspeed/1)*WalkMul) / 10)
		)
	end

	Direction = balaspread * Direction
	local Visivel = TracerCalculation()

	if WeaponData.RainbowMode then
		BColor = Color3.fromRGB(math.random(0,255),math.random(0,255),math.random(0,255))
	else
		BColor = WeaponData.TracerColor
	end

	if Visivel then
		if gameRules.ReplicatedBullets then
			Evt.ServerBullet:FireServer(Origin, Direction, WeaponData, ModTable)
		end
		if WeaponData.Tracer then
			local At1 = Instance.new("Attachment", Bullet); At1.Name = "At1"; At1.Position = Vector3.new(-.05,0,0)
			local At2 = Instance.new("Attachment", Bullet); At2.Name = "At2"; At2.Position = Vector3.new(.05,0,0)
			local Trail = Instance.new("Trail", Bullet)
			Trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0,0),NumberSequenceKeypoint.new(1,1)})
			Trail.WidthScale   = NumberSequence.new({NumberSequenceKeypoint.new(0,2,0),NumberSequenceKeypoint.new(1,1)})
			Trail.Color = ColorSequence.new(BColor)
			Trail.Texture = "rbxassetid://232918622"
			Trail.TextureMode = Enum.TextureMode.Stretch
			Trail.FaceCamera = true; Trail.LightEmission = 1; Trail.LightInfluence = 0
			Trail.Lifetime = .25; Trail.Attachment0 = At1; Trail.Attachment1 = At2
		end
		if WeaponData.BulletFlare then
			local bg = Instance.new("BillboardGui", Bullet)
			bg.Adornee = Bullet; bg.Enabled = false
			local sz = math.random(275,375)/10
			bg.Size = UDim2.new(sz,0,sz,0); bg.LightInfluence = 0
			local flash = Instance.new("ImageLabel", bg)
			flash.BackgroundTransparency = 1; flash.Size = UDim2.new(1,0,1,0)
			flash.Image = "http://www.roblox.com/asset/?id=1047066405"
			flash.ImageTransparency = math.random(2,5)/15; flash.ImageColor3 = BColor
			spawn(function() wait(.1); if Bullet:FindFirstChild("BillboardGui") then Bullet.BillboardGui.Enabled = true end end)
		end
	end

	local BF = Instance.new("BodyForce", Bullet)
	Bullet.CFrame = CFrame.new(Origin, Origin + Direction)
	Bullet:ApplyImpulse(Direction * WeaponData.MuzzleVelocity * ModTable.MuzzleVelocity)
	BF.Force = Vector3.new(0, Bullet:GetMass() * 196.2 - WeaponData.BulletDrop * 196.2, 0)

	game.Debris:AddItem(Bullet, 5)
	CastRay(Bullet, Origin)
end

